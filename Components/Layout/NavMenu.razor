@implements IDisposable

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="dashboard">Fitness App</a>
        <div class="nav-top-actions">
        <NotificationCenter />
        <div class="theme-menu" @onclick:stopPropagation>
            <button type="button" class="theme-toggle" title="Theme" aria-label="Theme" aria-expanded="@_themesOpen" @onclick="ToggleThemes">
                <span class="icon @ThemeIconClass" aria-hidden="true"></span>
            </button>
            @if (_themesOpen)
            {
                <div class="theme-dropdown" role="menu">
                    @foreach (var theme in SettingsService.Themes)
                    {
                        var isActive = theme.Key == _currentTheme;
                        <button type="button" class="theme-option @(isActive ? "active" : "")" role="menuitem" @onclick="() => SelectTheme(theme.Key)">
                            <span class="icon @(theme.IsLight ? "icon-sun" : "icon-moon")" aria-hidden="true"></span>
                            <span>@theme.Label</span>
                            @if (isActive)
                            {
                                <span class="icon icon-check theme-option-check" aria-hidden="true"></span>
                            }
                        </button>
                    }
                </div>
            }
        </div>
        </div>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="nav flex-column">
        <div class="nav-main">
            <div class="nav-item px-3">
                <a class="nav-link @(IsActive("dashboard", "schedule") ? "active" : "")" href="dashboard">
                    <span class="bi bi-house-door-fill-nav-menu" aria-hidden="true"></span> Dashboard
                </a>
            </div>

            <div class="nav-item px-3">
                <a class="nav-link @(IsActive("diet", "diet-plans", "foods") ? "active" : "")" href="diet">
                    <span class="bi bi-diet-nav-menu" aria-hidden="true"></span> Diet
                </a>
            </div>

            <div class="nav-item px-3">
                <a class="nav-link @(IsActive("training", "programs", "exercises", "live-workout") ? "active" : "")" href="training">
                    <span class="bi bi-workouts-nav-menu" aria-hidden="true"></span> Training
                </a>
            </div>

            <div class="nav-item px-3">
                <a class="nav-link @(IsActive("progress") ? "active" : "")" href="progress">
                    <span class="bi bi-progress-nav-menu" aria-hidden="true"></span> Progress
                </a>
            </div>

            <div class="nav-item px-3">
                <a class="nav-link @(IsActive("social", "social/global") ? "active" : "")" href="social">
                    <span class="bi bi-social-nav-menu" aria-hidden="true"></span> Social
                </a>
            </div>
        </div>

        <div class="nav-footer px-3">
            <div class="nav-profile @(_statusMenuOpen ? "menu-open" : "")">
                <a class="nav-profile-id @(IsActive("profile") ? "active" : "")" href="profile" title="View profile">
                    <span class="nav-avatar">
                        @if (!string.IsNullOrEmpty(_avatarData))
                        {
                            <img src="@_avatarData" alt="Profile picture" />
                        }
                        else
                        {
                            <span class="nav-avatar-initials">@Initials</span>
                        }
                        <span class="nav-status-dot status-@_status"></span>
                    </span>
                    <span class="nav-profile-meta">
                        <span class="nav-profile-name">@_username</span>
                        <span class="nav-profile-status">@PresenceStatus.Label(_status)</span>
                    </span>
                </a>
                <div class="nav-status-control" @onclick:stopPropagation>
                    <button type="button" class="nav-status-toggle" title="Set status" aria-label="Set status" aria-expanded="@_statusMenuOpen" @onclick="ToggleStatusMenu">
                        <span class="bi bi-chevron-nav-menu" aria-hidden="true"></span>
                    </button>
                    @if (_statusMenuOpen)
                    {
                        <div class="nav-status-menu" role="menu">
                            @foreach (var option in PresenceStatus.Options)
                            {
                                <button type="button" class="nav-status-option @(option.Key == _status ? "active" : "")" role="menuitem" @onclick="() => SetStatus(option.Key)">
                                    <span class="status-dot status-@option.Key"></span>
                                    <span>@option.Label</span>
                                </button>
                            }
                        </div>
                    }
                </div>
            </div>

            <div class="nav-footer-actions">
                <button type="button" class="nav-footer-button" @onclick="HandleLogout">
                    <span class="bi bi-logout-nav-menu" aria-hidden="true"></span>
                    <span>Logout</span>
                </button>

                @if (_isAdmin)
                {
                    <NavLink class="nav-icon-button" href="admin" title="Admin" aria-label="Admin">
                        <span class="bi bi-crown-nav-menu" aria-hidden="true"></span>
                    </NavLink>
                }

                <NavLink class="nav-icon-button" href="settings" title="Settings" aria-label="Settings">
                    <span class="bi bi-settings-nav-menu" aria-hidden="true"></span>
                </NavLink>
            </div>
        </div>
    </nav>
</div>

@code {
    [Inject] private CustomAuthStateProvider AuthState { get; set; } = default!;
    [Inject] private NavigationManager Navigation { get; set; } = default!;
    [Inject] private SettingsService SettingsSvc { get; set; } = default!;
    [Inject] private ProfileService ProfileSvc { get; set; } = default!;
    [Inject] private ProfilePresenceState Presence { get; set; } = default!;
    [Parameter] public EventCallback<string> OnThemeChanged { get; set; }

    private bool _isAdmin;
    private bool _themesOpen;
    private bool _statusMenuOpen;
    private int _userId;
    private string _currentTheme = "night";
    private string _username = "";
    private string? _avatarData;
    private string _status = PresenceStatus.Online;

    private string Initials
    {
        get
        {
            var source = string.IsNullOrWhiteSpace(_username) ? "?" : _username.Trim();
            return source.Length == 0 ? "?" : source[..1].ToUpperInvariant();
        }
    }

    private ThemeOption CurrentTheme => SettingsService.Themes.FirstOrDefault(t => t.Key == _currentTheme) ?? SettingsService.Themes[0];
    private string ThemeIconClass => CurrentTheme.IsLight ? "icon-sun" : "icon-moon";

    private bool IsActive(params string[] paths) => HubNav.IsInGroup(Navigation, paths);

    protected override void OnInitialized()
    {
        Navigation.LocationChanged += OnLocationChanged;
        Presence.OnChange += HandlePresenceChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        try
        {
            var state = await AuthState.GetAuthenticationStateAsync();
            _isAdmin = state.User.IsInRole("Admin");
            if (state.User.Identity is { IsAuthenticated: true })
            {
                _userId = int.Parse(state.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)!.Value);
                _currentTheme = await SettingsSvc.GetThemeAsync(_userId);
                await LoadProfileSummary();
                await OnThemeChanged.InvokeAsync(_currentTheme);
            }
            StateHasChanged();
        }
        catch { }
    }

    private async Task LoadProfileSummary()
    {
        if (_userId == 0) return;
        var user = await ProfileSvc.GetUserAsync(_userId);
        if (user is null) return;
        _username = user.Username;
        _avatarData = user.AvatarData;
        _status = PresenceStatus.Normalize(user.Status);
    }

    private void HandlePresenceChanged()
    {
        InvokeAsync(async () =>
        {
            await LoadProfileSummary();
            StateHasChanged();
        });
    }

    private void ToggleStatusMenu()
    {
        _statusMenuOpen = !_statusMenuOpen;
    }

    private async Task SetStatus(string status)
    {
        _status = PresenceStatus.Normalize(status);
        _statusMenuOpen = false;
        if (_userId > 0)
        {
            await ProfileSvc.UpdateStatusAsync(_userId, _status);
            Presence.NotifyChanged();
        }
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        _statusMenuOpen = false;
        InvokeAsync(StateHasChanged);
    }

    private void ToggleThemes()
    {
        _themesOpen = !_themesOpen;
    }

    private async Task SelectTheme(string theme)
    {
        _currentTheme = SettingsService.NormalizeTheme(theme);
        _themesOpen = false;
        if (_userId > 0)
            await SettingsSvc.SetThemeAsync(_userId, _currentTheme);
        await OnThemeChanged.InvokeAsync(_currentTheme);
    }

    private async Task HandleLogout()
    {
        await AuthState.LogoutAsync();
        try { Navigation.NavigateTo("/login", forceLoad: true); } catch { }
    }

    public void Dispose()
    {
        Navigation.LocationChanged -= OnLocationChanged;
        Presence.OnChange -= HandlePresenceChanged;
    }
}
