<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="dashboard">Fitness App</a>
        <div class="theme-menu" @onclick:stopPropagation>
            <button type="button" class="theme-toggle" title="Theme" aria-label="Theme" aria-expanded="@_themesOpen" @onclick="ToggleThemes">
                <span class="icon @ThemeIconClass" aria-hidden="true"></span>
            </button>
            @if (_themesOpen)
            {
                <div class="theme-dropdown" role="menu">
                    @foreach (var theme in SettingsService.Themes)
                    {
                        var isActive = theme.Key == _currentTheme;
                        <button type="button" class="theme-option @(isActive ? "active" : "")" role="menuitem" @onclick="() => SelectTheme(theme.Key)">
                            <span class="icon @(theme.IsLight ? "icon-sun" : "icon-moon")" aria-hidden="true"></span>
                            <span>@theme.Label</span>
                            @if (isActive)
                            {
                                <span class="icon icon-check theme-option-check" aria-hidden="true"></span>
                            }
                        </button>
                    }
                </div>
            }
        </div>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="nav flex-column">
        <div class="nav-main">
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="dashboard" Match="NavLinkMatch.All">
                    <span class="bi bi-house-door-fill-nav-menu" aria-hidden="true"></span> Dashboard
                </NavLink>
            </div>

            <div class="nav-item px-3">
                <NavLink class="nav-link" href="schedule">
                    <span class="bi bi-schedule-nav-menu" aria-hidden="true"></span> Schedule
                </NavLink>
            </div>

            <button type="button" class="nav-divider nav-section-toggle @(_trainingOpen ? "expanded" : "")" aria-expanded="@_trainingOpen" @onclick="ToggleTraining" @onclick:stopPropagation="true">
                <span>Training</span>
                <span class="bi bi-chevron-nav-menu" aria-hidden="true"></span>
            </button>

            @if (_trainingOpen)
            {
                <div class="nav-section-items">
                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="training">
                            <span class="bi bi-workouts-nav-menu" aria-hidden="true"></span> Training
                        </NavLink>
                    </div>

                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="programs">
                            <span class="bi bi-programs-nav-menu" aria-hidden="true"></span> Programs
                        </NavLink>
                    </div>

                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="exercises">
                            <span class="bi bi-exercises-nav-menu" aria-hidden="true"></span> Exercises
                        </NavLink>
                    </div>

                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="live-workout">
                            <span class="bi bi-live-nav-menu" aria-hidden="true"></span> Live Session
                        </NavLink>
                    </div>
                </div>
            }

            <div class="nav-item px-3">
                <NavLink class="nav-link" href="progress">
                    <span class="bi bi-progress-nav-menu" aria-hidden="true"></span> Progress
                </NavLink>
            </div>

            <div class="nav-item px-3">
                <NavLink class="nav-link" href="profile">
                    <span class="bi bi-person-nav-menu" aria-hidden="true"></span> Profile
                </NavLink>
            </div>
        </div>

        <div class="nav-footer px-3">
            <div class="nav-footer-actions">
                <button type="button" class="nav-footer-button" @onclick="HandleLogout">
                    <span class="bi bi-logout-nav-menu" aria-hidden="true"></span>
                    <span>Logout</span>
                </button>

                @if (_isAdmin)
                {
                    <NavLink class="nav-icon-button" href="admin" title="Admin" aria-label="Admin">
                        <span class="bi bi-crown-nav-menu" aria-hidden="true"></span>
                    </NavLink>
                }

                <NavLink class="nav-icon-button" href="settings" title="Settings" aria-label="Settings">
                    <span class="bi bi-settings-nav-menu" aria-hidden="true"></span>
                </NavLink>
            </div>
        </div>
    </nav>
</div>

@code {
    [Inject] private CustomAuthStateProvider AuthState { get; set; } = default!;
    [Inject] private NavigationManager Navigation { get; set; } = default!;
    [Inject] private SettingsService SettingsSvc { get; set; } = default!;
    [Parameter] public EventCallback<string> OnThemeChanged { get; set; }

    private bool _isAdmin;
    private bool _themesOpen;
    private bool _trainingOpen = true;
    private int _userId;
    private string _currentTheme = "night";

    private ThemeOption CurrentTheme => SettingsService.Themes.FirstOrDefault(t => t.Key == _currentTheme) ?? SettingsService.Themes[0];
    private string ThemeIconClass => CurrentTheme.IsLight ? "icon-sun" : "icon-moon";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        try
        {
            var state = await AuthState.GetAuthenticationStateAsync();
            _isAdmin = state.User.IsInRole("Admin");
            if (state.User.Identity is { IsAuthenticated: true })
            {
                _userId = int.Parse(state.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)!.Value);
                _currentTheme = await SettingsSvc.GetThemeAsync(_userId);
                await OnThemeChanged.InvokeAsync(_currentTheme);
            }
            StateHasChanged();
        }
        catch { }
    }

    private void ToggleThemes()
    {
        _themesOpen = !_themesOpen;
    }

    private void ToggleTraining()
    {
        _trainingOpen = !_trainingOpen;
    }

    private async Task SelectTheme(string theme)
    {
        _currentTheme = SettingsService.NormalizeTheme(theme);
        _themesOpen = false;
        if (_userId > 0)
            await SettingsSvc.SetThemeAsync(_userId, _currentTheme);
        await OnThemeChanged.InvokeAsync(_currentTheme);
    }

    private async Task HandleLogout()
    {
        await AuthState.LogoutAsync();
        try { Navigation.NavigateTo("/login", forceLoad: true); } catch { }
    }
}
