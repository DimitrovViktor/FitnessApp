    private async Task CopyWorkout()
    {
        if (_previewWorkout is null) return;
        await WorkoutService.CopyWorkoutToUserAsync(_previewWorkout.Id, _userId);
        _myWorkouts = await WorkoutService.GetUserWorkoutsAsync(_userId);
