@inject WorkoutService WorkoutService
@inject SettingsService SettingsSvc
@inject CustomAuthStateProvider AuthState
@inject NavigationManager Navigation
@using FitnessApp.Models.Enums

<PageTitle>Training - Fitness App</PageTitle>

@if (_isLoading)
{
    <div class="loading-state"><p>Loading...</p></div>
}
else
{
    <div class="training-page">
        <div class="hub-actions">
            <button type="button" class="btn-action" @onclick="OpenBuilder">+ New Training</button>
        </div>

        <div class="training-path-grid">
            @foreach (var category in TrainingCategories)
            {
                var categoryKey = category.Key;
                <button type="button" class="training-path-card @(_trainingCategory == categoryKey ? "active" : "")" @onclick="() => SelectTrainingCategory(categoryKey)">
                    <span class="training-path-title">@category.Label</span>
                    <span class="training-path-copy">@category.Description</span>
                    <span class="training-path-count">@GetTrainingCategorySummary(categoryKey)</span>
                </button>
            }
        </div>

        @if (!string.IsNullOrEmpty(_msg))
        {
            <div class="@(_msgErr ? "toast-err" : "toast-ok")">@_msg</div>
        }

        <div class="recent-activity-block">
            <div class="section-line">
                <h2 class="section-heading">Recent Activity</h2>
                <span>@GetTrainingCategoryLabel(_trainingCategory)</span>
            </div>
            @{ var recentItems = GetRecentActivity(); }
            @if (recentItems.Count == 0)
            {
                <div class="empty compact"><p>No recent activity in this section yet.</p></div>
            }
            else
            {
                <div class="activity-list">
                    @foreach (var item in recentItems)
                    {
                        <button type="button" class="activity-row" @onclick="() => OpenRecentActivity(item)">
                            <span class="activity-main">
                                <span class="activity-name">@item.Name</span>
                                <span class="activity-meta">@item.Type · @item.Detail</span>
                            </span>
                            <span class="activity-date">@item.When.ToLocalTime().ToString("MMM d")</span>
                        </button>
                    }
                </div>
            }
        </div>

        <div class="tab-bar training-tabs">
            <button type="button" class="tab @(_workoutViewTab == 0 ? "active" : "")" @onclick="() => _workoutViewTab = 0">My Activities</button>
            <button type="button" class="tab @(_workoutViewTab == 1 ? "active" : "")" @onclick="() => _workoutViewTab = 1">My Programs</button>
            <button type="button" class="tab @(_workoutViewTab == 2 ? "active" : "")" @onclick="() => _workoutViewTab = 2">Browse Activities</button>
            <button type="button" class="tab @(_workoutViewTab == 3 ? "active" : "")" @onclick="() => _workoutViewTab = 3">Browse Programs</button>
        </div>

        @if (_workoutViewTab == 0)
        {
            var workouts = FilteredMyWorkouts.ToList();
            <h2 class="section-heading">My @GetTrainingCategoryLabel(_trainingCategory) Activities</h2>
            @if (workouts.Count == 0)
            {
                <div class="empty"><p>No saved activities in this section yet. Use New Training or browse premade activities.</p></div>
            }
            else
            {
                <div class="card-grid">
                    @foreach (var w in workouts)
                    {
                        <div class="wk-card" @onclick="() => OpenWorkoutPreview(w.Id, true)">
                            <h3>@w.Name</h3>
                            @if (w.Program is not null) { <span class="badge-purple">@w.Program.Name</span> }
                            <div class="wk-meta">
                                <span>@GetWorkoutTypeLabel(w)</span>
                                <span>@w.WorkoutExercises.Count exercises</span>
                                <span>@w.WorkoutExercises.Sum(x => x.Sets) sets</span>
                                <span>~@WorkoutService.EstimateWorkoutMinutesFromWE(w.WorkoutExercises) min</span>
                            </div>
                            <div class="chip-row">
                                @foreach (var m in GetPrimaryMuscles(w.WorkoutExercises))
                                {
                                    <span class="chip-sm">@m</span>
                                }
                            </div>
                        </div>
                    }
                </div>
            }
        }
        else if (_workoutViewTab == 1)
        {
            var programs = FilteredMyPrograms.ToList();
            <h2 class="section-heading">My @GetTrainingCategoryLabel(_trainingCategory) Programs</h2>
            @if (programs.Count == 0)
            {
                <div class="empty"><p>No saved programs in this section yet. Browse programs to save one.</p></div>
            }
            else
            {
                <div class="card-grid">
                    @foreach (var p in programs)
                    {
                        <div class="wk-card" @onclick="() => OpenProgramPreview(p, true)">
                            <h3>@p.Name</h3>
                            <div class="wk-meta">
                                <span>@GetProgramTypeLabel(p)</span>
                                <span>@p.DurationWeeks weeks</span>
                                <span>@p.DaysPerWeek d/wk</span>
                                <span>@p.Workouts.Count workouts</span>
                            </div>
                            <div class="chip-row">
                                @if (p.TargetLevel is not null) { <span class="chip-sm">@p.TargetLevel</span> }
                                @if (p.TargetGoal is not null) { <span class="chip-sm">@FormatGoal(p.TargetGoal)</span> }
                            </div>
                        </div>
                    }
                </div>
            }
        }
        else if (_workoutViewTab == 2)
        {
            var workouts = FilteredPremadeWorkouts.ToList();
            <h2 class="section-heading">Browse @GetTrainingCategoryLabel(_trainingCategory) Activities</h2>
            @if (workouts.Count == 0)
            {
                <div class="empty"><p>No premade activities are available for this section yet.</p></div>
            }
            else
            {
                <div class="card-grid">
                    @foreach (var w in workouts)
                    {
                        <div class="wk-card" @onclick="() => OpenWorkoutPreview(w.Id, false)">
                            <h3>@w.Name</h3>
                            @if (w.Program is not null) { <span class="badge-purple">@w.Program.Name</span> }
                            <div class="wk-meta">
                                <span>@GetWorkoutTypeLabel(w)</span>
                                <span>@w.WorkoutExercises.Count exercises</span>
                                <span>@w.WorkoutExercises.Sum(x => x.Sets) sets</span>
                            </div>
                        </div>
                    }
                </div>
            }
        }
        else
        {
            var programs = FilteredPrebuiltPrograms.ToList();
            <h2 class="section-heading">Browse @GetTrainingCategoryLabel(_trainingCategory) Programs</h2>
            @if (programs.Count == 0)
            {
                <div class="empty"><p>No prebuilt programs are available for this section yet.</p></div>
            }
            else
            {
                <div class="card-grid">
                    @foreach (var p in programs)
                    {
                        <div class="wk-card" @onclick="() => OpenProgramPreview(p, false)">
                            <h3>@p.Name</h3>
                            <span class="badge-purple">Pre-built</span>
                            <div class="wk-meta">
                                <span>@GetProgramTypeLabel(p)</span>
                                <span>@p.DurationWeeks weeks</span>
                                <span>@p.DaysPerWeek d/wk</span>
                                <span>@p.Workouts.Count workouts</span>
                            </div>
                            <div class="chip-row">
                                @if (p.TargetLevel is not null) { <span class="chip-sm">@p.TargetLevel</span> }
                                @if (p.TargetGoal is not null) { <span class="chip-sm">@FormatGoal(p.TargetGoal)</span> }
                            </div>
                        </div>
                    }
                </div>
            }
        }

    </div>
}

<Modal IsOpen="_showBuilder" OnClose="CloseBuilder" Size="full">
    <div class="bld">
        <div class="bld-top">
            <input class="bld-name" @bind="_form.Name" placeholder="Workout name..." />
            <div class="bld-badges">
                <span class="bdg bdg-cal">@FormatEnergyValue(_estCal)</span>
                <span class="bdg bdg-sets">@_form.Exercises.Sum(e => e.Sets) sets</span>
                <span class="bdg bdg-ex">@_form.Exercises.Count exercises</span>
                <span class="bdg bdg-time">~@_estMin min</span>
            </div>
        </div>

        @if (_warnings.Count > 0)
        {
            <div class="bld-warnings">
                @foreach (var w in _warnings) { <div class="warn-item">@w</div> }
            </div>
        }

        <div class="bld-search-row">
            <input class="bld-search" @bind="_search" @bind:event="oninput" placeholder="Search exercises..." />
            <button type="button" class="filter-btn @(_filterMuscles.Count > 0 ? "active" : "")" @onclick="() => _showFilterMuscle = !_showFilterMuscle">Muscles @(_filterMuscles.Count > 0 ? $"({_filterMuscles.Count})" : "")</button>
            <button type="button" class="filter-btn @(_filterEquip.Count > 0 ? "active" : "")" @onclick="() => _showFilterEquip = !_showFilterEquip">Equipment @(_filterEquip.Count > 0 ? $"({_filterEquip.Count})" : "")</button>
            <button type="button" class="filter-btn @(!string.IsNullOrEmpty(_filterMove) ? "active" : "")" @onclick="() => _showFilterMove = !_showFilterMove">Type @(!string.IsNullOrEmpty(_filterMove) ? "(1)" : "")</button>
            @if (_filterMuscles.Count > 0 || _filterEquip.Count > 0 || !string.IsNullOrEmpty(_filterMove))
            {
                <button type="button" class="filter-clear" @onclick="ClearFilters">Clear</button>
            }
        </div>

        @if (_showFilterMuscle)
        {
            <div class="filter-panel">
                @foreach (var mg in _allMuscleGroups)
                {
                    <button type="button" class="fp-chip @(_filterMuscles.Contains(mg.Name) ? "sel" : "")" @onclick="() => ToggleFilter(_filterMuscles, mg.Name)">@mg.Name</button>
                }
            </div>
        }
        @if (_showFilterEquip)
        {
            <div class="filter-panel">
                @foreach (var eq in _allEquipment)
                {
                    <button type="button" class="fp-chip @(_filterEquip.Contains(eq.Name) ? "sel" : "")" @onclick="() => ToggleFilter(_filterEquip, eq.Name)">@eq.Name</button>
                }
            </div>
        }
        @if (_showFilterMove)
        {
            <div class="filter-panel">
                @foreach (var mt in Enum.GetValues<MovementType>())
                {
                    <button type="button" class=@(_filterMove == mt.ToString() ? "fp-chip sel" : "fp-chip") @onclick="@(() => ToggleMoveFilter(mt))">@mt</button>
                }
            </div>
        }

        <div class="bld-body">
            <div class="bld-section">
                <h3 class="sec-title">Selected (@_form.Exercises.Count)</h3>
                @if (_form.Exercises.Count == 0)
                {
                    <div class="empty-sm">Add exercises from the library below</div>
                }
                else
                {
                    @for (int i = 0; i < _form.Exercises.Count; i++)
                    {
                        var idx = i;
                        var entry = _form.Exercises[idx];
                        <div class="sel-card @(_activeExIdx == idx ? "active" : "") @(entry.SupersetGroup.HasValue ? "in-superset" : "")" @onclick="() => ActivateSelected(idx)">
                            <div class="sel-top">
                                <div class="sel-ord">
                                    <button type="button" class="ord-btn" disabled="@(idx == 0)" @onclick:stopPropagation @onclick="() => Move(idx, -1)" aria-label="Move up"><span class="icon icon-up" aria-hidden="true"></span></button>
                                    <span>@(idx + 1)</span>
                                    <button type="button" class="ord-btn" disabled="@(idx == _form.Exercises.Count - 1)" @onclick:stopPropagation @onclick="() => Move(idx, 1)" aria-label="Move down"><span class="icon icon-down" aria-hidden="true"></span></button>
                                </div>
                                <div class="sel-info">
                                    <span class="sel-name">@entry.Exercise?.Name</span>
                                    <span class="sel-meta">@(entry.Exercise is not null ? MuscleStr(entry.Exercise) : "")@SupersetEntryMeta(entry)</span>
                                </div>
                                <button type="button" class="btn-danger-xs" @onclick:stopPropagation @onclick="() => RemoveEntry(idx)">Remove</button>
                            </div>
                            <div class="sel-fields">
                                <div class="sf"><label>Sets</label><input type="number" @bind="entry.Sets" @bind:after="Recalc" min="1" @onclick:stopPropagation /></div>
                                <div class="sf"><label>Reps</label><input type="number" @bind="entry.Reps" @bind:after="Recalc" min="1" @onclick:stopPropagation /></div>
                                <div class="sf"><label>Rest(s)</label><input type="number" @bind="entry.RestTimeSec" @bind:after="Recalc" min="0" @onclick:stopPropagation /></div>
                                <span class="sel-kcal">~@FormatEnergyValue(EstSingle(entry))</span>
                            </div>
                            <div class="superset-builder-row" @onclick:stopPropagation>
                                @if (entry.SupersetGroup.HasValue)
                                {
                                    <span class="superset-pill">@SupersetLabel(entry)</span>
                                    <div class="sf superset-rounds-field"><label>Superset rounds</label><input type="number" value="@GetSupersetRounds(entry)" min="1" @onchange="(e) => SetSupersetRounds(entry, e)" /></div>
                                    <div class="sf superset-rest-field"><label>Rest after this exercise (seconds)</label><input type="number" @bind="entry.SupersetRestAfterSec" @bind:after="Recalc" min="0" /></div>
                                    <span class="superset-note">This exercise runs for @entry.Sets of @GetSupersetRounds(entry) rounds.</span>
                                    <button type="button" class="superset-btn" @onclick="() => RemoveFromSuperset(idx)">Remove From Superset</button>
                                }
                                else
                                {
                                    <button type="button" class="superset-btn" disabled="@(idx == 0)" @onclick="() => GroupWithPrevious(idx)">Group With Previous</button>
                                    <button type="button" class="superset-btn" @onclick="() => StartSupersetAt(idx)">Start Superset</button>
                                }
                            </div>
                        </div>
                    }
                }
            </div>

            @if (_suggestions.Count > 0)
            {
                <div class="bld-section">
                    <div class="sec-header" @onclick="() => _sugCollapsed = !_sugCollapsed">
                        <h3 class="sec-title">Suggested (@_suggestions.Count)</h3>
                        <span class="sec-toggle">@(_sugCollapsed ? "+" : "-")</span>
                    </div>
                    @if (!_sugCollapsed)
                    {
                        <div class="lib-grid">
                            @foreach (var ex in _suggestions)
                            {
                                <div class="lib-card sug" @onclick="() => OpenExPreview(ex)">
                                    <span class="lib-name">@ex.Name</span>
                                    <span class="lib-meta">@MuscleStr(ex)</span>
                                </div>
                            }
                        </div>
                    }
                </div>
            }

            <div class="bld-section">
                <div class="sec-header" @onclick="() => _libCollapsed = !_libCollapsed">
                    <h3 class="sec-title">Exercise Library (@GetFiltered().Count)</h3>
                    <span class="sec-toggle">@(_libCollapsed ? "+" : "-")</span>
                </div>
                @if (!_libCollapsed)
                {
                    <div class="lib-grid">
                        @foreach (var ex in GetFiltered().Take(50))
                        {
                            <div class="lib-card" @onclick="() => OpenExPreview(ex)">
                                <span class="lib-name">@ex.Name</span>
                                <span class="lib-meta">@MuscleStr(ex) · @ex.Level · MET @ex.MetValue</span>
                            </div>
                        }
                        @if (!GetFiltered().Any())
                        {
                            <div class="empty-sm">No exercises match your filters.</div>
                        }
                    </div>
                }
            </div>
        </div>

        <div class="bld-footer">
            <button type="button" class="btn-ghost" @onclick="CloseBuilder">Cancel</button>
            <button type="button" class="btn-action" @onclick="SaveWorkout" disabled="@_saving">@(_saving ? "Saving..." : (_editId.HasValue ? "Update" : "Save Workout"))</button>
        </div>
    </div>
</Modal>

<Modal IsOpen="_showExPreview" OnClose="CloseExPreview" Size="xl">
    @if (_previewEx is not null)
    {
        <div class="ex-detail-modal">
            <div class="ex-detail-banner">
                @{ var vid = _previewEx.Media.FirstOrDefault(m => m.MediaType == MediaType.Video); }
                @{ var img = _previewEx.Media.FirstOrDefault(m => m.MediaType == MediaType.Image); }
                @if (img is not null)
                {
                    <img src="@img.Url" alt="@_previewEx.Name" class="ex-detail-banner-img" />
                }
                else
                {
                    <span class="ex-detail-banner-ph">@_previewEx.Name</span>
                }
            </div>

            <div class="ex-detail-body">
                <div class="ex-detail-title">
                    <h2>@_previewEx.Name</h2>
                    <div class="ex-detail-badges">
                        <span class="ex-diff-tag ex-diff-@_previewEx.Level.ToString().ToLower()">@_previewEx.Level</span>
                        <span class="ex-equip-tag">@EquipStr(_previewEx)</span>
                        <span class="ex-equip-tag">@_previewEx.MovementType</span>
                        <span class="ex-met-tag">MET @_previewEx.MetValue</span>
                    </div>
                </div>

                <div class="ex-detail-grid">
                    <div>
                        <div class="ex-detail-sec">
                            <span class="ex-detail-heading">Proper Form</span>
                            <p class="ex-detail-text">@_previewEx.Description</p>
                        </div>
                        <div class="ex-detail-sec">
                            <span class="ex-detail-heading">Targeted Muscles</span>
                            <div class="ex-muscle-list">
                                @foreach (var mg in _previewEx.ExerciseMuscleGroups.OrderByDescending(m => m.IsPrimary))
                                {
                                    <div class="ex-muscle-row">
                                        <span class="ex-muscle-dot @(mg.IsPrimary ? "ex-dot-pri" : "ex-dot-sec")"></span>
                                        <span class="ex-muscle-name @(mg.IsPrimary ? "" : "ex-muscle-secondary")">@mg.MuscleGroup.Name</span>
                                        <span class="ex-muscle-role">@(mg.IsPrimary ? "Primary" : "Secondary")</span>
                                    </div>
                                }
                            </div>
                        </div>
                        @if (_previewEx.Alternatives.Count > 0)
                        {
                            <div class="ex-detail-sec">
                                <span class="ex-detail-heading">Alternatives</span>
                                <div class="ex-alt-list">
                                    @foreach (var alt in _previewEx.Alternatives)
                                    {
                                        var altEx = _allExercises.FirstOrDefault(e => e.Id == alt.AlternativeExerciseId);
                                        @if (altEx is not null)
                                        {
                                            <div class="ex-alt-row" @onclick="() => OpenExPreview(altEx)">
                                                <span class="ex-alt-name">@altEx.Name</span>
                                                <span class="ex-alt-arrow">to</span>
                                            </div>
                                        }
                                    }
                                </div>
                            </div>
                        }
                    </div>
                    <div>
                        <div class="ex-detail-sec">
                            <span class="ex-detail-heading">Video Demo</span>
                            @if (vid is not null)
                            {
                                <div class="ex-detail-video">
                                    <iframe src="@WorkoutService.GetYouTubeEmbedUrl(vid.Url)" allow="autoplay; encrypted-media" allowfullscreen frameborder="0"></iframe>
                                </div>
                            }
                            else
                            {
                                <div class="ex-detail-vid-ph">
                                    <div class="ex-play-circle"><div class="ex-play-tri"></div></div>
                                    <span class="ex-vid-label">Video demonstration</span>
                                </div>
                            }
                        </div>
                        <div class="ex-detail-sec">
                            <span class="ex-detail-heading">Calorie Estimates</span>
                            <div class="ex-cal-table">
                                <div class="ex-cal-hdr"><span>Weight</span><span>10 min</span><span>20 min</span><span>30 min</span></div>
                                @foreach (var (label, kg) in CalRanges())
                                {
                                    <div class="ex-cal-row">
                                        <span class="ex-cal-range">@label</span>
                                        <span class="ex-cal-val">@FormatEnergyValue(_previewEx.MetValue * kg * (10m/60m))</span>
                                        <span class="ex-cal-val">@FormatEnergyValue(_previewEx.MetValue * kg * (20m/60m))</span>
                                        <span class="ex-cal-val">@FormatEnergyValue(_previewEx.MetValue * kg * (30m/60m))</span>
                                    </div>
                                }
                            </div>
                            <span class="ex-cal-source">Source: Compendium of Physical Activities</span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="ex-detail-footer">
                <button type="button" class="btn-ghost" @onclick="CloseExPreview">Close</button>
                @if (!_form.Exercises.Any(e => e.ExerciseId == _previewEx.Id))
                {
                    <button type="button" class="btn-action" @onclick="() => AddFromPreview(_previewEx)">+ Add to Workout</button>
                }
                else
                {
                    <span class="ex-already">Already in workout</span>
                }
            </div>
        </div>
    }
</Modal>

<Modal IsOpen="_showWorkoutPreview" OnClose="() => _showWorkoutPreview = false" Size="lg">
    @if (_previewWorkout is not null)
    {
        <div class="wk-preview">
            <h2>@_previewWorkout.Name</h2>
            @if (_previewWorkout.Program is not null) { <span class="badge-purple">@_previewWorkout.Program.Name</span> }
            <div class="wk-prev-stats">
                <span class="bdg bdg-ex">@_previewWorkout.WorkoutExercises.Count exercises</span>
                <span class="bdg bdg-sets">@_previewWorkout.WorkoutExercises.Sum(x => x.Sets) sets</span>
                <span class="bdg bdg-cal">@FormatEnergyValue(EstWorkout(_previewWorkout))</span>
                <span class="bdg bdg-time">~@WorkoutService.EstimateWorkoutMinutesFromWE(_previewWorkout.WorkoutExercises) min</span>
            </div>
            <div class="wk-prev-list">
                @foreach (var we in _previewWorkout.WorkoutExercises.OrderBy(x => x.SortOrder))
                {
                    <div class="wk-prev-item">
                        <div class="wpi-info">
                            <span class="wpi-name">@we.Exercise.Name</span>
                            <span class="wpi-muscles">@MuscleStr(we.Exercise)</span>
                        </div>
                        <span class="wpi-sr">@we.Sets x @we.Reps</span>
                    </div>
                }
            </div>
            <div class="wk-prev-actions">
                @if (_previewIsOwn)
                {
                    <button type="button" class="btn-action" @onclick="EditWorkout">Edit</button>
                    <button type="button" class="btn-danger" @onclick="DeletePreviewWorkout">Delete</button>
                }
                else
                {
                    <button type="button" class="btn-action" @onclick="CopyWorkout">Copy to My Activities</button>
                }
            </div>
        </div>
    }
</Modal>

<Modal IsOpen="_showProgramPreview" OnClose="() => _showProgramPreview = false" Size="lg">
    @if (_previewProgram is not null)
    {
        <div class="wk-preview">
            <h2>@_previewProgram.Name</h2>
            <div class="wk-prev-stats">
                @if (_previewProgram.TargetLevel is not null) { <span class="bdg bdg-sets">@_previewProgram.TargetLevel</span> }
                @if (_previewProgram.TargetGoal is not null) { <span class="bdg bdg-cal">@_previewProgram.TargetGoal</span> }
                <span class="bdg bdg-time">@(_previewProgram.DurationWeeks)w · @(_previewProgram.DaysPerWeek)d/wk</span>
            </div>
            @if (!string.IsNullOrEmpty(_previewProgram.Description))
            {
                <p class="ex-desc">@_previewProgram.Description</p>
            }
            <h3 class="sec-title" style="margin-top:1rem">Workouts</h3>
            <div class="wk-prev-list">
                @foreach (var w in _previewProgram.Workouts.OrderBy(x => x.SortOrder))
                {
                    <div class="wk-prev-item">
                        <div class="wpi-info">
                            <span class="wpi-name">@w.Name</span>
                            <span class="wpi-muscles">@w.WorkoutExercises.Count exercises · @w.WorkoutExercises.Sum(x => x.Sets) sets</span>
                        </div>
                    </div>
                }
            </div>
            <div class="wk-prev-actions">
                @if (_previewProgramIsOwn)
                {
                    <button type="button" class="btn-action" @onclick="OpenEditProgram">Edit</button>
                    <button type="button" class="btn-danger" @onclick="DeletePreviewProgram">Delete</button>
                }
                else
                {
                    <button type="button" class="btn-action" @onclick="CopyProgram">Save to My Programs</button>
                }
            </div>
        </div>
    }
</Modal>

<Modal IsOpen="_showProgramEditor" OnClose="() => _showProgramEditor = false" Size="md">
    <div class="wk-preview">
        <h2>Edit Program</h2>
        <div class="prog-edit-fields">
            <div class="sf-full"><label>Name</label><input type="text" @bind="_progEditName" /></div>
            <div class="sf-full"><label>Description</label><textarea @bind="_progEditDesc" rows="3"></textarea></div>
            <div class="prog-edit-row">
                <div class="sf"><label>Weeks</label><input type="number" @bind="_progEditWeeks" min="1" /></div>
                <div class="sf"><label>Days/Week</label><input type="number" @bind="_progEditDays" min="1" max="7" /></div>
            </div>
            <div class="prog-edit-row">
                <div class="sf"><label>Level</label>
                    <select @bind="_progEditLevel">
                        <option value="">Any</option>
                        @foreach (var lv in Enum.GetValues<FitnessLevel>()) { <option value="@lv">@lv</option> }
                    </select>
                </div>
                <div class="sf"><label>Goal</label>
                    <select @bind="_progEditGoal">
                        <option value="">Any</option>
                        @foreach (var g in Enum.GetValues<PrimaryGoal>()) { <option value="@g">@g</option> }
                    </select>
                </div>
            </div>
        </div>
        <div class="wk-prev-actions" style="margin-top:1rem">
            <button type="button" class="btn-ghost" @onclick="() => _showProgramEditor = false">Cancel</button>
            <button type="button" class="btn-action" @onclick="SaveProgramEdits">Save</button>
        </div>
    </div>
</Modal>

@code {
    private bool _isLoading = true;
    private int _userId;
    private User? _user;
    private string _weightUnit = "kg";
    private string _energyUnit = "kcal";
    private string _trainingCategory = "strength";
    private string _builderCategory = "strength";
    private int _workoutViewTab;
    private string? _msg;
    private bool _msgErr;
    private bool _saving;

    private List<Workout> _myWorkouts = new();
    private List<Workout> _premadeWorkouts = new();
    private List<Models.Program> _myPrograms = new();
    private List<Models.Program> _prebuiltPrograms = new();
    private List<Exercise> _allExercises = new();
    private List<MuscleGroup> _allMuscleGroups = new();
    private List<Equipment> _allEquipment = new();

    private bool _showBuilder;
    private int? _editId;
    private UserWorkoutFormData _form = new();
    private List<string> _warnings = new();
    private List<Exercise> _suggestions = new();
    private decimal _estCal;
    private decimal _estMin;

    private string _search = "";
    private List<string> _filterMuscles = new();
    private List<string> _filterEquip = new();
    private string _filterMove = "";
    private bool _showFilterMuscle, _showFilterEquip, _showFilterMove;

    private bool _showExPreview;
    private Exercise? _previewEx;
    private int _activeExIdx = -1;

    private bool _showWorkoutPreview;
    private Workout? _previewWorkout;
    private bool _previewIsOwn;

    private bool _showProgramPreview;
    private Models.Program? _previewProgram;
    private bool _previewProgramIsOwn;

    private bool _showProgramEditor;
    private string _progEditName = "";
    private string? _progEditDesc;
    private int _progEditWeeks;
    private int _progEditDays;
    private string? _progEditLevel;
    private string? _progEditGoal;

    private bool _sugCollapsed;
    private bool _libCollapsed;

    private static readonly (string Key, string Label, string Description)[] TrainingCategories =
    {
        ("strength", "Strength Workout", "Build and manage resistance workouts, strength plans, and muscle-focused sessions."),
        ("cardio", "Cardio", "Track endurance sessions, cardio workouts, and conditioning programs."),
        ("recovery", "Recovery Activity", "Organize warmups, mobility work, stretching, and lower-intensity recovery sessions.")
    };

    private IEnumerable<Workout> FilteredMyWorkouts => _myWorkouts.Where(w => MatchesWorkoutCategory(w, _trainingCategory));
    private IEnumerable<Workout> FilteredPremadeWorkouts => _premadeWorkouts.Where(w => MatchesWorkoutCategory(w, _trainingCategory));
    private IEnumerable<Models.Program> FilteredMyPrograms => _myPrograms.Where(p => MatchesProgramCategory(p, _trainingCategory));
    private IEnumerable<Models.Program> FilteredPrebuiltPrograms => _prebuiltPrograms.Where(p => MatchesProgramCategory(p, _trainingCategory));

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        var state = await AuthState.GetAuthenticationStateAsync();
        if (state.User.Identity is not { IsAuthenticated: true }) { try { Navigation.NavigateTo("/login", forceLoad: true); } catch { } return; }
        _userId = int.Parse(state.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)!.Value);
        await LoadData();
        _isLoading = false;
        StateHasChanged();
    }

    private async Task LoadData()
    {
        _user = await WorkoutService.GetUserAsync(_userId);
        var settings = await SettingsSvc.GetSettingsAsync(_userId);
        _weightUnit = settings.WeightUnit;
        _energyUnit = settings.EnergyUnit;
        _allExercises = await WorkoutService.GetExerciseLibraryAsync();
        _allMuscleGroups = await WorkoutService.GetAllMuscleGroupsAsync();
        _allEquipment = await WorkoutService.GetAllEquipmentAsync();
        _myWorkouts = await WorkoutService.GetUserWorkoutsAsync(_userId);
        _premadeWorkouts = await WorkoutService.GetPremadeWorkoutsAsync();
        _myPrograms = await WorkoutService.GetUserProgramsAsync(_userId);
        _prebuiltPrograms = await WorkoutService.GetPrebuiltProgramsAsync();
    }

    private void SelectTrainingCategory(string category)
    {
        _trainingCategory = category;
        _workoutViewTab = 0;
        _msg = null;
    }

    private void QuickStartSelected()
    {
        OpenBuilderForCategory(_trainingCategory);
    }

    private void OpenBuilder()
    {
        OpenBuilderForCategory(_trainingCategory);
    }

    private void OpenBuilderFor(MovementType? movementType)
    {
        OpenBuilderForCategory(movementType == MovementType.Cardio ? "cardio" : "strength");
    }

    private void OpenBuilderForCategory(string category)
    {
        _editId = null;
        _form = new UserWorkoutFormData();
        _showBuilder = true;
        _msg = null;
        _activeExIdx = -1;
        _sugCollapsed = false;
        _libCollapsed = false;
        _builderCategory = category;
        _search = "";
        ClearFilters();
        if (category == "cardio")
        {
            _filterMove = MovementType.Cardio.ToString();
            _showFilterMove = true;
        }
        else
        {
            _showFilterMove = false;
        }
        Recalc();
    }

    private void ShowPrograms()
    {
        _workoutViewTab = 3;
    }

    private void CloseBuilder() { _showBuilder = false; _showFilterMuscle = _showFilterEquip = _showFilterMove = false; }

    private void Recalc()
    {
        decimal w = _user?.WeightKg ?? 70m;
        _estCal = WorkoutService.EstimateWorkoutCalories(_form.Exercises, w);
        _estMin = WorkoutService.EstimateWorkoutMinutes(_form.Exercises);
        _warnings = WorkoutService.GetWorkoutWarnings(_form.Exercises, _user?.FitnessLevel);
        _suggestions = WorkoutService.GetSuggestions(_form.Exercises, _allExercises)
            .Where(e => MatchesExerciseCategory(e, _builderCategory))
            .Take(6)
            .ToList();
    }

    private void AddExercise(Exercise ex)
    {
        if (_form.Exercises.Any(e => e.ExerciseId == ex.Id)) return;
        var (sets, reps, rest) = WorkoutService.GetRecommendation(_user?.PrimaryGoal, ex.Level, ex.ExerciseType);
        _form.Exercises.Add(new BuilderExerciseEntry { ExerciseId = ex.Id, Exercise = ex, Sets = sets, Reps = reps, RestTimeSec = rest });
        Recalc();
    }

    private void RemoveEntry(int idx)
    {
        if (idx >= 0 && idx < _form.Exercises.Count)
        {
            _form.Exercises.RemoveAt(idx);
            if (_activeExIdx == idx) _activeExIdx = -1;
            NormalizeSupersetOrders();
            Recalc();
        }
    }

    private void Move(int idx, int dir)
    {
        int n = idx + dir;
        if (n < 0 || n >= _form.Exercises.Count) return;
        (_form.Exercises[idx], _form.Exercises[n]) = (_form.Exercises[n], _form.Exercises[idx]);
        NormalizeSupersetOrders();
        Recalc();
    }

    private void ActivateSelected(int idx) => _activeExIdx = _activeExIdx == idx ? -1 : idx;

    private void GroupWithPrevious(int idx)
    {
        if (idx <= 0 || idx >= _form.Exercises.Count) return;
        var previous = _form.Exercises[idx - 1];
        var current = _form.Exercises[idx];
        var group = previous.SupersetGroup ?? NextSupersetGroup();
        previous.SupersetGroup = group;
        previous.SupersetRestAfterSec ??= 0;
        current.SupersetGroup = group;
        current.SupersetRestAfterSec ??= 0;
        var rounds = Math.Max(previous.Sets, current.Sets);
        previous.SupersetRounds = Math.Max(previous.SupersetRounds, rounds);
        current.SupersetRounds = Math.Max(current.SupersetRounds, rounds);
        NormalizeSupersetOrders(group);
        Recalc();
    }

    private void StartSupersetAt(int idx)
    {
        if (idx < 0 || idx >= _form.Exercises.Count) return;
        var entry = _form.Exercises[idx];
        entry.SupersetGroup = NextSupersetGroup();
        entry.SupersetRestAfterSec ??= 0;
        entry.SupersetRounds = Math.Max(1, entry.Sets);
        NormalizeSupersetOrders(entry.SupersetGroup);
        Recalc();
    }

    private void RemoveFromSuperset(int idx)
    {
        if (idx < 0 || idx >= _form.Exercises.Count) return;
        var group = _form.Exercises[idx].SupersetGroup;
        _form.Exercises[idx].SupersetGroup = null;
        _form.Exercises[idx].SupersetOrder = 0;
        _form.Exercises[idx].SupersetRestAfterSec = null;
        _form.Exercises[idx].SupersetRounds = 1;
        NormalizeSupersetOrders(group);
        Recalc();
    }

    private int NextSupersetGroup() => (_form.Exercises.Where(x => x.SupersetGroup.HasValue).Select(x => x.SupersetGroup!.Value).DefaultIfEmpty(0).Max()) + 1;

    private void NormalizeSupersetOrders(int? group = null)
    {
        var groups = group.HasValue ? new[] { group.Value } : _form.Exercises.Where(x => x.SupersetGroup.HasValue).Select(x => x.SupersetGroup!.Value).Distinct().ToArray();
        foreach (var supersetGroup in groups)
        {
            var groupEntries = _form.Exercises.Where(x => x.SupersetGroup == supersetGroup).ToList();
            if (groupEntries.Count == 0) continue;
            var maxSets = groupEntries.Max(x => Math.Max(1, x.Sets));
            var currentRounds = groupEntries.Max(x => Math.Max(1, x.SupersetRounds));
            var rounds = Math.Max(maxSets, currentRounds);
            var order = 1;
            foreach (var entry in groupEntries)
            {
                entry.SupersetOrder = order++;
                entry.SupersetRestAfterSec ??= 0;
                entry.SupersetRounds = rounds;
            }
        }
    }

    private int GetSupersetRounds(BuilderExerciseEntry entry)
    {
        if (!entry.SupersetGroup.HasValue) return Math.Max(1, entry.Sets);
        var groupEntries = _form.Exercises.Where(x => x.SupersetGroup == entry.SupersetGroup).ToList();
        if (groupEntries.Count == 0) return Math.Max(1, entry.Sets);
        return groupEntries.Max(x => Math.Max(Math.Max(1, x.Sets), Math.Max(1, x.SupersetRounds)));
    }

    private void SetSupersetRounds(BuilderExerciseEntry entry, ChangeEventArgs e)
    {
        if (!entry.SupersetGroup.HasValue) return;
        var groupEntries = _form.Exercises.Where(x => x.SupersetGroup == entry.SupersetGroup).ToList();
        if (groupEntries.Count == 0) return;
        var maxSets = groupEntries.Max(x => Math.Max(1, x.Sets));
        var requested = int.TryParse(e.Value?.ToString(), out var value) ? value : maxSets;
        var rounds = Math.Clamp(Math.Max(requested, maxSets), 1, 50);
        foreach (var groupEntry in groupEntries)
            groupEntry.SupersetRounds = rounds;
        Recalc();
    }

    private static string SupersetEntryMeta(BuilderExerciseEntry entry) => entry.SupersetGroup.HasValue ? $" · Superset {entry.SupersetGroup} · {Math.Max(1, entry.SupersetRounds)} rounds · rest after {entry.SupersetRestAfterSec ?? 0}s" : string.Empty;

    private static string SupersetLabel(BuilderExerciseEntry entry) => entry.SupersetGroup.HasValue ? $"Superset {entry.SupersetGroup} · position {Math.Max(1, entry.SupersetOrder)}" : string.Empty;

    private static string SupersetWorkoutMeta(WorkoutExercise entry) => entry.SupersetGroup.HasValue ? $" · Superset {entry.SupersetGroup} · {Math.Max(1, entry.SupersetRounds)} rounds · rest after {entry.SupersetRestAfterSec ?? 0}s" : string.Empty;

    private static string WorkoutSupersetSummary(Workout workout)
    {
        var count = workout.WorkoutExercises.Where(x => x.SupersetGroup.HasValue).Select(x => x.SupersetGroup!.Value).Distinct().Count();
        return count > 0 ? $" · {count} supersets" : string.Empty;
    }

    private async Task SaveWorkout()
    {
        _saving = true;
        if (string.IsNullOrWhiteSpace(_form.Name)) { _msg = "Give your workout a name."; _msgErr = true; _saving = false; return; }
        if (_form.Exercises.Count == 0) { _msg = "Add at least one exercise."; _msgErr = true; _saving = false; return; }

        NormalizeSupersetOrders();

        if (_editId.HasValue)
        {
            var ok = await WorkoutService.UpdateWorkoutAsync(_editId.Value, _userId, _form);
            _msg = ok ? "Workout updated." : "Failed to update."; _msgErr = !ok;
        }
        else
        {
            await WorkoutService.CreateWorkoutAsync(_userId, _form);
            _msg = "Workout created."; _msgErr = false;
        }

        _myWorkouts = await WorkoutService.GetUserWorkoutsAsync(_userId);
        _showBuilder = false;
        _saving = false;
    }

    private void OpenExPreview(Exercise ex) { _previewEx = ex; _showExPreview = true; }
    private void CloseExPreview() { _showExPreview = false; _previewEx = null; }

    private void AddFromPreview(Exercise ex)
    {
        AddExercise(ex);
        _showExPreview = false;
        _previewEx = null;
    }

    private async Task OpenWorkoutPreview(int id, bool own)
    {
        _previewWorkout = await WorkoutService.GetWorkoutByIdAsync(id, _userId);
        _previewIsOwn = own;
        _showWorkoutPreview = true;
    }

    private void OpenProgramPreview(Models.Program p, bool own)
    {
        _previewProgram = p;
        _previewProgramIsOwn = own;
        _showProgramPreview = true;
    }

    private async Task EditWorkout()
    {
        if (_previewWorkout is null) return;
        _editId = _previewWorkout.Id;
        _form = new UserWorkoutFormData
        {
            Name = _previewWorkout.Name,
            SortOrder = _previewWorkout.SortOrder,
            Exercises = _previewWorkout.WorkoutExercises.OrderBy(x => x.SortOrder).Select(x => new BuilderExerciseEntry
            {
                ExerciseId = x.ExerciseId, Exercise = x.Exercise, Sets = x.Sets, Reps = x.Reps, RestTimeSec = x.RestTimeSec, SupersetGroup = x.SupersetGroup, SupersetOrder = x.SupersetOrder, SupersetRestAfterSec = x.SupersetRestAfterSec, SupersetRounds = Math.Max(1, x.SupersetRounds)
            }).ToList()
        };
        _showWorkoutPreview = false;
        _showBuilder = true;
        _builderCategory = GetWorkoutCategoryKey(_previewWorkout);
        _activeExIdx = -1;
        _sugCollapsed = false;
        _libCollapsed = false;
        Recalc();
    }

    private async Task DeletePreviewWorkout()
    {
        if (_previewWorkout is null) return;
        var ok = await WorkoutService.DeleteWorkoutAsync(_previewWorkout.Id, _userId);
        _msg = ok ? "Workout deleted." : "Failed to delete."; _msgErr = !ok;
        _myWorkouts = await WorkoutService.GetUserWorkoutsAsync(_userId);
        _showWorkoutPreview = false;
