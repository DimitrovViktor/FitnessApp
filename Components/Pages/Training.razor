    private void OpenEditProgram()
    {
        if (_previewProgram is null) return;
        _progEditName = _previewProgram.Name;
        _progEditDesc = _previewProgram.Description;
        _progEditWeeks = _previewProgram.DurationWeeks;
        _progEditDays = _previewProgram.DaysPerWeek;
        _progEditLevel = _previewProgram.TargetLevel;
        _progEditGoal = _previewProgram.TargetGoal;
        _showProgramPreview = false;
        _showProgramEditor = true;
    }

    private async Task SaveProgramEdits()
    {
        if (_previewProgram is null || string.IsNullOrWhiteSpace(_progEditName)) return;
        var ok = await WorkoutService.UpdateProgramAsync(
            _previewProgram.Id, _userId, _progEditName, _progEditDesc,
            _progEditWeeks, _progEditDays,
            string.IsNullOrEmpty(_progEditLevel) ? null : _progEditLevel,
            string.IsNullOrEmpty(_progEditGoal) ? null : _progEditGoal);
        _msg = ok ? "Program updated." : "Failed to update."; _msgErr = !ok;
        _myPrograms = await WorkoutService.GetUserProgramsAsync(_userId);
        _showProgramEditor = false;
    }

    private async Task DeletePreviewProgram()
    {
        if (_previewProgram is null) return;
        var ok = await WorkoutService.DeleteProgramAsync(_previewProgram.Id, _userId);
        _msg = ok ? "Program deleted." : "Failed to delete."; _msgErr = !ok;
        _myPrograms = await WorkoutService.GetUserProgramsAsync(_userId);
        _myWorkouts = await WorkoutService.GetUserWorkoutsAsync(_userId);
        _showProgramPreview = false;
    }

    private List<ActivityItem> GetRecentActivity()
    {
        var workouts = FilteredMyWorkouts.Select(w => new ActivityItem
        {
            Name = w.Name,
            Type = "Workout",
            Detail = $"{w.WorkoutExercises.Count} exercises",
            When = w.CreatedAt,
            WorkoutId = w.Id,
            Program = null
        });

        var programs = FilteredMyPrograms.Select(p => new ActivityItem
        {
            Name = p.Name,
            Type = "Program",
            Detail = $"{p.DurationWeeks} weeks, {p.DaysPerWeek} d/wk",
            When = p.CreatedAt,
            WorkoutId = null,
            Program = p
        });

        return workouts.Concat(programs).OrderByDescending(x => x.When).Take(5).ToList();
    }

    private async Task OpenRecentActivity(ActivityItem item)
    {
        if (item.WorkoutId.HasValue)
        {
            await OpenWorkoutPreview(item.WorkoutId.Value, true);
            return;
        }

        if (item.Program is not null)
        {
            OpenProgramPreview(item.Program, true);
        }
    }

    private string GetTrainingCategorySummary(string category)
    {
        var workoutCount = _myWorkouts.Count(w => MatchesWorkoutCategory(w, category));
        var programCount = _myPrograms.Count(p => MatchesProgramCategory(p, category));
        return $"{workoutCount} workouts · {programCount} programs";
    }

    private static string GetTrainingCategoryLabel(string category) => category switch
    {
        "cardio" => "Cardio",
        "recovery" => "Recovery",
        _ => "Strength"
    };

    private static string GetTrainingCategoryHeading(string category) => category switch
    {
        "cardio" => "Cardio sessions and programs",
        "recovery" => "Recovery, warmups, and mobility",
        _ => "Strength workouts and programs"
    };

    private static string GetTrainingCategoryDescription(string category) => category switch
    {
        "cardio" => "Use this section for cardio workouts, cardio programs, and premade endurance plans.",
        "recovery" => "Use this section for warmups, mobility work, stretching, and recovery-focused sessions.",
        _ => "Use this section for your own strength workouts, saved strength programs, and premade lifting sessions."
    };

    private static string GetWorkoutTypeLabel(Workout workout) => GetTrainingCategoryLabel(GetWorkoutCategoryKey(workout));

    private static string GetWorkoutCategoryKey(Workout workout)
    {
        if (MatchesWorkoutCategory(workout, "recovery")) return "recovery";
        if (MatchesWorkoutCategory(workout, "cardio")) return "cardio";
        return "strength";
    }

    private static string GetProgramTypeLabel(Models.Program program)
    {
        if (MatchesProgramCategory(program, "recovery")) return "Recovery";
        if (MatchesProgramCategory(program, "cardio")) return "Cardio";
        if (MatchesProgramCategory(program, "hybrid")) return "Hybrid";
        return "Strength";
    }

    private static bool MatchesWorkoutCategory(Workout workout, string category)
    {
        var exercises = workout.WorkoutExercises.Select(x => x.Exercise).Where(e => e is not null).Cast<Exercise>().ToList();
        if (exercises.Count == 0) return category == "strength";

        var hasCardio = exercises.Any(IsCardioExercise);
        var hasRecovery = exercises.Any(IsRecoveryExercise);
        var hasStrength = exercises.Any(e => !IsCardioExercise(e) && !IsRecoveryExercise(e));

        return category switch
        {
            "cardio" => hasCardio && !hasStrength,
            "recovery" => hasRecovery && !hasStrength,
            _ => hasStrength || !hasCardio && !hasRecovery
        };
    }

    private static bool MatchesProgramCategory(Models.Program program, string category)
    {
        if (category == "recovery")
        {
            var programText = GetProgramSearchText(program);
            return ContainsAny(programText, "recovery", "mobility", "stretch", "warmup", "warm-up", "prehab") || program.Workouts.Any(w => MatchesWorkoutCategory(w, "recovery"));
        }

        if (category == "hybrid")
        {
            var programText = GetProgramSearchText(program);
            var hasCardio = ContainsAny(programText, "hybrid", "conditioning", "cardio", "endurance", "running", "cycling", "hiit") || program.Workouts.Any(w => MatchesWorkoutCategory(w, "cardio"));
            var hasStrength = ContainsAny(programText, "hypertrophy", "strength", "muscle", "power", "lifting") || program.Workouts.Any(w => MatchesWorkoutCategory(w, "strength"));
            return ContainsAny(programText, "hybrid", "circuit") || hasCardio && hasStrength;
        }

        if (category == "cardio")
        {
            var programText = GetProgramSearchText(program);
            return (ContainsAny(programText, "cardio", "endurance", "running", "cycling", "rowing", "conditioning", "hiit") || program.Workouts.Any(w => MatchesWorkoutCategory(w, "cardio"))) && !MatchesProgramCategory(program, "hybrid");
        }

        return !MatchesProgramCategory(program, "cardio") && !MatchesProgramCategory(program, "recovery") || program.Workouts.Any(w => MatchesWorkoutCategory(w, "strength"));
    }

    private static bool MatchesExerciseCategory(Exercise exercise, string category)
    {
        var isCardio = IsCardioExercise(exercise);
        var isRecovery = IsRecoveryExercise(exercise);

        return category switch
        {
            "cardio" => isCardio,
            "recovery" => isRecovery,
            _ => !isCardio && !isRecovery
        };
    }

    private static bool IsCardioExercise(Exercise exercise) => exercise.MovementType == MovementType.Cardio;

    private static bool IsRecoveryExercise(Exercise exercise)
    {
        var text = $"{exercise.Name} {exercise.Description} {exercise.ExerciseType}";
        return ContainsAny(text, "warmup", "warm-up", "mobility", "stretch", "activation", "recovery", "cooldown", "cool down", "dynamic", "foam roll", "prehab", "mobility drill");
    }

    private static string GetProgramSearchText(Models.Program program)
    {
        var workouts = program.Workouts.Select(w => w.Name);
        return string.Join(" ", new[] { program.Name, program.Description, program.TargetGoal, program.TargetLevel, program.Tags }.Where(x => !string.IsNullOrWhiteSpace(x)).Concat(workouts));
    }

    private static bool ContainsAny(string value, params string[] terms) => terms.Any(term => value.Contains(term, StringComparison.OrdinalIgnoreCase));

    private static string FormatGoal(string? goal)
    {
        return goal switch
        {
            "FatLoss" => "Fat Loss",
            "GeneralHealth" => "General Health",
            null or "" => "General",
            _ => goal
        };
    }

    private void ToggleFilter(List<string> list, string val) { if (!list.Remove(val)) list.Add(val); }
    private void ClearFilters() { _filterMuscles.Clear(); _filterEquip.Clear(); _filterMove = ""; }

    private void ToggleMoveFilter(MovementType mt)
    {
        var s = mt.ToString();
        _filterMove = _filterMove == s ? string.Empty : s;
    }

    private List<Exercise> GetFiltered()
    {
        var used = _form.Exercises.Select(e => e.ExerciseId).ToHashSet();
        return _allExercises.Where(e =>
        {
            if (used.Contains(e.Id)) return false;
            if (!MatchesExerciseCategory(e, _builderCategory)) return false;
            if (!string.IsNullOrWhiteSpace(_search) && !e.Name.Contains(_search, StringComparison.OrdinalIgnoreCase)
                && !e.Description.Contains(_search, StringComparison.OrdinalIgnoreCase)
                && !e.ExerciseMuscleGroups.Any(m => m.MuscleGroup.Name.Contains(_search, StringComparison.OrdinalIgnoreCase))) return false;
            if (_filterMuscles.Count > 0 && !_filterMuscles.All(fm => e.ExerciseMuscleGroups.Any(m => m.MuscleGroup.Name == fm))) return false;
            if (_filterEquip.Count > 0 && !e.ExerciseEquipment.Any(eq => _filterEquip.Contains(eq.Equipment.Name))) return false;
            if (!string.IsNullOrEmpty(_filterMove) && e.MovementType.ToString() != _filterMove) return false;
            return true;
        }).ToList();
    }

    private static IEnumerable<string> GetPrimaryMuscles(IEnumerable<WorkoutExercise> exercises) =>
        exercises.SelectMany(x => x.Exercise.ExerciseMuscleGroups.Where(mg => mg.IsPrimary).Select(mg => mg.MuscleGroup.Name)).Distinct().Take(4);

    private static string MuscleStr(Exercise ex) => string.Join(", ", ex.ExerciseMuscleGroups.Where(m => m.IsPrimary).Select(m => m.MuscleGroup.Name));
    private static string EquipStr(Exercise ex) => string.Join(", ", ex.ExerciseEquipment.Select(e => e.Equipment.Name));

    private string FormatEnergyValue(decimal calories) => SettingsService.FormatEnergy(calories, _energyUnit);

    private IEnumerable<(string Label, int Kg)> CalRanges()
    {
        foreach (var kg in new[] { 55, 65, 75, 85, 95 })
        {
            var lower = kg == 95 ? SettingsService.FromKg(90, _weightUnit) : SettingsService.FromKg(kg - 5, _weightUnit);
            var upper = SettingsService.FromKg(kg + 5, _weightUnit);
            var unit = SettingsService.WeightLabel(_weightUnit);
            var label = kg == 95 ? $"{Math.Round(lower ?? 90, 0)}+ {unit}" : $"{Math.Round(lower ?? kg - 5, 0)}–{Math.Round(upper ?? kg + 5, 0)} {unit}";
            yield return (label, kg);
        }
    }
    private decimal EstSingle(BuilderExerciseEntry e) => e.Exercise is not null ? WorkoutService.EstimateExerciseCalories(e.Exercise, e.Sets, e.Reps, e.SupersetGroup.HasValue ? Math.Max(0, e.SupersetRestAfterSec ?? 0) : Math.Max(0, e.RestTimeSec ?? 60), _user?.WeightKg ?? 70m) : 0;
    private decimal EstWorkout(Workout w) => WorkoutService.EstimateWorkoutCalories(w.WorkoutExercises.Select(x => new BuilderExerciseEntry { Exercise = x.Exercise, Sets = x.Sets, Reps = x.Reps, RestTimeSec = x.RestTimeSec, SupersetGroup = x.SupersetGroup, SupersetOrder = x.SupersetOrder, SupersetRestAfterSec = x.SupersetRestAfterSec, SupersetRounds = Math.Max(1, x.SupersetRounds) }).ToList(), _user?.WeightKg ?? 70m);

    private sealed class ActivityItem
    {
        public string Name { get; set; } = "";
        public string Type { get; set; } = "";
        public string Detail { get; set; } = "";
        public DateTime When { get; set; }
        public int? WorkoutId { get; set; }
        public Models.Program? Program { get; set; }
    }
