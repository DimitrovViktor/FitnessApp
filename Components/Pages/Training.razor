    private async Task CopyProgram()
    {
        if (_previewProgram is null) return;
        await WorkoutService.CopyProgramToUserAsync(_previewProgram.Id, _userId);
        _myPrograms = await WorkoutService.GetUserProgramsAsync(_userId);
        _myWorkouts = await WorkoutService.GetUserWorkoutsAsync(_userId);
