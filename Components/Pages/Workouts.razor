    private void ToggleFilter(List<string> list, string val) { if (!list.Remove(val)) list.Add(val); }
    private void ClearFilters() { _filterMuscles.Clear(); _filterEquip.Clear(); _filterMove = ""; }

    private void ToggleMoveFilter(MovementType mt)
    {
        var s = mt.ToString();
        _filterMove = _filterMove == s ? string.Empty : s;
    }

    private List<Exercise> GetFiltered()
    {
        var used = _form.Exercises.Select(e => e.ExerciseId).ToHashSet();
        return _allExercises.Where(e =>
        {
            if (used.Contains(e.Id)) return false;
            if (!string.IsNullOrWhiteSpace(_search) && !e.Name.Contains(_search, StringComparison.OrdinalIgnoreCase)) return false;
            if (_filterMuscles.Count > 0 && !_filterMuscles.All(fm => e.ExerciseMuscleGroups.Any(m => m.MuscleGroup.Name == fm))) return false;
            if (_filterEquip.Count > 0 && !e.ExerciseEquipment.Any(eq => _filterEquip.Contains(eq.Equipment.Name))) return false;
            if (!string.IsNullOrEmpty(_filterMove) && e.MovementType.ToString() != _filterMove) return false;
            return true;
        }).ToList();
    }

    private static IEnumerable<string> GetPrimaryMuscles(IEnumerable<WorkoutExercise> exercises) =>
        exercises.SelectMany(x => x.Exercise.ExerciseMuscleGroups.Where(mg => mg.IsPrimary).Select(mg => mg.MuscleGroup.Name)).Distinct().Take(4);

    private static string MuscleStr(Exercise ex) => string.Join(", ", ex.ExerciseMuscleGroups.Where(m => m.IsPrimary).Select(m => m.MuscleGroup.Name));
    private static string EquipStr(Exercise ex) => string.Join(", ", ex.ExerciseEquipment.Select(e => e.Equipment.Name));
    private decimal EstSingle(BuilderExerciseEntry e) => e.Exercise is not null ? WorkoutService.EstimateExerciseCalories(e.Exercise, e.Sets, e.Reps, e.RestTimeSec ?? 60, _user?.WeightKg ?? 70m) : 0;
    private decimal EstWorkout(Workout w) => WorkoutService.EstimateWorkoutCalories(w.WorkoutExercises.Select(x => new BuilderExerciseEntry { Exercise = x.Exercise, Sets = x.Sets, Reps = x.Reps, RestTimeSec = x.RestTimeSec }).ToList(), _user?.WeightKg ?? 70m);
}
