@page "/admin"
@inject AdminService AdminService
@inject CustomAuthStateProvider AuthState
@inject NavigationManager Navigation
@using FitnessApp.Models.Enums

<PageTitle>Admin Panel - Fitness App</PageTitle>

@if (_isLoading)
{
    <div class="loading-state"><p>Loading...</p></div>
}
else if (!_isAdmin)
{
    <div class="loading-state"><p>Access denied.</p></div>
}
else
{
    <div class="admin-page">
        <div class="admin-header">
            <h1>Admin Panel</h1>
            <p class="admin-subtitle">Manage application data</p>
        </div>

        <div class="counts-grid">
            <div class="count-card"><span class="count-value">@_counts.Users</span><span class="count-label">Users</span></div>
            <div class="count-card"><span class="count-value">@_counts.Exercises</span><span class="count-label">Exercises</span></div>
            <div class="count-card"><span class="count-value">@_counts.Workouts</span><span class="count-label">Workouts</span></div>
            <div class="count-card"><span class="count-value">@_counts.Equipment</span><span class="count-label">Equipment</span></div>
            <div class="count-card"><span class="count-value">@_counts.MuscleGroups</span><span class="count-label">Muscle Groups</span></div>
            <div class="count-card"><span class="count-value">@_counts.Foods</span><span class="count-label">Foods</span></div>
            <div class="count-card"><span class="count-value">@_counts.Programs</span><span class="count-label">Programs</span></div>
            <div class="count-card"><span class="count-value">@_counts.WorkoutLogs</span><span class="count-label">Workout Logs</span></div>
        </div>

        <div class="tab-bar">
            @foreach (var tab in _tabs) { <button type="button" class="tab-btn @(_activeTab == tab ? "active" : "")" @onclick="() => SwitchTab(tab)">@tab</button> }
        </div>

        @if (!string.IsNullOrEmpty(_message)) { <div class="@(_isError ? "msg-error" : "msg-success")">@_message</div> }

        <div class="section-actions">
            @if (_activeTab != "Users")
            {
                <button type="button" class="btn-add" @onclick="OpenAddModal">+ Add @_activeTab.TrimEnd('s')</button>
            }
        </div>

        <div class="table-section">
            <table class="admin-table">
                @switch (_activeTab)
                {
                    case "Users":
                        <thead><tr><th>ID</th><th>Username</th><th>Full Name</th><th>Email</th><th>Admin</th><th>Created</th></tr></thead>
                        <tbody>@foreach (var u in _users) { <tr><td>@u.Id</td><td>@u.Username</td><td>@u.FullName</td><td>@u.Email</td><td>@(u.IsAdmin ? "Yes" : "No")</td><td>@u.CreatedAt.ToString("yyyy-MM-dd")</td></tr> }</tbody>
                        break;
                    case "Exercises":
                        <thead><tr><th>ID</th><th>Name</th><th>Level</th><th>Movement</th><th>MET</th><th>Muscles</th><th>Actions</th></tr></thead>
                        <tbody>@foreach (var ex in _exercises) { <tr><td>@ex.Id</td><td>@ex.Name</td><td>@ex.Level</td><td>@ex.MovementType</td><td>@ex.MetValue</td><td>@string.Join(", ", ex.ExerciseMuscleGroups.Select(m => m.MuscleGroup.Name))</td><td class="actions-cell"><button type="button" class="btn-action btn-edit-action" @onclick="() => OpenEditExercise(ex.Id)">Edit</button><button type="button" class="btn-action btn-delete-action" @onclick="() => ConfirmDel(ex.Id, ex.Name, _tExercise)">Delete</button></td></tr> }</tbody>
                        break;
                    case "Workouts":
                        <thead><tr><th>ID</th><th>Name</th><th>User</th><th>Program</th><th>Exercises</th><th>Actions</th></tr></thead>
                        <tbody>@foreach (var w in _workouts) { <tr><td>@w.Id</td><td>@w.Name</td><td>@w.User.Username</td><td>@(w.Program?.Name ?? "—")</td><td>@w.WorkoutExercises.Count</td><td class="actions-cell"><button type="button" class="btn-action btn-edit-action" @onclick="() => OpenEditWorkout(w.Id)">Edit</button><button type="button" class="btn-action btn-delete-action" @onclick="() => ConfirmDel(w.Id, w.Name, _tWorkout)">Delete</button></td></tr> }</tbody>
                        break;
                    case "Equipment":
                        <thead><tr><th>ID</th><th>Name</th><th>Actions</th></tr></thead>
                        <tbody>@foreach (var eq in _equipment) { <tr><td>@eq.Id</td><td>@eq.Name</td><td class="actions-cell"><button type="button" class="btn-action btn-edit-action" @onclick="() => OpenEditEquipment(eq)">Edit</button><button type="button" class="btn-action btn-delete-action" @onclick="() => ConfirmDel(eq.Id, eq.Name, _tEquipment)">Delete</button></td></tr> }</tbody>
                        break;
                    case "Muscle Groups":
                        <thead><tr><th>ID</th><th>Name</th><th>Region</th><th>Actions</th></tr></thead>
                        <tbody>@foreach (var mg in _muscleGroups) { <tr><td>@mg.Id</td><td>@mg.Name</td><td>@(mg.BodyRegion ?? "—")</td><td class="actions-cell"><button type="button" class="btn-action btn-edit-action" @onclick="() => OpenEditMuscleGroup(mg)">Edit</button><button type="button" class="btn-action btn-delete-action" @onclick="() => ConfirmDel(mg.Id, mg.Name, _tMuscle)">Delete</button></td></tr> }</tbody>
                        break;
                    case "Foods":
                        <thead><tr><th>ID</th><th>Name</th><th>Cal</th><th>Protein</th><th>Carbs</th><th>Fat</th><th>Actions</th></tr></thead>
                        <tbody>@foreach (var f in _foods) { <tr><td>@f.Id</td><td>@f.Name</td><td>@f.CaloriesPer100g</td><td>@(f.ProteinPer100g?.ToString() ?? "—")</td><td>@(f.CarbsPer100g?.ToString() ?? "—")</td><td>@(f.FatPer100g?.ToString() ?? "—")</td><td class="actions-cell"><button type="button" class="btn-action btn-edit-action" @onclick="() => OpenEditFood(f)">Edit</button><button type="button" class="btn-action btn-delete-action" @onclick="() => ConfirmDel(f.Id, f.Name, _tFood)">Delete</button></td></tr> }</tbody>
                        break;
                    case "Programs":
                        <thead><tr><th>ID</th><th>Name</th><th>Weeks</th><th>Days</th><th>Level</th><th>Goal</th><th>Actions</th></tr></thead>
                        <tbody>@foreach (var p in _programs) { <tr><td>@p.Id</td><td>@p.Name</td><td>@p.DurationWeeks</td><td>@p.DaysPerWeek</td><td>@(p.TargetLevel ?? "—")</td><td>@(p.TargetGoal ?? "—")</td><td class="actions-cell"><button type="button" class="btn-action btn-edit-action" @onclick="() => OpenEditProgram(p)">Edit</button><button type="button" class="btn-action btn-delete-action" @onclick="() => ConfirmDel(p.Id, p.Name, _tProgram)">Delete</button></td></tr> }</tbody>
                        break;
                }
            </table>
        </div>
    </div>
}

<Modal IsOpen="_showExModal" OnClose="() => _showExModal = false" Size="lg">
    <div class="modal-form">
        <h2>@(_editingExId.HasValue ? "Edit Exercise" : "Add Exercise")</h2>
        <div class="step-dots"><span class="dot @(_exStep == 0 ? "active" : "")"></span><span class="dot @(_exStep == 1 ? "active" : "")"></span></div>

        @if (_exStep == 0)
        {
            <div class="mf-grid">
                <div class="mf-group"><label>Name *</label><input class="mf-input" @bind="_exForm.Name" /></div>
                <div class="mf-group"><label>Type</label><input class="mf-input" @bind="_exForm.ExerciseType" placeholder="e.g. Compound" /></div>
            </div>
            <div class="mf-group"><label>Description *</label><textarea class="mf-input mf-textarea" @bind="_exForm.Description" rows="3"></textarea></div>
            <div class="mf-grid mf-grid-4">
                <div class="mf-group"><label>Level</label><select class="mf-input" @bind="_exForm.Level">@foreach (var l in Enum.GetValues<ExerciseLevel>()) { <option value="@l">@l</option> }</select></div>
                <div class="mf-group"><label>Movement</label><select class="mf-input" @bind="_exForm.MovementType">@foreach (var m in Enum.GetValues<MovementType>()) { <option value="@m">@m</option> }</select></div>
                <div class="mf-group"><label>MET</label><input type="number" class="mf-input" @bind="_exForm.MetValue" step="0.1" min="0" /></div>
                <div class="mf-group"><label>Difficulty</label><input type="number" class="mf-input" @bind="_exForm.DifficultyRating" min="1" max="10" /></div>
            </div>
            <div class="mf-actions"><button type="button" class="btn-ghost" @onclick="() => _showExModal = false">Cancel</button><button type="button" class="btn-glow" @onclick="() => _exStep = 1">Next</button></div>
        }
        else
        {
            <div class="mf-group"><label>Muscle Groups</label>
                <div class="chip-grid">@foreach (var mg in _muscleGroups) { var sel = _exForm.MuscleGroupIds.Contains(mg.Id); var pri = _exForm.PrimaryMuscleGroupIds.Contains(mg.Id); <div class="chip-wrapper"><button type="button" class="chip @(sel ? (pri ? "chip-primary" : "chip-selected") : "")" @onclick="() => ToggleExMg(mg.Id)">@mg.Name</button>@if (sel) { <button type="button" class="chip-star @(pri ? "active" : "")" @onclick="() => ToggleExPri(mg.Id)" aria-label="Toggle primary muscle"><span class="icon icon-star" aria-hidden="true"></span></button> }</div> }</div>
            </div>
            <div class="mf-group"><label>Equipment</label>
                <div class="chip-grid">@foreach (var eq in _equipment) { var sel = _exForm.EquipmentIds.Contains(eq.Id); <button type="button" class="chip @(sel ? "chip-selected" : "")" @onclick="() => ToggleExEq(eq.Id)">@eq.Name</button> }</div>
            </div>
            <div class="mf-group"><label>Alternatives</label>
                <div class="chip-grid">@foreach (var ex in _exercises.Where(e => !_editingExId.HasValue || e.Id != _editingExId.Value)) { var sel = _exForm.AlternativeIds.Contains(ex.Id); <button type="button" class="chip @(sel ? "chip-selected" : "")" @onclick="() => ToggleExAlt(ex.Id)">@ex.Name</button> }</div>
            </div>
            <div class="mf-actions"><button type="button" class="btn-ghost" @onclick="() => _exStep = 0">Back</button><button type="button" class="btn-glow" @onclick="SaveExercise" disabled="@_isSaving">@(_isSaving ? "Saving..." : "Save")</button></div>
        }
    </div>
</Modal>

<Modal IsOpen="_showSimpleModal" OnClose="() => _showSimpleModal = false" Size="sm">
    <div class="modal-form">
        <h2>@_simpleTitle</h2>
        @switch (_simpleType)
        {
            case _tEquipment:
                <div class="mf-group"><label>Name *</label><input class="mf-input" @bind="_eqName" /></div>
                break;
            case _tMuscle:
                <div class="mf-group"><label>Name *</label><input class="mf-input" @bind="_mgForm.Name" /></div>
                <div class="mf-group"><label>Body Region</label><input class="mf-input" @bind="_mgForm.BodyRegion" placeholder="e.g. Upper Body" /></div>
                break;
            case _tFood:
                <div class="mf-group"><label>Name *</label><input class="mf-input" @bind="_foodForm.Name" /></div>
                <div class="mf-grid mf-grid-4">
                    <div class="mf-group"><label>Cal/100g *</label><input type="number" class="mf-input" @bind="_foodForm.CaloriesPer100g" step="0.1" /></div>
                    <div class="mf-group"><label>Protein</label><input type="number" class="mf-input" @bind="_foodForm.ProteinPer100g" step="0.1" /></div>
                    <div class="mf-group"><label>Carbs</label><input type="number" class="mf-input" @bind="_foodForm.CarbsPer100g" step="0.1" /></div>
                    <div class="mf-group"><label>Fat</label><input type="number" class="mf-input" @bind="_foodForm.FatPer100g" step="0.1" /></div>
                </div>
                break;
            case _tProgram:
                <div class="mf-group"><label>Name *</label><input class="mf-input" @bind="_progForm.Name" /></div>
                <div class="mf-group"><label>Description</label><textarea class="mf-input mf-textarea" @bind="_progForm.Description" rows="2"></textarea></div>
                <div class="mf-grid mf-grid-4">
                    <div class="mf-group"><label>Weeks</label><input type="number" class="mf-input" @bind="_progForm.DurationWeeks" min="1" /></div>
                    <div class="mf-group"><label>Days/wk</label><input type="number" class="mf-input" @bind="_progForm.DaysPerWeek" min="1" max="7" /></div>
                    <div class="mf-group"><label>Level</label><select class="mf-input" @bind="_progForm.TargetLevel"><option value="">Any</option>@foreach (var l in Enum.GetValues<FitnessLevel>()) { <option value="@l.ToString()">@l</option> }</select></div>
                    <div class="mf-group"><label>Goal</label><select class="mf-input" @bind="_progForm.TargetGoal"><option value="">Any</option>@foreach (var g in Enum.GetValues<PrimaryGoal>()) { <option value="@g.ToString()">@g</option> }</select></div>
                </div>
                <div class="mf-group"><label><input type="checkbox" @bind="_progForm.IsPreBuilt" /> Pre-built</label></div>
                break;
        }
        <div class="mf-actions"><button type="button" class="btn-ghost" @onclick="() => _showSimpleModal = false">Cancel</button><button type="button" class="btn-glow" @onclick="SaveSimple" disabled="@_isSaving">@(_isSaving ? "Saving..." : "Save")</button></div>
    </div>
</Modal>

<Modal IsOpen="_showWkModal" OnClose="() => _showWkModal = false" Size="lg">
    <div class="modal-form">
        <h2>@(_editingWkId.HasValue ? "Edit Workout" : "Add Workout")</h2>
        <div class="mf-grid">
            <div class="mf-group"><label>Name *</label><input class="mf-input" @bind="_wkForm.Name" /></div>
            <div class="mf-group"><label>User</label><select class="mf-input" @bind="_wkForm.UserId">@foreach (var u in _users) { <option value="@u.Id">@u.Username</option> }</select></div>
        </div>
        <div class="mf-grid">
            <div class="mf-group"><label>Program</label><select class="mf-input" @bind="_wkForm.ProgramId"><option value="">None</option>@foreach (var p in _programs) { <option value="@p.Id">@p.Name</option> }</select></div>
            <div class="mf-group"><label>Sort</label><input type="number" class="mf-input" @bind="_wkForm.SortOrder" min="0" /></div>
        </div>
        <div class="mf-group"><label>Exercises</label>
            @for (int i = 0; i < _wkForm.Exercises.Count; i++) { var idx = i; <div class="wk-ex-row"><select class="mf-input" @bind="_wkForm.Exercises[idx].ExerciseId">@foreach (var ex in _exercises) { <option value="@ex.Id">@ex.Name</option> }</select><input type="number" class="mf-input mf-sm" @bind="_wkForm.Exercises[idx].Sets" min="1" placeholder="Sets" /><input type="number" class="mf-input mf-sm" @bind="_wkForm.Exercises[idx].Reps" min="1" placeholder="Reps" /><input type="number" class="mf-input mf-sm" @bind="_wkForm.Exercises[idx].RestTimeSec" min="0" placeholder="Rest" /><button type="button" class="rm-btn" @onclick="() => _wkForm.Exercises.RemoveAt(idx)" aria-label="Remove exercise"><span class="icon icon-x" aria-hidden="true"></span></button></div> }
            <button type="button" class="add-ex-btn" @onclick='() => _wkForm.Exercises.Add(new WorkoutExerciseEntry { ExerciseId = _exercises.FirstOrDefault()?.Id ?? 0 })'>+ Add Exercise</button>
        </div>
        <div class="mf-actions"><button type="button" class="btn-ghost" @onclick="() => _showWkModal = false">Cancel</button><button type="button" class="btn-glow" @onclick="SaveWorkout" disabled="@_isSaving">@(_isSaving ? "Saving..." : "Save")</button></div>
    </div>
</Modal>

<Modal IsOpen="_showDelConfirm" OnClose="() => _showDelConfirm = false" Size="sm">
    <div class="modal-form del-modal">
        <h2>Delete @_delName?</h2>
        <p>This action cannot be undone.</p>
        <div class="mf-actions"><button type="button" class="btn-ghost" @onclick="() => _showDelConfirm = false">Cancel</button><button type="button" class="btn-danger" @onclick="ExecuteDelete" disabled="@_isDeleting">@(_isDeleting ? "Deleting..." : "Delete")</button></div>
    </div>
</Modal>

@code {
    private bool _isLoading = true;
    private bool _isAdmin;
    private int _userId;

    private const string _tExercise = "exercise", _tWorkout = "workout", _tEquipment = "equipment", _tMuscle = "musclegroup", _tFood = "food", _tProgram = "program";

    private AdminCounts _counts = new();
    private List<User> _users = new();
    private List<Exercise> _exercises = new();
    private List<Workout> _workouts = new();
    private List<Equipment> _equipment = new();
    private List<MuscleGroup> _muscleGroups = new();
    private List<Food> _foods = new();
    private List<Models.Program> _programs = new();

    private readonly string[] _tabs = { "Users", "Exercises", "Workouts", "Equipment", "Muscle Groups", "Foods", "Programs" };
    private string _activeTab = "Users";
    private string? _message;
    private bool _isError;
    private bool _isSaving;

    private bool _showExModal;
    private int? _editingExId;
    private ExerciseFormData _exForm = new();
    private int _exStep;

    private bool _showSimpleModal;
    private string _simpleType = "";
    private string _simpleTitle = "";
    private int? _editingSimpleId;
    private string _eqName = "";
    private MuscleGroupFormData _mgForm = new();
    private FoodFormData _foodForm = new();
    private ProgramFormData _progForm = new();

    private bool _showWkModal;
    private int? _editingWkId;
    private WorkoutFormData _wkForm = new();

    private bool _showDelConfirm;
    private string _delName = "";
    private int _delId;
    private string _delType = "";
    private bool _isDeleting;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        var state = await AuthState.GetAuthenticationStateAsync();
        if (state.User.Identity is not { IsAuthenticated: true }) { try { Navigation.NavigateTo("/login", forceLoad: true); } catch { } return; }
        _userId = int.Parse(state.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)!.Value);
        _isAdmin = await AdminService.IsAdminAsync(_userId);
        if (_isAdmin) await LoadAllData();
        _isLoading = false;
        StateHasChanged();
    }

    private async Task LoadAllData()
    {
        _counts = await AdminService.GetCountsAsync();
        _users = await AdminService.GetAllUsersAsync();
        _exercises = await AdminService.GetAllExercisesAsync();
        _workouts = await AdminService.GetAllWorkoutsAsync();
        _equipment = await AdminService.GetAllEquipmentAsync();
        _muscleGroups = await AdminService.GetAllMuscleGroupsAsync();
        _foods = await AdminService.GetAllFoodsAsync();
        _programs = await AdminService.GetAllProgramsAsync();
    }

    private void SwitchTab(string tab) { _activeTab = tab; _message = null; }
    private void Msg(string text, bool err) { _message = text; _isError = err; }

    private void OpenAddModal()
    {
        _message = null;
        switch (_activeTab)
        {
            case "Exercises": _editingExId = null; _exForm = new(); _exStep = 0; _showExModal = true; break;
            case "Workouts": _editingWkId = null; _wkForm = new WorkoutFormData { UserId = _users.FirstOrDefault()?.Id ?? _userId }; _showWkModal = true; break;
            case "Equipment": _editingSimpleId = null; _eqName = ""; _simpleType = _tEquipment; _simpleTitle = "Add Equipment"; _showSimpleModal = true; break;
            case "Muscle Groups": _editingSimpleId = null; _mgForm = new(); _simpleType = _tMuscle; _simpleTitle = "Add Muscle Group"; _showSimpleModal = true; break;
            case "Foods": _editingSimpleId = null; _foodForm = new(); _simpleType = _tFood; _simpleTitle = "Add Food"; _showSimpleModal = true; break;
            case "Programs": _editingSimpleId = null; _progForm = new(); _simpleType = _tProgram; _simpleTitle = "Add Program"; _showSimpleModal = true; break;
        }
    }

    private async Task OpenEditExercise(int id)
    {
        var ex = await AdminService.GetExerciseByIdAsync(id);
        if (ex is null) return;
        _editingExId = id;
        _exForm = new ExerciseFormData { Name = ex.Name, Description = ex.Description, ExerciseType = ex.ExerciseType, DifficultyRating = ex.DifficultyRating, Level = ex.Level, MovementType = ex.MovementType, MetValue = ex.MetValue, RepTimeSec = ex.RepTimeSec, MuscleGroupIds = ex.ExerciseMuscleGroups.Select(m => m.MuscleGroupId).ToList(), PrimaryMuscleGroupIds = ex.ExerciseMuscleGroups.Where(m => m.IsPrimary).Select(m => m.MuscleGroupId).ToList(), EquipmentIds = ex.ExerciseEquipment.Select(e => e.EquipmentId).ToList(), AlternativeIds = ex.Alternatives.Select(a => a.AlternativeExerciseId).ToList() };
        _exStep = 0; _showExModal = true;
    }

    private async Task SaveExercise()
    {
        _isSaving = true;
        if (string.IsNullOrWhiteSpace(_exForm.Name) || string.IsNullOrWhiteSpace(_exForm.Description)) { Msg("Name and description required.", true); _isSaving = false; return; }
        if (_editingExId.HasValue) { var ok = await AdminService.UpdateExerciseAsync(_editingExId.Value, _exForm); Msg(ok ? "Exercise updated." : "Failed.", !ok); }
        else { await AdminService.CreateExerciseAsync(_exForm); Msg("Exercise created.", false); }
        _exercises = await AdminService.GetAllExercisesAsync(); _counts = await AdminService.GetCountsAsync();
        _showExModal = false; _isSaving = false;
    }

    private async Task OpenEditWorkout(int id)
    {
        var w = await AdminService.GetWorkoutByIdAsync(id);
        if (w is null) return;
        _editingWkId = id;
        _wkForm = new WorkoutFormData { Name = w.Name, UserId = w.UserId, ProgramId = w.ProgramId, SortOrder = w.SortOrder, Exercises = w.WorkoutExercises.OrderBy(x => x.SortOrder).Select(x => new WorkoutExerciseEntry { ExerciseId = x.ExerciseId, Sets = x.Sets, Reps = x.Reps, RestTimeSec = x.RestTimeSec }).ToList() };
        _showWkModal = true;
    }

    private async Task SaveWorkout()
    {
        _isSaving = true;
        if (string.IsNullOrWhiteSpace(_wkForm.Name)) { Msg("Name required.", true); _isSaving = false; return; }
        if (_editingWkId.HasValue) { var ok = await AdminService.UpdateWorkoutAsync(_editingWkId.Value, _wkForm); Msg(ok ? "Workout updated." : "Failed.", !ok); }
        else { await AdminService.CreateWorkoutAsync(_wkForm); Msg("Workout created.", false); }
        _workouts = await AdminService.GetAllWorkoutsAsync(); _counts = await AdminService.GetCountsAsync();
        _showWkModal = false; _isSaving = false;
    }

    private void OpenEditEquipment(Equipment eq) { _editingSimpleId = eq.Id; _eqName = eq.Name; _simpleType = _tEquipment; _simpleTitle = "Edit Equipment"; _showSimpleModal = true; }
    private void OpenEditMuscleGroup(MuscleGroup mg) { _editingSimpleId = mg.Id; _mgForm = new MuscleGroupFormData { Name = mg.Name, BodyRegion = mg.BodyRegion }; _simpleType = _tMuscle; _simpleTitle = "Edit Muscle Group"; _showSimpleModal = true; }
    private void OpenEditFood(Food f) { _editingSimpleId = f.Id; _foodForm = new FoodFormData { Name = f.Name, CaloriesPer100g = f.CaloriesPer100g, ProteinPer100g = f.ProteinPer100g, CarbsPer100g = f.CarbsPer100g, FatPer100g = f.FatPer100g }; _simpleType = _tFood; _simpleTitle = "Edit Food"; _showSimpleModal = true; }
    private void OpenEditProgram(Models.Program p) { _editingSimpleId = p.Id; _progForm = new ProgramFormData { Name = p.Name, Description = p.Description, DurationWeeks = p.DurationWeeks, DaysPerWeek = p.DaysPerWeek, TargetLevel = p.TargetLevel, TargetGoal = p.TargetGoal, IsPreBuilt = p.IsPreBuilt, CreatedByUserId = p.CreatedByUserId }; _simpleType = _tProgram; _simpleTitle = "Edit Program"; _showSimpleModal = true; }

    private async Task SaveSimple()
    {
        _isSaving = true;
        switch (_simpleType)
        {
            case _tEquipment:
                if (string.IsNullOrWhiteSpace(_eqName)) { Msg("Name required.", true); _isSaving = false; return; }
                if (_editingSimpleId.HasValue) await AdminService.UpdateEquipmentAsync(_editingSimpleId.Value, _eqName); else await AdminService.CreateEquipmentAsync(_eqName);
                _equipment = await AdminService.GetAllEquipmentAsync(); break;
            case _tMuscle:
                if (string.IsNullOrWhiteSpace(_mgForm.Name)) { Msg("Name required.", true); _isSaving = false; return; }
                if (_editingSimpleId.HasValue) await AdminService.UpdateMuscleGroupAsync(_editingSimpleId.Value, _mgForm); else await AdminService.CreateMuscleGroupAsync(_mgForm);
                _muscleGroups = await AdminService.GetAllMuscleGroupsAsync(); break;
            case _tFood:
                if (string.IsNullOrWhiteSpace(_foodForm.Name)) { Msg("Name required.", true); _isSaving = false; return; }
                if (_editingSimpleId.HasValue) await AdminService.UpdateFoodAsync(_editingSimpleId.Value, _foodForm); else await AdminService.CreateFoodAsync(_foodForm);
                _foods = await AdminService.GetAllFoodsAsync(); break;
            case _tProgram:
                if (string.IsNullOrWhiteSpace(_progForm.Name)) { Msg("Name required.", true); _isSaving = false; return; }
                if (_editingSimpleId.HasValue) await AdminService.UpdateProgramAsync(_editingSimpleId.Value, _progForm); else await AdminService.CreateProgramAsync(_progForm);
                _programs = await AdminService.GetAllProgramsAsync(); break;
        }
        _counts = await AdminService.GetCountsAsync();
        Msg($"{_simpleType} saved.", false);
        _showSimpleModal = false; _isSaving = false;
    }

    private void ConfirmDel(int id, string name, string type) { _delId = id; _delName = name; _delType = type; _showDelConfirm = true; }

    private async Task ExecuteDelete()
    {
        _isDeleting = true;
        bool ok = _delType switch
        {
            _tExercise => await AdminService.DeleteExerciseAsync(_delId),
            _tWorkout => await AdminService.DeleteWorkoutAsync(_delId),
            _tEquipment => await AdminService.DeleteEquipmentAsync(_delId),
            _tMuscle => await AdminService.DeleteMuscleGroupAsync(_delId),
            _tFood => await AdminService.DeleteFoodAsync(_delId),
            _tProgram => await AdminService.DeleteProgramAsync(_delId),
            _ => false
        };
        if (ok) { await LoadAllData(); Msg("Deleted.", false); } else { Msg("Failed to delete.", true); }
        _showDelConfirm = false; _isDeleting = false;
    }

    private void ToggleExMg(int id) { if (!_exForm.MuscleGroupIds.Remove(id)) _exForm.MuscleGroupIds.Add(id); else _exForm.PrimaryMuscleGroupIds.Remove(id); }
    private void ToggleExPri(int id) { if (_exForm.MuscleGroupIds.Contains(id)) { if (!_exForm.PrimaryMuscleGroupIds.Remove(id)) _exForm.PrimaryMuscleGroupIds.Add(id); } }
    private void ToggleExEq(int id) { if (!_exForm.EquipmentIds.Remove(id)) _exForm.EquipmentIds.Add(id); }
    private void ToggleExAlt(int id) { if (!_exForm.AlternativeIds.Remove(id)) _exForm.AlternativeIds.Add(id); }
}
