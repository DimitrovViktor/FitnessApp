@inject WorkoutService WorkoutService
@inject SettingsService SettingsSvc
@inject CustomAuthStateProvider AuthState
@inject NavigationManager Navigation
@using FitnessApp.Models.Enums

<PageTitle>Exercise Library - Fitness App</PageTitle>

@if (_isLoading)
{
    <div class="loading-state"><p>Loading...</p></div>
}
else
{
    <div class="exercises-page">

        <div class="search-box">
            <span class="search-icon">⌕</span>
            <input class="search-input" placeholder="Search exercises, muscles..." @bind="_search" @bind:event="oninput" />
        </div>

        <div class="library-section-grid">
            @foreach (var sec in ExerciseSections)
            {
                var sectionKey = sec.Key;
                <button type="button" class="library-section-card @(_exerciseSection == sectionKey ? "active" : "")" @onclick="() => SelectExerciseSection(sectionKey)">
                    <span class="library-section-title">@sec.Label</span>
                    <span class="library-section-copy">@sec.Description</span>
                    <span class="library-section-count">@GetExerciseSectionCount(sectionKey) exercises</span>
                </button>
            }
        </div>

        @if (!string.IsNullOrEmpty(_exerciseSection))
        {
            <div class="filter-section">
                <div class="filter-group">
                    <span class="filter-label">Muscle Group</span>
                    <div class="pill-row">
                        <button type="button" class="pill @(_filterMuscles.Count == 0 ? "pill-active" : "")" @onclick="() => _filterMuscles.Clear()">All</button>
                        @foreach (var mg in GetVisibleMuscleGroups())
                        {
                            var name = mg.Name;
                            <button type="button" class="pill @(_filterMuscles.Contains(name) ? "pill-active" : "")" @onclick="() => ToggleMuscle(name)">@name</button>
                        }
                    </div>
                </div>
                <div class="filter-row">
                    <div class="filter-group">
                        <span class="filter-label">Difficulty</span>
                        <div class="pill-row">
                            <button type="button" class="pill-sub @(_filterDiff == "" ? "pill-sub-active" : "")" @onclick='() => _filterDiff = ""'>All</button>
                            @foreach (var lv in Enum.GetValues<ExerciseLevel>())
                            {
                                var lvStr = lv.ToString();
                                <button type="button" class="pill-sub @(_filterDiff == lvStr ? "pill-sub-active" : "")" @onclick="() => _filterDiff = lvStr">@lvStr</button>
                            }
                        </div>
                    </div>
                    <div class="filter-group">
                        <span class="filter-label">Equipment</span>
                        <div class="pill-row">
                            <button type="button" class="pill-sub @(_filterEquip == "" ? "pill-sub-active" : "")" @onclick='() => _filterEquip = ""'>All</button>
                            @foreach (var eq in GetVisibleEquipment())
                            {
                                var name = eq.Name;
                                <button type="button" class="pill-sub @(_filterEquip == name ? "pill-sub-active" : "")" @onclick="() => _filterEquip = name">@name</button>
                            }
                        </div>
                    </div>
                    <div class="filter-count">@GetFiltered().Count exercises</div>
                </div>
            </div>
        }

        @{ var visibleExercises = GetFiltered().Take(60).ToList(); }
        @if (visibleExercises.Count == 0)
        {
            <div class="empty-state"><p>No exercises match this section and filter combination.</p></div>
        }
        else
        {
            <div class="ex-grid">
                @foreach (var ex in visibleExercises)
                {
                    var exRef = ex;
                    <div class="ex-card" @onclick="() => OpenDetail(exRef)">
                        <div class="ex-card-img">
                            @{ var thumb = ex.Media.FirstOrDefault(m => m.MediaType == MediaType.Image); }
                            @if (thumb is not null)
                            {
                                <img src="@thumb.Url" alt="@ex.Name" />
                            }
                            else
                            {
                                <span class="ex-card-placeholder">@ex.Name[0]</span>
                            }
                        </div>
                        <div class="ex-card-body">
                            <span class="ex-card-name">@ex.Name</span>
                            <span class="ex-card-muscles">@PrimaryStr(ex)@(SecondaryFirst(ex) is not null ? $" · {SecondaryFirst(ex)}" : "")</span>
                            <div class="ex-card-tags">
                                <span class="diff-tag diff-@ex.Level.ToString().ToLower()">@ex.Level</span>
                                <span class="equip-tag">@EquipFirst(ex)</span>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
}

<Modal IsOpen="_showDetail" OnClose="CloseDetail" Size="xl">
    @if (_detailEx is not null)
    {
        <div class="detail-modal">
            <div class="detail-banner">
                @{ var detailVid = _detailEx.Media.FirstOrDefault(m => m.MediaType == MediaType.Video); }
                @{ var detailImg = _detailEx.Media.FirstOrDefault(m => m.MediaType == MediaType.Image); }
                @if (detailImg is not null)
                {
                    <img src="@detailImg.Url" alt="@_detailEx.Name" class="detail-banner-img" />
                }
                else
                {
                    <div class="detail-banner-placeholder">@_detailEx.Name</div>
                }
            </div>

            <div class="detail-body">
                <div class="detail-title-row">
                    <h2>@_detailEx.Name</h2>
                    <div class="detail-badges">
                        <span class="diff-tag diff-@_detailEx.Level.ToString().ToLower()">@_detailEx.Level</span>
                        <span class="equip-tag">@EquipFirst(_detailEx)</span>
                        <span class="equip-tag">@_detailEx.MovementType</span>
                        <span class="met-tag">MET @_detailEx.MetValue</span>
                    </div>
                </div>

                <div class="detail-grid">
                    <div class="detail-left">
                        <div class="detail-section">
                            <span class="detail-heading">Proper Form</span>
                            <p class="detail-text">@_detailEx.Description</p>
                        </div>

                        <div class="detail-section">
                            <span class="detail-heading">Targeted Muscles</span>
                            <div class="muscle-list">
                                @foreach (var mg in _detailEx.ExerciseMuscleGroups.OrderByDescending(m => m.IsPrimary))
                                {
                                    <div class="muscle-row">
                                        <span class="muscle-dot @(mg.IsPrimary ? "dot-primary" : "dot-secondary")"></span>
                                        <span class="muscle-name @(mg.IsPrimary ? "" : "muscle-sec")">@mg.MuscleGroup.Name</span>
                                        <span class="muscle-role">@(mg.IsPrimary ? "Primary" : "Secondary")</span>
                                    </div>
                                }
                            </div>
                        </div>

                        @if (_detailEx.Alternatives.Count > 0)
                        {
                            <div class="detail-section">
                                <span class="detail-heading">Alternatives</span>
                                <div class="alt-list">
                                    @foreach (var alt in _detailEx.Alternatives)
                                    {
                                        var altEx = alt.AlternativeExercise;
                                        <div class="alt-row" @onclick="() => OpenDetail(FindExercise(altEx.Id))" @onclick:stopPropagation>
                                            <span class="alt-name">@altEx.Name</span>
                                            <span class="alt-arrow">to</span>
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                    </div>

                    <div class="detail-right">
                        <div class="detail-section">
                            <span class="detail-heading">Video Demo</span>
                            @if (detailVid is not null)
                            {
                                <div class="detail-video">
                                    <iframe src="@WorkoutService.GetYouTubeEmbedUrl(detailVid.Url)" allow="autoplay; encrypted-media" allowfullscreen frameborder="0"></iframe>
                                </div>
                            }
                            else
                            {
                                <div class="detail-video-placeholder">
                                    <div class="play-circle"><div class="play-triangle"></div></div>
                                    <span class="vid-label">Video demonstration</span>
                                </div>
                            }
                        </div>

                        <div class="detail-section">
                            <span class="detail-heading">Calorie Estimates</span>
                            <div class="cal-table">
                                <div class="cal-hdr">
                                    <span>Weight</span>
                                    <span>10 min</span>
                                    <span>20 min</span>
                                    <span>30 min</span>
                                </div>
                                @foreach (var (label, kg) in CalRanges())
                                {
                                    <div class="cal-row">
                                        <span class="cal-range">@label</span>
                                        <span class="cal-val">@CalBurn(kg, 10)</span>
                                        <span class="cal-val">@CalBurn(kg, 20)</span>
                                        <span class="cal-val">@CalBurn(kg, 30)</span>
                                    </div>
                                }
                            </div>
                            <span class="cal-source">Source: Compendium of Physical Activities</span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="detail-footer">
                <button type="button" class="btn-ghost" @onclick="CloseDetail">Close</button>
            </div>
        </div>
    }
</Modal>

@code {
    private bool _isLoading = true;
    private int _userId;
    private string _weightUnit = "kg";
    private string _energyUnit = "kcal";
    private List<Exercise> _allExercises = new();
    private List<MuscleGroup> _allMuscleGroups = new();
    private List<Equipment> _allEquipment = new();

    private string _search = "";
    private string _exerciseSection = "strength";
    private HashSet<string> _filterMuscles = new();
    private string _filterDiff = "";
    private string _filterEquip = "";

    private static readonly (string Key, string Label, string Description)[] ExerciseSections =
    {
        ("strength", "Strength Library", "Resistance exercises for muscle, strength, and structured workouts."),
        ("cardio", "Cardio Modalities", "Running, cycling, rowing, conditioning, and heart-rate based training."),
        ("mobility", "Warmups and Mobility", "Preparation, activation, stretching, and recovery-focused movement.")
    };

    private bool _showDetail;
    private Exercise? _detailEx;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        var state = await AuthState.GetAuthenticationStateAsync();
        if (state.User.Identity is not { IsAuthenticated: true }) { try { Navigation.NavigateTo("/login", forceLoad: true); } catch { } return; }
        _userId = int.Parse(state.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)!.Value);
        var settings = await SettingsSvc.GetSettingsAsync(_userId);
        _weightUnit = settings.WeightUnit;
        _energyUnit = settings.EnergyUnit;
        _allExercises = await WorkoutService.GetExerciseLibraryAsync();
        _allMuscleGroups = await WorkoutService.GetAllMuscleGroupsAsync();
        _allEquipment = await WorkoutService.GetAllEquipmentAsync();
        _isLoading = false;
        StateHasChanged();
    }

    private List<Exercise> GetFiltered()
    {
        return _allExercises.Where(e =>
        {
            if (!MatchesExerciseSection(e, _exerciseSection)) return false;
            if (!string.IsNullOrWhiteSpace(_search) && !e.Name.Contains(_search, StringComparison.OrdinalIgnoreCase)
                && !e.Description.Contains(_search, StringComparison.OrdinalIgnoreCase)
                && !e.ExerciseMuscleGroups.Any(m => m.MuscleGroup.Name.Contains(_search, StringComparison.OrdinalIgnoreCase))
                && !e.ExerciseEquipment.Any(eq => eq.Equipment.Name.Contains(_search, StringComparison.OrdinalIgnoreCase))) return false;
            if (_filterMuscles.Count > 0 && !_filterMuscles.All(fm => e.ExerciseMuscleGroups.Any(m => m.MuscleGroup.Name == fm))) return false;
            if (!string.IsNullOrEmpty(_filterDiff) && e.Level.ToString() != _filterDiff) return false;
            if (!string.IsNullOrEmpty(_filterEquip) && !e.ExerciseEquipment.Any(eq => eq.Equipment.Name == _filterEquip)) return false;
            return true;
        }).ToList();
    }

    private void SelectExerciseSection(string section)
    {
        _exerciseSection = section;
        _filterMuscles.Clear();
        _filterDiff = "";
        _filterEquip = "";
    }

    private void OpenDetail(Exercise? ex) { if (ex is null) return; _detailEx = ex; _showDetail = true; }
    private void CloseDetail() { _showDetail = false; _detailEx = null; }
    private void ToggleMuscle(string name) { if (!_filterMuscles.Remove(name)) _filterMuscles.Add(name); }

    private int GetExerciseSectionCount(string section) => _allExercises.Count(e => MatchesExerciseSection(e, section));

    private List<MuscleGroup> GetVisibleMuscleGroups() => _allMuscleGroups
        .Where(mg => _allExercises.Any(e => MatchesExerciseSection(e, _exerciseSection) && e.ExerciseMuscleGroups.Any(em => em.MuscleGroup.Name == mg.Name)))
        .ToList();

    private List<Equipment> GetVisibleEquipment() => _allEquipment
        .Where(eq => _allExercises.Any(e => MatchesExerciseSection(e, _exerciseSection) && e.ExerciseEquipment.Any(ee => ee.Equipment.Name == eq.Name)))
        .ToList();

    private static bool MatchesExerciseSection(Exercise exercise, string section)
    {
        var isCardio = exercise.MovementType == MovementType.Cardio;
        var isMobility = IsWarmupOrMobility(exercise);

        return section switch
        {
            "cardio" => isCardio,
            "mobility" => isMobility,
            _ => !isCardio && !isMobility
        };
    }

    private static bool IsWarmupOrMobility(Exercise exercise)
    {
        var text = $"{exercise.Name} {exercise.Description} {exercise.ExerciseType}";
        return ContainsAny(text, "warmup", "warm-up", "mobility", "stretch", "activation", "recovery", "cooldown", "cool down", "dynamic", "foam roll", "prehab", "mobility drill");
    }

    private static bool ContainsAny(string value, params string[] terms) => terms.Any(term => value.Contains(term, StringComparison.OrdinalIgnoreCase));

    private Exercise? FindExercise(int id) => _allExercises.FirstOrDefault(e => e.Id == id);

    private static string PrimaryStr(Exercise ex) =>
        string.Join(", ", ex.ExerciseMuscleGroups.Where(m => m.IsPrimary).Select(m => m.MuscleGroup.Name));

    private static string? SecondaryFirst(Exercise ex) =>
        ex.ExerciseMuscleGroups.Where(m => !m.IsPrimary).Select(m => m.MuscleGroup.Name).FirstOrDefault();

    private static string EquipFirst(Exercise ex) =>
        ex.ExerciseEquipment.Select(e => e.Equipment.Name).FirstOrDefault() ?? "Bodyweight";

    private string CalBurn(int weightKg, int minutes) =>
        _detailEx is null ? "—" : SettingsService.FormatEnergy(_detailEx.MetValue * weightKg * (minutes / 60m), _energyUnit);

    private IEnumerable<(string Label, int Kg)> CalRanges()
    {
        foreach (var kg in new[] { 55, 65, 75, 85, 95 })
        {
            var lower = kg == 95 ? SettingsService.FromKg(90, _weightUnit) : SettingsService.FromKg(kg - 5, _weightUnit);
            var upper = SettingsService.FromKg(kg + 5, _weightUnit);
            var unit = SettingsService.WeightLabel(_weightUnit);
            var label = kg == 95 ? $"{Math.Round(lower ?? 90, 0)}+ {unit}" : $"{Math.Round(lower ?? kg - 5, 0)}–{Math.Round(upper ?? kg + 5, 0)} {unit}";
            yield return (label, kg);
        }
    }
}
