    private void SelectAddExercise(int exerciseId)
    {
        _selectedAddExerciseId = exerciseId;
        _addExerciseError = "";
    }

    private async Task AddSelectedExerciseToSession()
    {
        if (_session is null || _selectedAddExerciseId is null) return;

        var exercise = _exerciseLibrary.FirstOrDefault(e => e.Id == _selectedAddExerciseId.Value);
        if (exercise is null)
        {
            _addExerciseError = "Select an exercise before adding it to the session.";
            return;
        }

        var sets = Math.Clamp(_addExerciseSets, 1, 20);
        var reps = Math.Clamp(_addExerciseReps, 1, 999);
        var rest = Math.Clamp(_addExerciseRest, 0, 600);

        _addExerciseSets = sets;
        _addExerciseReps = reps;
        _addExerciseRest = rest;

        var supersetGroup = ResolveAddSupersetGroup();
        int? supersetRestAfter = string.IsNullOrEmpty(_addSupersetChoice) ? null : Math.Clamp(_addSupersetRestAfter, 0, 600);

        var liveExercise = new LiveExerciseState
        {
            ExerciseId = exercise.Id,
            OriginalSets = sets,
            OriginalReps = reps,
            RestTimeSec = rest,
            SupersetGroup = supersetGroup,
            SupersetRestAfterSec = supersetRestAfter,
            SupersetRounds = Math.Max(1, sets),
            OriginalSupersetGroup = supersetGroup,
            OriginalSupersetRestAfterSec = supersetRestAfter,
            OriginalSupersetRounds = Math.Max(1, sets),
            IsSessionOnly = true
        };

        for (int i = 0; i < sets; i++)
            liveExercise.Sets.Add(new LiveSetState { Reps = reps });

        _liveState.Exercises.Add(liveExercise);
        _orderedExercises.Add(CreateSessionOnlyWorkoutExercise(exercise, liveExercise, _orderedExercises.Count));
        NormalizeLiveSupersetOrders();

        var newIndex = _liveState.Exercises.Count - 1;
        _liveState.CurrentExerciseIndex = newIndex;
        _liveState.ExpandedExerciseIndex = newIndex;

        RecalcTotals();
        await PersistState();

        _showAddExercise = false;
        _addExerciseError = "";
        _addSupersetChoice = "";
        _addSupersetRestAfter = 0;
        StateHasChanged();
    }


    private int? ResolveAddSupersetGroup()
    {
        if (string.IsNullOrEmpty(_addSupersetChoice)) return null;
        if (_addSupersetChoice == "new") return NextLiveSupersetGroup();
        return int.TryParse(_addSupersetChoice, out var group) ? group : null;
    }

    private int NextLiveSupersetGroup() => _liveState.Exercises.Where(x => x.SupersetGroup.HasValue).Select(x => x.SupersetGroup!.Value).DefaultIfEmpty(0).Max() + 1;

    private void NormalizeLiveSupersetOrders()
    {
        foreach (var group in _liveState.Exercises.Where(x => x.SupersetGroup.HasValue).Select(x => x.SupersetGroup!.Value).Distinct())
        {
            var groupExercises = _liveState.Exercises.Where(x => x.SupersetGroup == group).ToList();
            if (groupExercises.Count == 0) continue;
            var maxSets = groupExercises.Max(x => Math.Max(1, x.Sets.Count));
            var currentRounds = groupExercises.Max(x => Math.Max(1, x.SupersetRounds));
            var rounds = Math.Max(maxSets, currentRounds);
            var order = 1;
            foreach (var exercise in groupExercises)
            {
                exercise.SupersetOrder = order++;
                exercise.SupersetRestAfterSec ??= 0;
                exercise.SupersetRounds = rounds;
            }
        }

        for (int i = 0; i < _liveState.Exercises.Count && i < _orderedExercises.Count; i++)
        {
            _orderedExercises[i].SupersetGroup = _liveState.Exercises[i].SupersetGroup;
            _orderedExercises[i].SupersetOrder = _liveState.Exercises[i].SupersetOrder;
            _orderedExercises[i].SupersetRestAfterSec = _liveState.Exercises[i].SupersetRestAfterSec;
            _orderedExercises[i].SupersetRounds = Math.Max(1, _liveState.Exercises[i].SupersetRounds);
        }
    }


    private string FocusRestText(LiveExerciseState exercise, WorkoutExercise workoutExercise)
    {
        if (exercise.SupersetGroup.HasValue) return $"after this exercise: {exercise.SupersetRestAfterSec ?? 0}s";
        return $"{workoutExercise.RestTimeSec ?? _restTimerDefault}s";
    }

    private string ExerciseHeaderMeta(LiveExerciseState exercise, WorkoutExercise workoutExercise)
    {
        var parts = new List<string> { ExerciseSetSummary(exercise, workoutExercise) };
        if (exercise.SupersetGroup.HasValue)
            parts.Add($"Superset {exercise.SupersetGroup} · {GetLiveSupersetRounds(exercise)} rounds · rest after {exercise.SupersetRestAfterSec ?? 0} seconds");
        else
            parts.Add($"{workoutExercise.RestTimeSec ?? _restTimerDefault} seconds rest");
        var muscle = MuscleStr(workoutExercise.Exercise);
        if (!string.IsNullOrWhiteSpace(muscle)) parts.Add(muscle);
        if (exercise.IsSessionOnly) parts.Add("Session only");
        return string.Join(" · ", parts);
    }

    private int GetLiveSupersetRounds(LiveExerciseState exercise)
    {
        if (!exercise.SupersetGroup.HasValue) return Math.Max(1, exercise.Sets.Count);
        return _liveState.Exercises
            .Where(x => x.SupersetGroup == exercise.SupersetGroup)
            .Select(x => Math.Max(Math.Max(1, x.Sets.Count), Math.Max(1, x.SupersetRounds)))
            .DefaultIfEmpty(Math.Max(1, exercise.Sets.Count))
            .Max();
    }

    private string SupersetRoundCopy(LiveExerciseState exercise)
    {
        var rounds = GetLiveSupersetRounds(exercise);
        return $"This superset is planned for {rounds} rounds. This exercise is active for {exercise.Sets.Count} of {rounds} rounds.";
    }

    private async void SetLiveSupersetRounds(int exIdx, ChangeEventArgs e)
    {
        if (exIdx < 0 || exIdx >= _liveState.Exercises.Count) return;
        var exercise = _liveState.Exercises[exIdx];
        if (!exercise.SupersetGroup.HasValue) return;
        var groupExercises = _liveState.Exercises.Where(x => x.SupersetGroup == exercise.SupersetGroup).ToList();
        if (groupExercises.Count == 0) return;
        var maxSets = groupExercises.Max(x => Math.Max(1, x.Sets.Count));
        var requested = int.TryParse(e.Value?.ToString(), out var value) ? value : maxSets;
        var rounds = Math.Clamp(Math.Max(requested, maxSets), 1, 50);
        foreach (var groupExercise in groupExercises)
            groupExercise.SupersetRounds = rounds;
        NormalizeLiveSupersetOrders();
        RecalcTotals();
        await PersistState();
        StateHasChanged();
    }

    private static string LiveSupersetMeta(LiveExerciseState exercise) => exercise.SupersetGroup.HasValue ? $" · Superset {exercise.SupersetGroup} · {Math.Max(1, exercise.SupersetRounds)} rounds · rest after {exercise.SupersetRestAfterSec ?? 0} seconds" : string.Empty;

    private int GetRestAfterExercise(int exIdx, int defaultRest)
    {
        if (exIdx < 0 || exIdx >= _liveState.Exercises.Count) return 0;
        var exercise = _liveState.Exercises[exIdx];
        if (!exercise.SupersetGroup.HasValue) return 0;
        return Math.Clamp(exercise.SupersetRestAfterSec ?? 0, 0, 600);
    }


    private async Task GroupLiveWithPrevious(int exIdx)
    {
        if (exIdx <= 0 || exIdx >= _liveState.Exercises.Count) return;
        var previous = _liveState.Exercises[exIdx - 1];
        var current = _liveState.Exercises[exIdx];
        var group = previous.SupersetGroup ?? NextLiveSupersetGroup();
        previous.SupersetGroup = group;
        previous.SupersetRestAfterSec ??= 0;
        current.SupersetGroup = group;
        current.SupersetRestAfterSec ??= 0;
        var rounds = Math.Max(previous.Sets.Count, current.Sets.Count);
        previous.SupersetRounds = Math.Max(previous.SupersetRounds, rounds);
        current.SupersetRounds = Math.Max(current.SupersetRounds, rounds);
        NormalizeLiveSupersetOrders();
        RecalcTotals();
        await PersistState();
        StateHasChanged();
    }

    private async Task StartLiveSupersetAt(int exIdx)
    {
        if (exIdx < 0 || exIdx >= _liveState.Exercises.Count) return;
        var exercise = _liveState.Exercises[exIdx];
        exercise.SupersetGroup = NextLiveSupersetGroup();
        exercise.SupersetRestAfterSec ??= 0;
        exercise.SupersetRounds = Math.Max(1, exercise.Sets.Count);
        NormalizeLiveSupersetOrders();
        RecalcTotals();
        await PersistState();
        StateHasChanged();
    }

    private async Task RemoveLiveFromSuperset(int exIdx)
    {
        if (exIdx < 0 || exIdx >= _liveState.Exercises.Count) return;
        var exercise = _liveState.Exercises[exIdx];
        exercise.SupersetGroup = null;
        exercise.SupersetOrder = 0;
        exercise.SupersetRestAfterSec = null;
        exercise.SupersetRounds = 1;
        NormalizeLiveSupersetOrders();
        RecalcTotals();
        await PersistState();
        StateHasChanged();
    }

    private async void SetLiveSupersetRestAfter(int exIdx, ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var seconds))
            await SetLiveSupersetRestAfter(exIdx, seconds);
    }

    private async Task SetLiveSupersetRestAfter(int exIdx, int seconds)
    {
        if (exIdx < 0 || exIdx >= _liveState.Exercises.Count) return;
        var value = Math.Clamp(seconds, 0, 600);
        _liveState.Exercises[exIdx].SupersetRestAfterSec = value;
        if (exIdx < _orderedExercises.Count) _orderedExercises[exIdx].SupersetRestAfterSec = value;
        RecalcTotals();
        await PersistState();
        StateHasChanged();
    }

    private static string PickerExerciseMeta(Exercise exercise)
    {
        var muscles = string.Join(", ", exercise.ExerciseMuscleGroups.Where(m => m.IsPrimary).Select(m => m.MuscleGroup.Name));
        return string.IsNullOrWhiteSpace(muscles) ? exercise.Level.ToString() : $"{muscles} · {exercise.Level}";
    }

    private async void CompleteSet(int exIdx, int setIdx, int restSec)
    {
        _liveState.Exercises[exIdx].IsSkipped = false;
        _liveState.Exercises[exIdx].Sets[setIdx].IsSkipped = false;
        _liveState.Exercises[exIdx].Sets[setIdx].IsCompleted = true;
        RecalcTotals();
        await PersistState();

        var les = _liveState.Exercises[exIdx];
        var restAfterExercise = les.SupersetGroup.HasValue ? GetRestAfterExercise(exIdx, restSec) : restSec;

        if (les.SupersetGroup.HasValue)
        {
            var movedInsideSuperset = TryAdvanceWithinSuperset(exIdx, setIdx);
            if (!movedInsideSuperset && IsExerciseDone(les))
                AdvanceToNextExercise(exIdx);

            if (IsAllDone())
            {
                FinishWorkout();
                StateHasChanged();
                return;
            }

            MaybeStartRest(restAfterExercise);

            StateHasChanged();
            return;
        }

        var activeSets = les.Sets.Where(s => !s.IsSkipped).ToList();
        bool allExDone = activeSets.Count > 0 && activeSets.All(s => s.IsCompleted);

        if (allExDone)
        {
            AdvanceToNextExercise(exIdx);

            if (IsAllDone())
            {
                FinishWorkout();
                StateHasChanged();
                return;
            }

            MaybeStartRest(restAfterExercise);

            StateHasChanged();
            return;
        }

        MaybeStartRest(restAfterExercise);

        StateHasChanged();
    }

    private void SkipSet(int exIdx, int setIdx)
    {
        if (_confirmBeforeSkip)
        {
            _pendingSkipExIdx = exIdx;
            _pendingSkipSetIdx = setIdx;
            _pendingSkipIsExercise = false;
            return;
        }
        _ = DoSkipSetAsync(exIdx, setIdx);
    }

    private async Task DoSkipSetAsync(int exIdx, int setIdx)
    {
        _liveState.Exercises[exIdx].Sets[setIdx].IsCompleted = false;
        _liveState.Exercises[exIdx].Sets[setIdx].IsSkipped = true;
        RecalcTotals();

        var les = _liveState.Exercises[exIdx];
        if (!HasCompletedSets(les) && les.Sets.All(s => s.IsSkipped))
            les.IsSkipped = true;
        if (les.SupersetGroup.HasValue)
            TryAdvanceWithinSuperset(exIdx, setIdx);
        else if (les.Sets.Where(s => !s.IsSkipped).All(s => s.IsCompleted))
            AdvanceToNextExercise(exIdx);

        if (IsAllDone())
        {
            await PersistState();
            FinishWorkout();
            StateHasChanged();
            return;
        }

        await PersistState();
        StateHasChanged();
    }

    private async void UndoSetCompletion(int exIdx, int setIdx)
    {
        var exercise = _liveState.Exercises[exIdx];
        exercise.IsSkipped = false;
        exercise.Sets[setIdx].IsCompleted = false;
        exercise.Sets[setIdx].IsSkipped = false;
        _liveState.CurrentExerciseIndex = exIdx;
        _liveState.ExpandedExerciseIndex = exIdx;
        _showFinish = false;
        RecalcTotals();
        await PersistState();
        StateHasChanged();
    }

    private async void UndoSkipSet(int exIdx, int setIdx)
    {
        var exercise = _liveState.Exercises[exIdx];
        exercise.IsSkipped = false;
        exercise.Sets[setIdx].IsSkipped = false;
        exercise.Sets[setIdx].IsCompleted = false;
        _liveState.CurrentExerciseIndex = exIdx;
        _liveState.ExpandedExerciseIndex = exIdx;
        _showFinish = false;
        RecalcTotals();
        await PersistState();
        StateHasChanged();
    }

    private async void RemoveSet(int exIdx, int setIdx)
    {
        var exercise = _liveState.Exercises[exIdx];
        if (exercise.Sets.Count <= 1 || setIdx < 0 || setIdx >= exercise.Sets.Count) return;

        exercise.Sets.RemoveAt(setIdx);
        exercise.IsSkipped = exercise.Sets.All(s => s.IsSkipped) && !HasCompletedSets(exercise);
        NormalizeLiveSupersetOrders();
        _liveState.CurrentExerciseIndex = exIdx;
        _liveState.ExpandedExerciseIndex = exIdx;
        _showFinish = false;
        RecalcTotals();
        await PersistState();
        StateHasChanged();
    }

    private async void UndoExerciseCompletion(int exIdx)
    {
        var exercise = _liveState.Exercises[exIdx];
        exercise.IsSkipped = false;
        foreach (var set in exercise.Sets.Where(s => s.IsCompleted && !s.IsSkipped))
        {
            set.IsCompleted = false;
        }
        _liveState.CurrentExerciseIndex = exIdx;
        _liveState.ExpandedExerciseIndex = exIdx;
        _showFinish = false;
        RecalcTotals();
        await PersistState();
        StateHasChanged();
    }

    private void SkipExercise(int exIdx)
    {
        if (_confirmBeforeSkip)
        {
            _pendingSkipExIdx = exIdx;
            _pendingSkipSetIdx = null;
            _pendingSkipIsExercise = true;
            return;
        }
        _ = DoSkipExerciseAsync(exIdx);
    }

    private async Task DoSkipExerciseAsync(int exIdx)
    {
        var exercise = _liveState.Exercises[exIdx];
        if (HasCompletedSets(exercise))
        {
            foreach (var set in exercise.Sets.Where(s => !s.IsCompleted))
            {
                set.IsSkipped = true;
            }
            exercise.IsSkipped = false;
        }
        else
        {
            exercise.IsSkipped = true;
            foreach (var set in exercise.Sets)
            {
                set.IsCompleted = false;
                set.IsSkipped = true;
            }
        }

        RecalcTotals();
        AdvanceToNextExercise(exIdx);

        if (IsAllDone())
        {
            await PersistState();
            FinishWorkout();
            StateHasChanged();
            return;
        }

        await PersistState();
        StateHasChanged();
    }

    private async void UnskipExercise(int exIdx)
    {
        var exercise = _liveState.Exercises[exIdx];
        exercise.IsSkipped = false;
        foreach (var set in exercise.Sets)
        {
            set.IsSkipped = false;
        }
        _liveState.CurrentExerciseIndex = exIdx;
        _liveState.ExpandedExerciseIndex = exIdx;
        RecalcTotals();
        await PersistState();
        StateHasChanged();
    }

    private async void RestoreSkippedSets(int exIdx)
    {
        var exercise = _liveState.Exercises[exIdx];
        exercise.IsSkipped = false;
        foreach (var set in exercise.Sets)
        {
            set.IsSkipped = false;
