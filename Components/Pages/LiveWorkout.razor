    private async void AdjustReps(int exIdx, int setIdx, int delta)
    {
        var setS = _liveState.Exercises[exIdx].Sets[setIdx];
        setS.Reps = Math.Max(1, setS.Reps + delta);
        RecalcTotals();
        await PersistState();
        StateHasChanged();
    }

    private async void SetReps(int exIdx, int setIdx, ChangeEventArgs e)
    {
        var setS = _liveState.Exercises[exIdx].Sets[setIdx];
        if (int.TryParse(e.Value?.ToString(), out var reps))
            setS.Reps = Math.Clamp(reps, 1, 999);
        else
            setS.Reps = 1;

        RecalcTotals();
        await PersistState();
        StateHasChanged();
    }

    private async void SetWeight(int exIdx, int setIdx, ChangeEventArgs e)
    {
        if (decimal.TryParse(e.Value?.ToString(), out var val) && val >= 0)
            _liveState.Exercises[exIdx].Sets[setIdx].WeightKg = SettingsService.ToKg(val, _weightUnit);
        else
            _liveState.Exercises[exIdx].Sets[setIdx].WeightKg = null;
        RecalcTotals();
        await PersistState();
        StateHasChanged();
    }

    private async void AddSet(int exIdx, WorkoutExercise we)
    {
        var exercise = _liveState.Exercises[exIdx];
        var lastSet = exercise.Sets.LastOrDefault();
        exercise.IsSkipped = false;
        exercise.Sets.Add(new LiveSetState
        {
            Reps = lastSet?.Reps ?? we.Reps,
            WeightKg = lastSet?.WeightKg
        });
        NormalizeLiveSupersetOrders();
        _liveState.CurrentExerciseIndex = exIdx;
        _liveState.ExpandedExerciseIndex = exIdx;
        _showFinish = false;
        RecalcTotals();
        await PersistState();
        StateHasChanged();
    }

    private bool TryAdvanceWithinSuperset(int fromIdx, int roundIndex)
    {
        if (fromIdx < 0 || fromIdx >= _liveState.Exercises.Count) return false;
        var source = _liveState.Exercises[fromIdx];
        if (!source.SupersetGroup.HasValue) return false;

        var groupIndexes = _liveState.Exercises
            .Select((exercise, index) => new { exercise, index })
            .Where(x => x.exercise.SupersetGroup == source.SupersetGroup)
            .OrderBy(x => Math.Max(1, x.exercise.SupersetOrder))
            .ThenBy(x => x.index)
            .ToList();

        var currentPosition = groupIndexes.FindIndex(x => x.index == fromIdx);
        if (currentPosition < 0) return false;
        var rounds = GetLiveSupersetRounds(source);

        for (int i = currentPosition + 1; i < groupIndexes.Count; i++)
        {
            if (HasAvailableSupersetRoundSet(groupIndexes[i].index, roundIndex))
            {
                JumpToExercise(groupIndexes[i].index);
                return true;
            }
        }

        for (int round = roundIndex + 1; round < rounds; round++)
        {
            foreach (var item in groupIndexes)
            {
                if (HasAvailableSupersetRoundSet(item.index, round))
                {
                    JumpToExercise(item.index);
                    return true;
                }
            }
        }

        return false;
    }

    private bool HasAvailableSupersetRoundSet(int exIdx, int roundIndex)
    {
        if (exIdx < 0 || exIdx >= _liveState.Exercises.Count || roundIndex < 0) return false;
        var exercise = _liveState.Exercises[exIdx];
        if (exercise.IsSkipped || roundIndex >= exercise.Sets.Count) return false;
        var set = exercise.Sets[roundIndex];
        return !set.IsCompleted && !set.IsSkipped;
    }

    private void AdvanceToNextExercise(int fromIdx)
    {
        for (int i = fromIdx + 1; i < _liveState.Exercises.Count; i++)
        {
            var next = _liveState.Exercises[i];
            if (!next.IsSkipped && !next.Sets.Where(s => !s.IsSkipped).All(s => s.IsCompleted))
            {
                _liveState.CurrentExerciseIndex = i;
                _liveState.ExpandedExerciseIndex = i;
                return;
            }
        }
    }

    private bool IsAllDone() => _liveState.Exercises.All(e => e.IsSkipped || e.Sets.Where(s => !s.IsSkipped).All(s => s.IsCompleted));

    private void ToggleExpand(int exIdx) => _liveState.ExpandedExerciseIndex = _liveState.ExpandedExerciseIndex == exIdx ? -1 : exIdx;

    private void StartRest(int seconds)
    {
        _resting = true;
        _restTotal = seconds;
        _restRemaining = seconds;

        _restTimer?.Dispose();
        _restTimer = new System.Threading.Timer(async _ =>
        {
            _restRemaining--;
            if (_restRemaining <= 0)
            {
                _resting = false;
                _restTimer?.Dispose();
            }
            await InvokeAsync(StateHasChanged);
        }, null, 1000, 1000);
    }

    private void MaybeStartRest(int seconds)
    {
        if (_autoStartRest && seconds > 0)
            StartRest(seconds);
    }

    private string ModeStyle(string mode)
    {
        var active = _liveMode == mode;
        var border = active ? "var(--accent-border)" : "var(--border)";
        var bg = active ? "var(--accent-dim)" : "var(--bg)";
        var color = active ? "var(--accent)" : "var(--t2)";
        return $"flex:1;padding:13px;border-radius:12px;font-family:inherit;font-size:14px;font-weight:800;cursor:pointer;border:1px solid {border};background:{bg};color:{color};";
    }

    private void ExitCardio()
    {
        _liveMode = "workout";
    }

    private async Task ConfirmSkip()
    {
        var exIdx = _pendingSkipExIdx;
        var setIdx = _pendingSkipSetIdx;
        var isExercise = _pendingSkipIsExercise;
        _pendingSkipExIdx = null;
        _pendingSkipSetIdx = null;
        if (exIdx is null) return;

        if (isExercise)
            await DoSkipExerciseAsync(exIdx.Value);
        else if (setIdx is not null)
            await DoSkipSetAsync(exIdx.Value, setIdx.Value);
    }

    private void CancelSkip()
    {
        _pendingSkipExIdx = null;
        _pendingSkipSetIdx = null;
    }

    private void SkipRest()
    {
        _resting = false;
        _restTimer?.Dispose();
    }

    private void FinishWorkout()
    {
        _finishStatus = ComputeWorkoutStatus();
        _finishTitle = _finishStatus switch
        {
            WorkoutLogStatus.Complete => "Workout Complete!",
            WorkoutLogStatus.Modified => "Workout Modified",
            WorkoutLogStatus.Partial => "Workout Partial",
            _ => "Workout Summary"
        };
        _showFinish = true;
    }

    private void CancelWorkout()
    {
        _showCancelConfirm = true;
    }

    private async Task ConfirmCancel()
    {
        if (_session is not null)
        {
            if (_completedSets > 0)
            {
                var exercises = BuildExerciseLogEntries();
                await LogService.SaveWorkoutLogAsync(_userId, _session.WorkoutId, _startTime, DateTime.UtcNow, _estCalBurned, exercises, WorkoutLogStatus.Partial);
                await LogService.CheckAndSavePersonalRecordsAsync(_userId, exercises);
                await DashService.CancelScheduleAsync(_session.Id, _userId);
            }
            else
            {
                await DashService.DeleteScheduleAsync(_session.Id, _userId);
            }
        }
        _showCancelConfirm = false;
        try { Navigation.NavigateTo("/dashboard"); } catch { }
    }

    private async Task ConfirmFinish()
    {
        if (_session is not null)
        {
            if (_completedSets > 0)
            {
                await DashService.CompleteWorkoutAsync(_session.Id, _userId);

                var exercises = BuildExerciseLogEntries();
                var status = ComputeWorkoutStatus();
                await LogService.SaveWorkoutLogAsync(_userId, _session.WorkoutId, _startTime, DateTime.UtcNow, _estCalBurned, exercises, status);
                await LogService.CheckAndSavePersonalRecordsAsync(_userId, exercises);
            }
            else
            {
                await DashService.DeleteScheduleAsync(_session.Id, _userId);
            }
        }

        _showFinish = false;
        try { Navigation.NavigateTo("/dashboard"); } catch { }
    }

    private WorkoutLogStatus ComputeWorkoutStatus()
    {
        bool anySkipped = _liveState.Exercises.Any(e => e.IsSkipped);
        bool anyIncomplete = _liveState.Exercises.Any(e => !e.IsSkipped && e.Sets.Any(s => !s.IsCompleted && !s.IsSkipped));
        bool anyModified = _liveState.Exercises.Any(e => !e.IsSkipped && (e.IsSessionOnly || e.Sets.Count != e.OriginalSets || e.Sets.Any(s => s.Reps != e.OriginalReps || s.IsSkipped) || e.SupersetGroup != e.OriginalSupersetGroup || e.SupersetRestAfterSec != e.OriginalSupersetRestAfterSec || e.SupersetRounds != e.OriginalSupersetRounds));

        if (anySkipped || anyIncomplete) return WorkoutLogStatus.Partial;
        if (anyModified) return WorkoutLogStatus.Modified;
        return WorkoutLogStatus.Complete;
    }

    private List<ExerciseLogEntry> BuildExerciseLogEntries()
    {
        var entries = new List<ExerciseLogEntry>();
        decimal weight = _user?.WeightKg ?? 70m;

        for (int i = 0; i < _liveState.Exercises.Count && i < _orderedExercises.Count; i++)
        {
            var les = _liveState.Exercises[i];
            var we = _orderedExercises[i];
            var completedSets = les.Sets.Count(s => s.IsCompleted && !s.IsSkipped);
            var skippedSets = les.Sets.Count(s => s.IsSkipped);
            var hasIncompleteSets = les.Sets.Any(s => !s.IsCompleted && !s.IsSkipped);
            var status = LogStatus.Completed;

            if (les.IsSkipped || (completedSets == 0 && skippedSets > 0 && !hasIncompleteSets))
                status = LogStatus.Skipped;
            else if (les.IsSessionOnly && completedSets > 0)
                status = LogStatus.Added;
            else if (skippedSets > 0 || hasIncompleteSets || les.Sets.Count != les.OriginalSets || les.Sets.Any(s => s.Reps != les.OriginalReps) || les.SupersetGroup != les.OriginalSupersetGroup || les.SupersetRestAfterSec != les.OriginalSupersetRestAfterSec || les.SupersetRounds != les.OriginalSupersetRounds)
                status = LogStatus.Modified;

            decimal cal = 0;
            if (!les.IsSkipped)
            {
                var doneSets = les.Sets.Where(s => s.IsCompleted && !s.IsSkipped).ToList();
                if (doneSets.Count > 0)
                {
                    int avgReps = (int)Math.Round(doneSets.Average(s => s.Reps));
                    cal = WorkoutService.EstimateExerciseCalories(we.Exercise, doneSets.Count, avgReps, we.RestTimeSec ?? _restTimerDefault, weight);
                }
            }

            var entry = new ExerciseLogEntry
            {
                ExerciseId = les.ExerciseId,
                Status = status,
                CaloriesBurned = Math.Round(cal, 1)
            };

            foreach (var setS in les.Sets)
            {
                var setCompleted = setS.IsCompleted && !setS.IsSkipped;
                entry.Sets.Add(new SetLogEntry
                {
                    RepsCompleted = setCompleted ? setS.Reps : null,
                    WeightKg = setCompleted ? setS.WeightKg : null,
                    IsCompleted = setCompleted
                });
            }

            entries.Add(entry);
        }

        return entries;
    }


    private int GetEstimateRest(WorkoutExercise workoutExercise, LiveExerciseState liveExercise)
    {
        return liveExercise.SupersetGroup.HasValue ? Math.Max(0, liveExercise.SupersetRestAfterSec ?? 0) : Math.Max(0, workoutExercise.RestTimeSec ?? _restTimerDefault);
    }

    private string FormatElapsed()
    {
        var elapsed = DateTime.UtcNow - _startTime;
        return elapsed.Hours > 0 ? $"{elapsed.Hours}h {elapsed.Minutes:D2}m" : $"{elapsed.Minutes}m {elapsed.Seconds:D2}s";
    }

    private string FormatRestTime()
    {
        int m = _restRemaining / 60;
        int s = _restRemaining % 60;
        return m > 0 ? $"{m}:{s:D2}" : $"{s}s";
    }

    private double RestPercent() => _restTotal > 0 ? (double)_restRemaining / _restTotal * 100 : 0;

    private string WeightUnitLabel => SettingsService.WeightLabel(_weightUnit);

    private string DisplayWeight(decimal? weightKg)
    {
        var converted = SettingsService.FromKg(weightKg, _weightUnit);
        return converted.HasValue ? converted.Value.ToString("0.##") : string.Empty;
    }

    private string FormatEnergyValue(decimal calories) => SettingsService.FormatEnergy(calories, _energyUnit);

    private static string MuscleStr(Exercise ex) =>
        string.Join(", ", ex.ExerciseMuscleGroups.Where(m => m.IsPrimary).Select(m => m.MuscleGroup.Name));

