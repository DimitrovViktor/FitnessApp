@inject DashboardService DashService
@inject WorkoutService WorkoutService
@inject SettingsService SettingsSvc
@inject LoggingService LogService
@inject CustomAuthStateProvider AuthState
@inject NavigationManager Navigation
@using FitnessApp.Models.Enums
@using System.Text.Json
@implements IDisposable

<PageTitle>Live Workout - Fitness App</PageTitle>

@if (_isLoading)
{
    <div class="loading-state"><p>Loading...</p></div>
}
else if (_session is null)
{
    <div class="live-start">
        <div class="live-header">
            <div>
                <span class="live-kicker">Live Session</span>
                <h1>Start a session</h1>
                <p class="live-start-sub">Choose a workout to train, or track a cardio session right now.</p>
            </div>
        </div>

        <div style="display:flex;gap:8px;margin:0 0 20px;">
            <button type="button" style='@ModeStyle("workout")' @onclick='() => _liveMode = "workout"'>Workout</button>
            <button type="button" style='@ModeStyle("cardio")' @onclick='() => _liveMode = "cardio"'>Cardio</button>
        </div>

        @if (_liveMode == "cardio")
        {
            <CardioPanel UserId="_userId" OnExit="ExitCardio" />
        }
        else
        {
        <section class="live-start-card">
            <div class="live-start-head">
                <div>
                    <h2>Quick Start</h2>
                    <p>Jump straight into one of your workouts</p>
                </div>
            </div>
            @if (_userWorkouts.Count == 0)
            {
                <div class="empty-picker">No workouts yet. Create one in Training, or search the library below.</div>
            }
            else
            {
                <div class="quick-start-grid">
                    @foreach (var w in _userWorkouts.Take(6))
                    {
                        <button type="button" class="quick-start-card" disabled="@_starting" @onclick="() => StartWorkout(w.Id)">
                            <span class="quick-start-name">@w.Name</span>
                            <span class="quick-start-meta">@w.WorkoutExercises.Count ex · @w.WorkoutExercises.Sum(x => x.Sets) sets</span>
                        </button>
                    }
                </div>
            }
        </section>

        <section class="live-start-card">
            <div class="live-start-head">
                <div>
                    <h2>Find a workout</h2>
                    <p>Search your workouts and the prebuilt library</p>
                </div>
            </div>
            <label class="live-search-field">
                <span>Search workouts</span>
                <input type="search" placeholder="Search by workout name, program, or exercise" @bind="_workoutSearch" @bind:event="oninput" />
            </label>
            <div class="exercise-picker-list">
                @foreach (var item in FilteredStartWorkouts)
                {
                    <button type="button" class="exercise-picker-item" disabled="@_starting" @onclick="() => StartWorkout(item.Workout.Id)">
                        <div>
                            <strong>@item.Workout.Name</strong>
                            <span>@StartWorkoutMeta(item.Workout)</span>
                        </div>
                        <span class="picker-type">@(item.IsPremade ? "Library" : "My Workout")</span>
                    </button>
                }
                @if (!FilteredStartWorkouts.Any())
                {
                    <div class="empty-picker">No workouts match your search.</div>
                }
            </div>
        </section>
        }
    </div>
}
else
{
    var currentExercise = CurrentExerciseState;
    var currentWorkoutExercise = CurrentWorkoutExercise;

    <div class="live-page">
        <div class="live-header">
            <div>
                <span class="live-kicker">Live Session</span>
                <h1>@_session.Workout.Name</h1>
                <div class="live-badges">
                    <span class="lbdg lbdg-prog">@_completedSets / @_totalSets sets</span>
                    <span class="lbdg lbdg-time">@FormatElapsed()</span>
                    <span class="lbdg lbdg-cal">@FormatEnergyValue(_estCalBurned)</span>
                </div>
            </div>
            <div class="live-header-actions">
                <button type="button" class="btn-cancel-workout" @onclick="CancelWorkout">Cancel Workout</button>
                <button type="button" class="btn-ghost btn-add-exercise" @onclick="OpenAddExercise">Add Exercise</button>
                <button type="button" class="btn-action btn-finish-style" @onclick="FinishWorkout">Finish Workout</button>
            </div>
        </div>

        <div class="live-progress-card">
            <div class="live-progress-top">
                <span>Session Progress</span>
                <strong>@ProgressPercent%</strong>
            </div>
            <div class="live-progress">
                <div class="live-bar" style="width:@ProgressPercent%"></div>
            </div>
        </div>

        @if (_resting)
        {
            <div class="rest-overlay">
                <div class="rest-card">
                    <span class="rest-label">Rest</span>
                    <span class="rest-time">@FormatRestTime()</span>
                    <div class="rest-bar-bg"><div class="rest-bar-fill" style="width:@RestPercent()%"></div></div>
                    <button type="button" class="btn-action" @onclick="SkipRest">Skip Rest</button>
                </div>
            </div>
        }

        <div class="live-focus-grid">
            <section class="live-focus-card">
                <div class="focus-eyebrow">Current Exercise</div>
                @if (currentExercise is not null && currentWorkoutExercise is not null)
                {
                    <div class="focus-title-row">
                        <div>
                            <h2>@currentWorkoutExercise.Exercise.Name</h2>
                            <p>@MuscleStr(currentWorkoutExercise.Exercise)</p>
                        </div>
                        <span class="focus-status @ExerciseStatusClass(currentExercise)">@ExerciseStatusText(currentExercise)</span>
                    </div>
                    <div class="focus-metrics">
                        <div>
                            <span>Next Set</span>
                            <strong>@CurrentSetSummary()</strong>
                        </div>
                        <div>
                            <span>Completed</span>
                            <strong>@CompletedSetCount(currentExercise) / @currentExercise.Sets.Count</strong>
                        </div>
                        <div>
                            <span>Rest</span>
                            <strong>@FocusRestText(currentExercise, currentWorkoutExercise)</strong>
                        </div>
                    </div>
                    <div class="focus-actions">
                        <button type="button" class="btn-ghost btn-sm" disabled="@(!CanJumpToPreviousExercise())" @onclick="JumpToPreviousExercise">Previous</button>
                        <button type="button" class="btn-ghost btn-sm" disabled="@(!CanJumpToNextExercise())" @onclick="JumpToNextExercise">Next</button>
                    </div>
                }
                else
                {
                    <h2>Workout Ready</h2>
                    <p>Review your exercises and complete sets as you train.</p>
                }
            </section>

            <section class="live-summary-card">
                <div class="summary-row">
                    <span>Exercises</span>
                    <strong>@CompletedExerciseCount / @_liveState.Exercises.Count</strong>
                </div>
                <div class="summary-row">
                    <span>Sets Left</span>
                    <strong>@RemainingSets</strong>
                </div>
                <div class="summary-row">
                    <span>Energy</span>
                    <strong>@FormatEnergyValue(_estCalBurned)</strong>
                </div>
            </section>
        </div>

        <div class="exercise-nav-strip">
            @for (int ni = 0; ni < _liveState.Exercises.Count && ni < _orderedExercises.Count; ni++)
            {
                var navIdx = ni;
                var navState = _liveState.Exercises[navIdx];
                var navExercise = _orderedExercises[navIdx];

                <button type="button" class="exercise-step @ExerciseStepClass(navIdx)" @onclick="() => JumpToExercise(navIdx)">
                    <span>@(navIdx + 1)</span>
                    <strong>@ShortExerciseName(navExercise.Exercise.Name)</strong>
                    <small>@ExerciseStatusText(navState)</small>
                </button>
            }
        </div>

        <div class="ex-checklist">
            @for (int ei = 0; ei < _liveState.Exercises.Count; ei++)
            {
                var exIdx = ei;
                var les = _liveState.Exercises[exIdx];
                var we = _orderedExercises[exIdx];
                var activeSets = les.Sets.Where(s => !s.IsSkipped).ToList();
                var allDone = les.IsSkipped || (activeSets.Count > 0 && activeSets.All(s => s.IsCompleted)) || (activeSets.Count == 0 && HasCompletedSets(les));
                var anyDone = les.IsSkipped || activeSets.Any(s => s.IsCompleted) || HasCompletedSets(les);
                var statusClass = les.IsSkipped ? "ex-skipped" : (allDone ? "ex-done" : (anyDone ? "ex-partial" : (_liveState.CurrentExerciseIndex == exIdx ? "ex-current" : "")));

                <div class="ex-block @statusClass @ExerciseDragClass(exIdx)"
                     @ondragenter="() => SetExerciseDragOver(exIdx)"
                     @ondragover="() => SetExerciseDragOver(exIdx)"
                     @ondragover:preventDefault="true"
                     @ondrop="() => DropExercise(exIdx)">
                    <div class="ex-header" @onclick="() => ToggleExpand(exIdx)">
                        <div class="ex-hdr-left">
                            <span class="exercise-drag-handle" role="button" tabindex="0" draggable="true" aria-label="Drag exercise to reorder" @onclick:stopPropagation="true" @ondragstart="() => BeginExerciseDrag(exIdx)" @ondragend="() => EndExerciseDrag()">
                                <span></span>
                                <span></span>
                                <span></span>
                            </span>
                            <span class="ex-num">@(exIdx + 1)</span>
                            <div>
                                <span class="ex-hdr-name @(les.IsSkipped ? "text-skipped" : "")">@we.Exercise.Name</span>
                                <span class="ex-hdr-meta">@ExerciseHeaderMeta(les, we)</span>
                            </div>
                        </div>
                        <span class="ex-hdr-status">
                            @if (les.IsSkipped) { <span class="skip-label">Skipped</span> }
                            else if (allDone) { <span class="check-icon"><span class="icon icon-check" aria-label="Completed"></span></span> }
                            else { <span>@CompletedSetCount(les)/@les.Sets.Count</span> }
                        </span>
                    </div>

                    @if (_liveState.ExpandedExerciseIndex == exIdx || _liveState.CurrentExerciseIndex == exIdx)
                    {
                        <div class="ex-body">
                            @if (!les.IsSkipped)
                            {
                                @if (les.SupersetGroup.HasValue)
                                {
                                    <div class="live-superset-panel">
                                        <div>
                                            <span class="live-superset-title">Superset @les.SupersetGroup · Position @Math.Max(1, les.SupersetOrder)</span>
                                            <span class="live-superset-copy">@($"{SupersetRoundCopy(les)} Exercises with fewer sets stop appearing after their last set.")</span>
                                        </div>
                                        <label class="live-superset-rest live-superset-rounds">
                                            <span>Superset rounds</span>
                                            <input type="number" min="1" max="50" step="1" value="@GetLiveSupersetRounds(les)" @onchange="(e) => SetLiveSupersetRounds(exIdx, e)" />
                                        </label>
                                        <label class="live-superset-rest">
                                            <span>Rest after this exercise (seconds)</span>
                                            <input type="number" min="0" step="5" value="@(les.SupersetRestAfterSec ?? 0)" @onchange="(e) => SetLiveSupersetRestAfter(exIdx, e)" />
                                        </label>
                                        <div class="live-superset-buttons">
                                            <button type="button" class="btn-ghost btn-sm" @onclick="() => SetLiveSupersetRestAfter(exIdx, 0)">No Rest Here</button>
                                            <button type="button" class="btn-ghost btn-sm" @onclick="() => RemoveLiveFromSuperset(exIdx)">Remove From Superset</button>
                                        </div>
                                    </div>
                                }
                                else
                                {
                                    <div class="live-superset-quick-row">
                                        <span>Superset</span>
                                        <button type="button" class="btn-ghost btn-sm" disabled="@(exIdx == 0)" @onclick="() => GroupLiveWithPrevious(exIdx)">Group With Previous</button>
                                        <button type="button" class="btn-ghost btn-sm" @onclick="() => StartLiveSupersetAt(exIdx)">Start Superset</button>
                                    </div>
                                }

                                @for (int si = 0; si < les.Sets.Count; si++)
                                {
                                    var setIdx = si;
                                    var setS = les.Sets[setIdx];
                                    var setClass = setS.IsSkipped ? "set-skipped" : (setS.IsCompleted ? "set-done" : "");

                                    <div class="set-row @setClass">
                                        <span class="set-label">Set @(setIdx + 1)</span>
                                        <div class="set-reps-control">
                                            <button type="button" class="reps-btn" disabled="@(setS.IsSkipped || setS.Reps <= 1)" @onclick="() => AdjustReps(exIdx, setIdx, -1)">-</button>
                                            <input type="number" class="reps-input" min="1" step="1" value="@setS.Reps"
                                                   disabled="@setS.IsSkipped"
                                                   aria-label="Reps"
                                                   @onchange="(e) => SetReps(exIdx, setIdx, e)" />
                                            <span class="reps-unit">reps</span>
                                            <button type="button" class="reps-btn" disabled="@setS.IsSkipped" @onclick="() => AdjustReps(exIdx, setIdx, 1)">+</button>
                                        </div>
                                        @if (_showWeightInSets)
                                        {
                                            <div class="set-weight-control">
                                                <input type="number" class="weight-input" placeholder="@WeightUnitLabel" step="0.5" min="0"
                                                       disabled="@setS.IsSkipped"
                                                       value="@DisplayWeight(setS.WeightKg)"
                                                       @onchange="(e) => SetWeight(exIdx, setIdx, e)" />
                                            </div>
                                        }
                                        <div class="set-actions">
                                            @if (setS.IsSkipped)
                                            {
                                                <span class="skip-label set-state-label">Skipped</span>
                                                <button type="button" class="btn-undo-set" @onclick="() => UndoSkipSet(exIdx, setIdx)">Undo Skip</button>
                                            }
                                            else if (setS.IsCompleted)
                                            {
                                                <span class="set-check"><span class="icon icon-check" aria-label="Completed"></span></span>
                                                <button type="button" class="btn-undo-set" @onclick="() => UndoSetCompletion(exIdx, setIdx)">Mark Undone</button>
                                            }
                                            else
                                            {
                                                <button type="button" class="btn-action btn-set-size" @onclick="() => CompleteSet(exIdx, setIdx, we.RestTimeSec ?? _restTimerDefault)">Complete</button>
                                                <button type="button" class="btn-skip-set" @onclick="() => SkipSet(exIdx, setIdx)">Skip Set</button>
                                            }
                                            <button type="button" class="btn-remove-set" disabled="@(les.Sets.Count <= 1)" @onclick="() => RemoveSet(exIdx, setIdx)">Remove</button>
                                        </div>
                                    </div>
                                }

                                <div class="ex-modify-row">
                                    <div class="ex-modify-left">
                                        <button type="button" class="btn-ghost btn-sm" @onclick="() => AddSet(exIdx, we)">@ExtendSetLabel(les)</button>
                                        @if (HasCompletedSets(les))
                                        {
                                            <button type="button" class="btn-ghost btn-sm btn-undo-ex" @onclick="() => UndoExerciseCompletion(exIdx)">Mark Exercise Undone</button>
                                        }
                                        @if (HasSkippedSets(les))
                                        {
                                            <button type="button" class="btn-ghost btn-sm" @onclick="() => RestoreSkippedSets(exIdx)">Restore Skipped Sets</button>
                                        }
                                    </div>
                                    @if (HasRemainingSets(les))
                                    {
                                        <button type="button" class="btn-ghost btn-sm btn-skip-ex" @onclick="() => SkipExercise(exIdx)">@ExerciseSkipLabel(les)</button>
                                    }
                                </div>
                            }
                            else
                            {
                                <div class="ex-modify-row">
                                    <button type="button" class="btn-ghost btn-sm" @onclick="() => UnskipExercise(exIdx)">Undo Skip</button>
                                </div>
                            }
                        </div>
                    }
                </div>
            }
        </div>
    </div>
}

<Modal IsOpen="_showAddExercise" OnClose="CloseAddExercise" Size="md">
    <div class="add-exercise-modal">
        <div class="add-exercise-head">
            <div>
                <span class="modal-kicker">Session Only</span>
                <h2>Add Exercise</h2>
                <p>This exercise will be recorded in this live session without changing the saved workout.</p>
            </div>
        </div>

        <div class="add-exercise-controls">
            <label class="add-field add-search-field">
                <span>Search Exercise</span>
                <input type="search" placeholder="Search by name, muscle, or type" @bind="_exerciseSearch" @bind:event="oninput" />
            </label>
            <label class="add-field">
                <span>Sets</span>
                <input type="number" min="1" max="20" step="1" @bind="_addExerciseSets" />
            </label>
            <label class="add-field">
                <span>Reps</span>
                <input type="number" min="1" max="999" step="1" @bind="_addExerciseReps" />
            </label>
            <label class="add-field">
                <span>Rest</span>
                <input type="number" min="0" max="600" step="5" @bind="_addExerciseRest" />
            </label>
            <label class="add-field add-superset-field">
                <span>Superset</span>
                <select @bind="_addSupersetChoice">
                    <option value="">None</option>
                    @foreach (var option in AvailableSupersetGroups)
                    {
                        <option value="@option">Superset @option</option>
                    }
                    <option value="new">New Superset</option>
                </select>
            </label>
            @if (!string.IsNullOrEmpty(_addSupersetChoice))
            {
                <label class="add-field">
                    <span>Rest after this exercise (seconds)</span>
                    <input type="number" min="0" max="600" step="5" @bind="_addSupersetRestAfter" />
                </label>
            }
        </div>

        @if (!string.IsNullOrWhiteSpace(_addExerciseError))
        {
            <div class="add-error">@_addExerciseError</div>
        }

        <div class="exercise-picker-list">
            @foreach (var exercise in FilteredAddExercises)
            {
                var selected = exercise.Id == _selectedAddExerciseId;
                <button type="button" class="exercise-picker-item @(selected ? "selected" : "")" @onclick="() => SelectAddExercise(exercise.Id)">
                    <div>
                        <strong>@exercise.Name</strong>
                        <span>@PickerExerciseMeta(exercise)</span>
                    </div>
                    <span class="picker-type">@(exercise.ExerciseType ?? exercise.MovementType.ToString())</span>
                </button>
            }
            @if (!FilteredAddExercises.Any())
            {
                <div class="empty-picker">No exercises match your search.</div>
            }
        </div>

        <div class="mf-actions add-actions">
            <button type="button" class="btn-ghost" @onclick="CloseAddExercise">Cancel</button>
            <button type="button" class="btn-action" disabled="@(_selectedAddExerciseId is null)" @onclick="AddSelectedExerciseToSession">Add To Session</button>
        </div>
    </div>
</Modal>

<Modal IsOpen="_showFinish" OnClose="() => _showFinish = false" Size="sm">
    <div class="finish-modal">
        <h2>@_finishTitle</h2>
        @if (_finishStatus is not null)
        {
            <div class="finish-status-row">
                <span class="finish-status-tag finish-status-@_finishStatus.Value.ToString().ToLower()">@_finishStatus</span>
            </div>
        }
        <div class="finish-stats">
            <div class="fs-item"><span class="fs-val">@_completedSets</span><span class="fs-label">Sets</span></div>
            <div class="fs-item"><span class="fs-val">@FormatElapsed()</span><span class="fs-label">Duration</span></div>
            <div class="fs-item"><span class="fs-val">@FormatEnergyValue(_estCalBurned)</span><span class="fs-label">Energy</span></div>
        </div>
        <div class="mf-actions">
            <button type="button" class="btn-ghost" @onclick="() => _showFinish = false">Continue Session</button>
            <button type="button" class="btn-action" @onclick="ConfirmFinish">@(_completedSets > 0 ? "Save & Exit" : "Discard & Exit")</button>
        </div>
    </div>
</Modal>

<Modal IsOpen="_pendingSkipExIdx is not null" OnClose="CancelSkip" Size="sm">
    <div class="finish-modal">
        <h2>@(_pendingSkipIsExercise ? "Skip Exercise?" : "Skip Set?")</h2>
        <p class="cancel-desc">@(_pendingSkipIsExercise ? "This exercise will be marked as skipped." : "This set will be marked as skipped.")</p>
        <div class="mf-actions">
            <button type="button" class="btn-ghost" @onclick="CancelSkip">Keep Going</button>
            <button type="button" class="btn-action btn-finish-style" @onclick="ConfirmSkip">@(_pendingSkipIsExercise ? "Skip Exercise" : "Skip Set")</button>
        </div>
    </div>
</Modal>

<Modal IsOpen="_showCancelConfirm" OnClose="() => _showCancelConfirm = false" Size="sm">
    <div class="finish-modal">
        <h2>Cancel Workout?</h2>
        <p class="cancel-desc">@(_completedSets > 0 ? $"You have {_completedSets} completed sets. This will be saved as a partial workout." : "No sets completed. This workout will not be recorded.")</p>
        <div class="mf-actions">
            <button type="button" class="btn-ghost" @onclick="() => _showCancelConfirm = false">Continue Training</button>
            <button type="button" class="btn-action btn-finish-style" @onclick="ConfirmCancel">@(_completedSets > 0 ? "Stop & Save" : "Discard")</button>
        </div>
    </div>
</Modal>

@code {
    private bool _isLoading = true;
    private int _userId;
    private User? _user;
    private string _weightUnit = "kg";
    private string _energyUnit = "kcal";
    private int _restTimerDefault = 60;
    private string _liveMode = "workout";
    private bool _autoStartRest = true;
    private bool _showWeightInSets = true;
    private bool _confirmBeforeSkip = true;
    private int? _pendingSkipExIdx;
    private int? _pendingSkipSetIdx;
    private bool _pendingSkipIsExercise;
    private WorkoutSchedule? _session;
    private List<WorkoutExercise> _orderedExercises = new();
    private List<Exercise> _exerciseLibrary = new();

    private LiveSessionState _liveState = new();
    private int _completedSets;
    private int _totalSets;
    private decimal _estCalBurned;
    private DateTime _startTime;

    private bool _resting;
    private int _restTotal;
    private int _restRemaining;
    private System.Threading.Timer? _restTimer;
    private System.Threading.Timer? _elapsedTimer;

    private bool _showFinish;
    private bool _showCancelConfirm;
    private bool _showAddExercise;
    private int? _dragExerciseIndex;
    private int? _dragOverExerciseIndex;
    private string _exerciseSearch = "";
    private int? _selectedAddExerciseId;
    private int _addExerciseSets = 3;
    private int _addExerciseReps = 10;
    private int _addExerciseRest = 60;
    private string _addSupersetChoice = "";
    private int _addSupersetRestAfter;
    private string _addExerciseError = "";
    private string _finishTitle = "";
    private WorkoutLogStatus? _finishStatus;

    private List<Workout> _userWorkouts = new();
    private List<Workout> _premadeWorkouts = new();
    private string _workoutSearch = "";
    private bool _starting;

    private IEnumerable<(Workout Workout, bool IsPremade)> AllStartWorkouts
    {
        get
        {
            var seen = new HashSet<int>();
            foreach (var w in _userWorkouts)
                if (seen.Add(w.Id)) yield return (w, false);
            foreach (var w in _premadeWorkouts)
                if (seen.Add(w.Id)) yield return (w, true);
        }
    }

    private IEnumerable<(Workout Workout, bool IsPremade)> FilteredStartWorkouts => AllStartWorkouts
        .Where(x => string.IsNullOrWhiteSpace(_workoutSearch)
            || x.Workout.Name.Contains(_workoutSearch, StringComparison.OrdinalIgnoreCase)
            || (x.Workout.Program?.Name?.Contains(_workoutSearch, StringComparison.OrdinalIgnoreCase) ?? false)
            || x.Workout.WorkoutExercises.Any(we => we.Exercise != null && we.Exercise.Name.Contains(_workoutSearch, StringComparison.OrdinalIgnoreCase)))
        .Take(40);

    private static string StartWorkoutMeta(Workout workout)
    {
        var summary = $"{workout.WorkoutExercises.Count} ex · {workout.WorkoutExercises.Sum(x => x.Sets)} sets";
        var program = workout.Program?.Name;
        return string.IsNullOrWhiteSpace(program) ? summary : $"{summary} · {program}";
    }

    private IEnumerable<Exercise> FilteredAddExercises => _exerciseLibrary
        .Where(e => string.IsNullOrWhiteSpace(_exerciseSearch)
            || e.Name.Contains(_exerciseSearch, StringComparison.OrdinalIgnoreCase)
            || (e.ExerciseType?.Contains(_exerciseSearch, StringComparison.OrdinalIgnoreCase) ?? false)
            || e.MovementType.ToString().Contains(_exerciseSearch, StringComparison.OrdinalIgnoreCase)
            || e.ExerciseMuscleGroups.Any(m => m.MuscleGroup.Name.Contains(_exerciseSearch, StringComparison.OrdinalIgnoreCase)))
        .Take(40);

    private int ProgressPercent => _totalSets > 0 ? Math.Clamp((int)Math.Round((double)_completedSets / _totalSets * 100), 0, 100) : 0;
    private int RemainingSets => Math.Max(_totalSets - _completedSets, 0);
    private int CompletedExerciseCount => _liveState.Exercises.Count(IsExerciseDone);
    private LiveExerciseState? CurrentExerciseState => _liveState.CurrentExerciseIndex >= 0 && _liveState.CurrentExerciseIndex < _liveState.Exercises.Count ? _liveState.Exercises[_liveState.CurrentExerciseIndex] : null;
    private WorkoutExercise? CurrentWorkoutExercise => _liveState.CurrentExerciseIndex >= 0 && _liveState.CurrentExerciseIndex < _orderedExercises.Count ? _orderedExercises[_liveState.CurrentExerciseIndex] : null;
    private IEnumerable<int> AvailableSupersetGroups => _liveState.Exercises.Where(e => e.SupersetGroup.HasValue).Select(e => e.SupersetGroup!.Value).Distinct().OrderBy(x => x);

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        var state = await AuthState.GetAuthenticationStateAsync();
        if (state.User.Identity is not { IsAuthenticated: true }) { try { Navigation.NavigateTo("/login", forceLoad: true); } catch { } return; }
        _userId = int.Parse(state.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)!.Value);
        _user = await WorkoutService.GetUserAsync(_userId);
        var settings = await SettingsSvc.GetSettingsAsync(_userId);
        _weightUnit = settings.WeightUnit;
        _energyUnit = settings.EnergyUnit;
        _restTimerDefault = settings.RestTimerDefault;
        _autoStartRest = settings.AutoStartRestTimer;
        _showWeightInSets = settings.ShowWeightInSets;
        _confirmBeforeSkip = settings.ConfirmBeforeSkip;
        _session = await DashService.GetActiveSessionAsync(_userId);
        _exerciseLibrary = await WorkoutService.GetExerciseLibraryAsync();

        if (_session is not null)
            BeginSessionTracking();
        else
            await LoadStartOptions();

        _isLoading = false;
        StateHasChanged();
    }

    private void BeginSessionTracking()
    {
        _startTime = _session!.StartedAt ?? DateTime.UtcNow;
        _orderedExercises = _session.Workout.WorkoutExercises.OrderBy(x => x.SortOrder).ToList();
        LoadOrInitState();
        _elapsedTimer?.Dispose();
        _elapsedTimer = new System.Threading.Timer(async _ =>
        {
            await InvokeAsync(StateHasChanged);
        }, null, 0, 1000);
    }

    private async Task LoadStartOptions()
    {
        _userWorkouts = await WorkoutService.GetUserWorkoutsAsync(_userId);
        _premadeWorkouts = await WorkoutService.GetPremadeWorkoutsAsync();
    }

    private async Task StartWorkout(int workoutId)
    {
        if (_starting) return;
        _starting = true;
        await DashService.QuickStartWorkoutAsync(_userId, workoutId);
        _session = await DashService.GetActiveSessionAsync(_userId);
        if (_session is not null)
            BeginSessionTracking();
        _starting = false;
        StateHasChanged();
    }

    private void LoadOrInitState()
    {
        var stateLoaded = false;

        if (!string.IsNullOrEmpty(_session!.LiveSessionJson))
        {
            try
            {
                _liveState = JsonSerializer.Deserialize<LiveSessionState>(_session.LiveSessionJson) ?? new();
                stateLoaded = _liveState.Exercises.Count > 0;
            }
            catch
            {
                _liveState = new();
            }
        }

        if (!stateLoaded)
            InitializeStateFromWorkout();
        else if (!RebuildOrderedExercisesFromState())
            InitializeStateFromWorkout();

        NormalizeLiveSupersetOrders();

        if (_liveState.CurrentExerciseIndex < 0 || _liveState.CurrentExerciseIndex >= _liveState.Exercises.Count)
            _liveState.CurrentExerciseIndex = 0;

        if (_liveState.ExpandedExerciseIndex < -1 || _liveState.ExpandedExerciseIndex >= _liveState.Exercises.Count)
            _liveState.ExpandedExerciseIndex = _liveState.CurrentExerciseIndex;

        RecalcTotals();
    }

    private void InitializeStateFromWorkout()
    {
        _liveState = new LiveSessionState();
        foreach (var we in _orderedExercises)
        {
            var les = new LiveExerciseState
            {
                ExerciseId = we.ExerciseId,
                OriginalSets = we.Sets,
                OriginalReps = we.Reps,
                RestTimeSec = we.RestTimeSec,
                SupersetGroup = we.SupersetGroup,
                SupersetOrder = we.SupersetOrder,
                SupersetRestAfterSec = we.SupersetRestAfterSec,
                SupersetRounds = Math.Max(1, we.SupersetRounds),
                OriginalSupersetGroup = we.SupersetGroup,
                OriginalSupersetOrder = we.SupersetOrder,
                OriginalSupersetRestAfterSec = we.SupersetRestAfterSec,
                OriginalSupersetRounds = Math.Max(1, we.SupersetRounds)
            };
            for (int i = 0; i < we.Sets; i++)
                les.Sets.Add(new LiveSetState { Reps = we.Reps });
            _liveState.Exercises.Add(les);
        }
        _liveState.ExpandedExerciseIndex = 0;
    }

    private bool RebuildOrderedExercisesFromState()
    {
        if (_session is null) return false;

        var baseExercises = _orderedExercises.ToList();
        var usedBaseIndexes = new HashSet<int>();
        var rebuilt = new List<WorkoutExercise>();

        for (int stateIndex = 0; stateIndex < _liveState.Exercises.Count; stateIndex++)
        {
            var stateExercise = _liveState.Exercises[stateIndex];
            var baseIndex = -1;

            for (int i = 0; i < baseExercises.Count; i++)
            {
                if (usedBaseIndexes.Contains(i)) continue;
                if (baseExercises[i].ExerciseId != stateExercise.ExerciseId) continue;
                baseIndex = i;
                break;
            }

            if (baseIndex >= 0 && !stateExercise.IsSessionOnly)
            {
                usedBaseIndexes.Add(baseIndex);
                rebuilt.Add(baseExercises[baseIndex]);
                continue;
            }

            var exercise = _exerciseLibrary.FirstOrDefault(e => e.Id == stateExercise.ExerciseId);
            if (exercise is null) return false;

            stateExercise.IsSessionOnly = true;
            rebuilt.Add(CreateSessionOnlyWorkoutExercise(exercise, stateExercise, stateIndex));
        }

        _orderedExercises = rebuilt;
        return _orderedExercises.Count == _liveState.Exercises.Count;
    }

    private WorkoutExercise CreateSessionOnlyWorkoutExercise(Exercise exercise, LiveExerciseState state, int sortOrder)
    {
        var sets = Math.Clamp(state.OriginalSets > 0 ? state.OriginalSets : state.Sets.Count, 1, 20);
        var reps = Math.Clamp(state.OriginalReps > 0 ? state.OriginalReps : state.Sets.FirstOrDefault()?.Reps ?? 10, 1, 999);

        return new WorkoutExercise
        {
            WorkoutId = _session?.WorkoutId ?? 0,
            Workout = _session!.Workout,
            ExerciseId = exercise.Id,
            Exercise = exercise,
            Sets = sets,
            Reps = reps,
            SortOrder = sortOrder,
            RestTimeSec = state.RestTimeSec ?? _restTimerDefault,
            SupersetGroup = state.SupersetGroup,
            SupersetOrder = state.SupersetOrder,
            SupersetRestAfterSec = state.SupersetRestAfterSec,
            SupersetRounds = Math.Max(1, state.SupersetRounds)
        };
    }

    private void RecalcTotals()
    {
        _totalSets = _liveState.Exercises.Where(e => !e.IsSkipped).Sum(e => e.Sets.Count(s => !s.IsSkipped));
        _completedSets = _liveState.Exercises.Where(e => !e.IsSkipped).Sum(e => e.Sets.Count(s => s.IsCompleted && !s.IsSkipped));
        RecalcCalories();
    }

    private static bool HasCompletedSets(LiveExerciseState exercise) => exercise.Sets.Any(s => s.IsCompleted && !s.IsSkipped);

    private static bool HasSkippedSets(LiveExerciseState exercise) => exercise.Sets.Any(s => s.IsSkipped);

    private static bool HasRemainingSets(LiveExerciseState exercise) => !exercise.IsSkipped && exercise.Sets.Any(s => !s.IsCompleted && !s.IsSkipped);

    private static int CompletedSetCount(LiveExerciseState exercise) => exercise.Sets.Count(s => s.IsCompleted && !s.IsSkipped);

    private static bool IsExerciseDone(LiveExerciseState exercise)
    {
        if (exercise.IsSkipped) return true;
        var activeSets = exercise.Sets.Where(s => !s.IsSkipped).ToList();
        return activeSets.Count > 0 && activeSets.All(s => s.IsCompleted);
    }

    private static string ExerciseStatusText(LiveExerciseState exercise)
    {
        if (exercise.IsSkipped) return "Skipped";
        if (IsExerciseDone(exercise)) return "Done";
        if (HasCompletedSets(exercise)) return "In Progress";
        if (HasSkippedSets(exercise)) return "Adjusted";
        return "Pending";
    }

    private static string ExerciseStatusClass(LiveExerciseState exercise)
    {
        if (exercise.IsSkipped) return "status-skipped";
        if (IsExerciseDone(exercise)) return "status-done";
        if (HasCompletedSets(exercise)) return "status-active";
        return "status-pending";
    }

    private string ExerciseStepClass(int index)
    {
        if (index < 0 || index >= _liveState.Exercises.Count) return string.Empty;
        var exercise = _liveState.Exercises[index];
        var classes = ExerciseStatusClass(exercise);
        if (_liveState.CurrentExerciseIndex == index) classes += " is-current";
        return classes;
    }

    private static string ExerciseSkipLabel(LiveExerciseState exercise) => HasCompletedSets(exercise) ? "Skip Rest of Exercise" : "Skip Exercise";

    private static string ExtendSetLabel(LiveExerciseState exercise) => IsExerciseDone(exercise) ? "Extend Exercise" : "Add Set";

    private static string ShortExerciseName(string name)
    {
        const int maxLength = 18;
        return name.Length <= maxLength ? name : $"{name[..maxLength]}...";
    }

    private static string ExerciseSetSummary(LiveExerciseState exercise, WorkoutExercise workoutExercise)
    {
        var completed = CompletedSetCount(exercise);
        var active = exercise.Sets.Count(s => !s.IsSkipped);
        var skipped = exercise.Sets.Count(s => s.IsSkipped);
        var reps = exercise.Sets.FirstOrDefault(s => !s.IsSkipped)?.Reps ?? exercise.Sets.FirstOrDefault()?.Reps ?? workoutExercise.Reps;
        return skipped > 0 ? $"{completed}/{exercise.Sets.Count} sets · {skipped} skipped · {reps} reps" : $"{active} x {reps}";
    }

    private string CurrentSetSummary()
    {
        var exercise = CurrentExerciseState;
        if (exercise is null) return "Ready";
        var nextIndex = exercise.Sets.FindIndex(s => !s.IsCompleted && !s.IsSkipped);
        if (nextIndex < 0) return "Complete";
        if (exercise.SupersetGroup.HasValue) return $"Round {nextIndex + 1} of {GetLiveSupersetRounds(exercise)} · set {nextIndex + 1} of {exercise.Sets.Count}";
        return $"Set {nextIndex + 1} of {exercise.Sets.Count}";
    }

    private bool CanJumpToPreviousExercise() => _liveState.CurrentExerciseIndex > 0;

    private bool CanJumpToNextExercise() => _liveState.CurrentExerciseIndex < _liveState.Exercises.Count - 1;

    private void JumpToPreviousExercise()
    {
        if (CanJumpToPreviousExercise()) JumpToExercise(_liveState.CurrentExerciseIndex - 1);
    }

    private void JumpToNextExercise()
    {
        if (CanJumpToNextExercise()) JumpToExercise(_liveState.CurrentExerciseIndex + 1);
    }

    private void JumpToExercise(int index)
    {
        if (index < 0 || index >= _liveState.Exercises.Count) return;
        _liveState.CurrentExerciseIndex = index;
        _liveState.ExpandedExerciseIndex = index;
    }

    private void BeginExerciseDrag(int index)
    {
        if (index < 0 || index >= _liveState.Exercises.Count) return;
        _dragExerciseIndex = index;
        _dragOverExerciseIndex = index;
    }

    private void SetExerciseDragOver(int index)
    {
        if (_dragExerciseIndex is null || index < 0 || index >= _liveState.Exercises.Count) return;
        _dragOverExerciseIndex = index;
    }

    private async Task DropExercise(int targetIndex)
    {
        if (_dragExerciseIndex is null || targetIndex < 0 || targetIndex >= _liveState.Exercises.Count)
        {
            EndExerciseDrag();
            return;
        }

        var sourceIndex = _dragExerciseIndex.Value;
        if (sourceIndex != targetIndex)
        {
            MoveExercise(sourceIndex, targetIndex);
            RecalcTotals();
            await PersistState();
        }

        EndExerciseDrag();
        StateHasChanged();
    }

    private void EndExerciseDrag()
    {
        _dragExerciseIndex = null;
        _dragOverExerciseIndex = null;
    }

    private string ExerciseDragClass(int index)
    {
        if (_dragExerciseIndex == index) return "ex-dragging";
        if (_dragOverExerciseIndex == index) return "ex-drag-over";
        return string.Empty;
    }

    private void MoveExercise(int sourceIndex, int targetIndex)
    {
        if (sourceIndex < 0 || sourceIndex >= _liveState.Exercises.Count || targetIndex < 0 || targetIndex >= _liveState.Exercises.Count) return;

        var currentExercise = _liveState.CurrentExerciseIndex >= 0 && _liveState.CurrentExerciseIndex < _liveState.Exercises.Count ? _liveState.Exercises[_liveState.CurrentExerciseIndex] : null;
        var expandedExercise = _liveState.ExpandedExerciseIndex >= 0 && _liveState.ExpandedExerciseIndex < _liveState.Exercises.Count ? _liveState.Exercises[_liveState.ExpandedExerciseIndex] : null;
        var liveExercise = _liveState.Exercises[sourceIndex];
        var orderedExercise = _orderedExercises[sourceIndex];

        _liveState.Exercises.RemoveAt(sourceIndex);
        _orderedExercises.RemoveAt(sourceIndex);

        if (targetIndex > sourceIndex) targetIndex--;

        _liveState.Exercises.Insert(targetIndex, liveExercise);
        _orderedExercises.Insert(targetIndex, orderedExercise);

        NormalizeLiveSupersetOrders();

        _liveState.CurrentExerciseIndex = currentExercise is null ? Math.Clamp(targetIndex, 0, _liveState.Exercises.Count - 1) : _liveState.Exercises.IndexOf(currentExercise);
        _liveState.ExpandedExerciseIndex = expandedExercise is null ? _liveState.CurrentExerciseIndex : _liveState.Exercises.IndexOf(expandedExercise);

        if (_liveState.CurrentExerciseIndex < 0) _liveState.CurrentExerciseIndex = Math.Clamp(targetIndex, 0, _liveState.Exercises.Count - 1);
        if (_liveState.ExpandedExerciseIndex < -1) _liveState.ExpandedExerciseIndex = _liveState.CurrentExerciseIndex;
    }

    private void RecalcCalories()
    {
        if (_session is null || _user is null) return;
        decimal weight = _user.WeightKg ?? 70m;
        decimal total = 0;
        for (int i = 0; i < _orderedExercises.Count && i < _liveState.Exercises.Count; i++)
        {
            var les = _liveState.Exercises[i];
            if (les.IsSkipped) continue;
            var doneSets = les.Sets.Where(s => s.IsCompleted && !s.IsSkipped).ToList();
            if (doneSets.Count > 0)
            {
                int avgReps = (int)Math.Round(doneSets.Average(s => s.Reps));
                total += WorkoutService.EstimateExerciseCalories(_orderedExercises[i].Exercise, doneSets.Count, avgReps, GetEstimateRest(_orderedExercises[i], les), weight);
            }
        }
        _estCalBurned = Math.Round(total, 0);
    }

    private async Task PersistState()
    {
        if (_session is null) return;
        var json = JsonSerializer.Serialize(_liveState);
        await DashService.SaveLiveSessionStateAsync(_session.Id, _userId, json);
    }

