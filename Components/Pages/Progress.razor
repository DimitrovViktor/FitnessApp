@page "/progress"
@inject ProgressService ProgressSvc
@inject SettingsService SettingsSvc
@inject CustomAuthStateProvider AuthState
@inject NavigationManager Navigation
@using FitnessApp.Models.Enums

<PageTitle>Progress - Fitness App</PageTitle>

@if (_isLoading)
{
    <div class="loading-state"><p>Loading...</p></div>
}
else
{
    <div class="progress-page">
        <div class="page-header">
            <div>
                <h1>Progress</h1>
                <p class="page-sub">Track body changes, training performance, and diet consistency in one place</p>
            </div>
        </div>

        <div class="progress-section-grid">
            @foreach (var section in GetProgressSections())
            {
                <button type="button" class="progress-section-card @(_activeSection == section.Key ? "active" : "")" @onclick="() => _activeSection = section.Key">
                    <span class="progress-section-title">@section.Title</span>
                    <span class="progress-section-copy">@section.Description</span>
                    <span class="progress-section-count">@section.Meta</span>
                </button>
            }
        </div>

        <div class="stats-grid">
            @foreach (var stat in GetActiveStats())
            {
                <div class="stat-card">
                    <span class="stat-label">@stat.Label</span>
                    <span class="stat-val">@stat.Value</span>
                    <span class="stat-sub">@stat.Sub</span>
                </div>
            }
        </div>

        @if (_activeSection == SectionBody)
        {
            <div class="two-col progress-body-grid">
                <div class="panel">
                    <div class="panel-header">
                        <span class="panel-title">Body Measurements</span>
                        <div class="panel-header-btns">
                            <button type="button" class="btn-log" @onclick="OpenHistory">History</button>
                            <button type="button" class="btn-log" @onclick="() => _showLogModal = true">+ Log</button>
                        </div>
                    </div>
                    <div class="measurements-grid">
                        @foreach (var item in GetMeasurementDisplay())
                        {
                            <div class="meas-card">
                                <span class="meas-label">@item.Label</span>
                                <span class="meas-value">@item.Value</span>
                                <span class="meas-change @(item.Trend == "down" ? "meas-down" : "meas-up")">@GetTrendLabel(item.Trend, item.Change)</span>
                            </div>
                        }
                    </div>
                </div>

                <div class="panel">
                    <div class="panel-header">
                        <span class="panel-title">Measurement Trend</span>
                        <span class="panel-hint">Recent logs</span>
                    </div>
                    @if (_chartMeasurements.Count >= 2)
                    {
                        <div class="chart-container">
                            <svg viewBox="0 0 560 220" class="chart-svg">
                                @{ var mPad = new ChartPad(16, 10, 10, 28); }
                                @for (int gi = 0; gi <= 4; gi++)
                                {
                                    var gy = mPad.Top + (double)gi / 4 * (220 - mPad.Top - mPad.Bottom);
                                    <line x1="@mPad.Left" y1="@Math.Round(gy,1)" x2="@(560 - mPad.Right)" y2="@Math.Round(gy,1)" stroke="var(--border-faint)" stroke-width="1" />
                                }
                                @foreach (var series in _measSeries)
                                {
                                    if (_hiddenMeasSeries.Contains(series.Key)) continue;
                                    var points = GetMeasPoints(series.Key, 560, 220, mPad);
                                    if (points.Count < 2) continue;
                                    <polyline points="@string.Join(" ", points.Select(p => $"{p.X},{p.Y}"))" fill="none" stroke="@series.Color" stroke-width="2" stroke-linejoin="round" opacity="0.8" />
                                }
                                @foreach (var series in _measSeries)
                                {
                                    if (_hiddenMeasSeries.Contains(series.Key)) continue;
                                    var points = GetMeasPoints(series.Key, 560, 220, mPad);
                                    @foreach (var pt in points)
                                    {
                                        <circle cx="@pt.X" cy="@pt.Y" r="4.5" fill="@series.Color" stroke="var(--bg)" stroke-width="2" class="chart-point">
                                            <title>@pt.Label</title>
                                        </circle>
                                    }
                                }
                                @{ var mXLabels = GetMeasXLabels(560, mPad); }
                                @foreach (var xl in mXLabels)
                                {
                                    @((MarkupString)$"<text x='{xl.X}' y='{220 - 6}' text-anchor='middle' fill='var(--t3)' font-size='10' font-family='Inter,sans-serif'>{xl.Label}</text>")
                                }
                            </svg>
                        </div>
                        <div class="chart-legend">
                            @foreach (var series in _measSeries)
                            {
                                var key = series.Key;
                                var hidden = _hiddenMeasSeries.Contains(key);
                                <button type="button" class="legend-btn @(hidden ? "legend-hidden" : "")" @onclick="() => ToggleMeasSeries(key)">
                                    <span class="legend-swatch" style="background:@(hidden ? "var(--t3)" : series.Color)"></span>
                                    @series.Label
                                </button>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="empty-text">Log at least two measurements to see body trends.</div>
                    }
                </div>
            </div>
        }
        else if (_activeSection == SectionTraining)
        {
            <div class="two-col equal-progress-row training-coverage-row">
                <div class="panel equal-panel">
                    <div class="panel-header">
                        <span class="panel-title">Weekly Muscle Coverage</span>
                        <span class="panel-hint">This week</span>
                    </div>
                    @if (HasMuscleCoverageData)
                    {
                        <div class="legend-row">
                            @foreach (var legend in GetMuscleLegend())
                            {
                                <div class="legend-item">
                                    <span class="legend-dot" style="background:@legend.Color"></span>
                                    <span class="legend-text">@legend.Label</span>
                                </div>
                            }
                        </div>
                        <div class="muscle-list">
                            @foreach (var m in _muscleCoverage)
                            {
                                var color = GetMuscleColor(m.Status);
                                <div class="muscle-row">
                                    <div class="muscle-labels">
                                        <span class="muscle-name">@m.Name</span>
                                        <div class="muscle-right">
                                            <span class="muscle-sets">@m.Sets/@m.Target sets</span>
                                            <span class="muscle-status" style="color:@color">@GetMuscleStatusLabel(m.Status)</span>
                                        </div>
                                    </div>
                                    <div class="muscle-bar-bg">
                                        <div class="muscle-bar-fill" style="width:@(m.Target > 0 ? Math.Min((int)((double)m.Sets / m.Target * 100), 100) : 0)%;background:@color"></div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="empty-text empty-panel-message">No completed exercise sets for this week. Complete logged sets to populate weekly muscle coverage.</div>
                    }
                </div>

                <div class="panel equal-panel">
                    <div class="panel-header">
                        <span class="panel-title">Weekly Energy Burn</span>
                        <span class="panel-hint">Last @_weeklyCalories.Count weeks</span>
                    </div>
                    @if (HasWeeklyEnergyLogs)
                    {
                        <div class="cal-chart">
                            @{ var maxKcal = _weeklyCalories.Count > 0 ? Math.Max(_weeklyCalories.Max(w => w.Kcal), 1) : 1; }
                            @foreach (var w in _weeklyCalories)
                            {
                                var h = w.HasLogs ? (int)((double)w.Kcal / maxKcal * 100) : 0;
                                var isLatest = w == _weeklyCalories.LastOrDefault();
                                <div class="cal-bar-col">
                                    <div class="cal-bar-track">
                                        <span class="cal-bar-val @(isLatest ? "cal-bar-latest" : "")">@(w.HasLogs ? FormatEnergyValue(w.Kcal) : "No log")</span>
                                        <div class="cal-bar @(isLatest ? "cal-bar-active" : "")" style="flex-basis:@(h)%"></div>
                                    </div>
                                    <span class="cal-bar-label">@w.Label</span>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="empty-text empty-panel-message">No workout energy logs yet. Complete workouts to see weekly energy burn.</div>
                    }
                </div>
            </div>

            <div class="two-col equal-progress-row training-records-row">
                <div class="panel equal-panel progress-pr-panel">
                    <div class="panel-title" style="margin-bottom:16px">Personal Records</div>
                    <div class="pr-list">
                        @foreach (var pr in _personalRecords)
                        {
                            <div class="pr-row">
                                <div>
                                    <span class="pr-name">@GetExerciseName(pr)</span>
                                    <span class="pr-date">@pr.Date.ToString("MMM d")</span>
                                </div>
                                <div class="pr-right">
                                    <span class="pr-weight">@FormatWeightValue(pr.WeightKg)</span>
                                    <span class="pr-reps">@pr.Reps reps</span>
                                </div>
                            </div>
                        }
                        @if (_personalRecords.Count == 0)
                        {
                            <div class="empty-text">No personal records yet. Complete workouts with tracked weight to start recording PRs.</div>
                        }
                    </div>
                    @if (HasPrChartData)
                    {
                        <div class="chart-divider"></div>
                        <div class="chart-title">PR Progression Over Time</div>
                        <div class="chart-container">
                            <svg viewBox="0 0 560 220" class="chart-svg">
                                @{ var prPad = new ChartPad(44, 10, 10, 28); }
                                @foreach (var ex in _prChartExercises)
                                {
                                    if (_hiddenPrSeries.Contains(ex.Name)) continue;
                                    var points = GetPrPoints(ex.Name, 560, 220, prPad);
                                    if (points.Count < 2) continue;
                                    <polyline points="@string.Join(" ", points.Select(p => $"{p.X},{p.Y}"))" fill="none" stroke="@ex.Color" stroke-width="2" stroke-linejoin="round" opacity="0.8" />
                                }
                                @foreach (var ex in _prChartExercises)
                                {
                                    if (_hiddenPrSeries.Contains(ex.Name)) continue;
                                    var points = GetPrPoints(ex.Name, 560, 220, prPad);
                                    @foreach (var pt in points)
                                    {
                                        <circle cx="@pt.X" cy="@pt.Y" r="4.5" fill="@ex.Color" stroke="var(--bg)" stroke-width="2" class="chart-point">
                                            <title>@pt.Label</title>
                                        </circle>
                                    }
                                }
                                @{ var prYLabels = GetPrYLabels(220, prPad); }
                                @foreach (var yl in prYLabels)
                                {
                                    @((MarkupString)$"<text x='{prPad.Left - 6}' y='{yl.Y + 4}' text-anchor='end' fill='var(--t3)' font-size='10' font-family='Inter,sans-serif'>{yl.Label}</text>")
                                    <line x1="@prPad.Left" y1="@yl.Y" x2="@(560 - prPad.Right)" y2="@yl.Y" stroke="var(--border-faint)" stroke-width="1" />
                                }
                                @{ var prXLabels = GetPrXLabels(560, prPad); }
                                @foreach (var xl in prXLabels)
                                {
                                    @((MarkupString)$"<text x='{xl.X}' y='{220 - 6}' text-anchor='middle' fill='var(--t3)' font-size='10' font-family='Inter,sans-serif'>{xl.Label}</text>")
                                }
                            </svg>
                        </div>
                        <div class="chart-legend">
                            @foreach (var ex in _prChartExercises)
                            {
                                var name = ex.Name;
                                var hidden = _hiddenPrSeries.Contains(name);
                                <button type="button" class="legend-btn @(hidden ? "legend-hidden" : "")" @onclick="() => TogglePrSeries(name)">
                                    <span class="legend-swatch" style="background:@(hidden ? "var(--t3)" : ex.Color)"></span>
                                    @name
                                </button>
                            }
                        </div>
                    }
                    else if (_personalRecords.Count > 0)
                    {
                        <div class="chart-divider"></div>
                        <div class="empty-text">Log at least two personal records for the same exercise to see a progression chart.</div>
                    }
                </div>

                <div class="panel equal-panel progress-consistency-panel">
                    <div class="panel-header">
                        <span class="panel-title">Consistency</span>
                            <span class="panel-hint">Last 30 days</span>
                        </div>
                        <div class="consistency-grid">
                            @foreach (var day in _consistency)
                            {
                                <div class="c-cell @(day.IsActive ? "c-active" : "")" title="@day.Date.ToString("ddd, d MMM yyyy") - @(day.IsActive ? "Active" : "Rest")">
                                    <span class="c-tooltip">@day.Date.ToString("d MMM")<br />@(day.IsActive ? "Active" : "Rest")</span>
                                </div>
                            }
                        </div>
                        <div class="consistency-stats">
                            <div class="cs-item">
                                <span class="cs-label">Current streak</span>
                                <span class="cs-val cs-success">@_streak days</span>
                            </div>
                            <div class="cs-item">
                                <span class="cs-label">Best streak</span>
                                <span class="cs-val cs-accent">@_bestStreak days</span>
                            </div>
                            <div class="cs-item">
                                <span class="cs-label">Active days</span>
                                <span class="cs-val">@ActiveDaysText(_consistency)</span>
                            </div>
                        </div>
                </div>
            </div>

            @if (_suggestions.Count > 0)
            {
                <div class="panel progress-suggestions-panel">
                    <div class="panel-title" style="margin-bottom:16px">Progressive Overload Suggestions</div>
                    <div class="suggestions-grid compact">
                        @foreach (var s in _suggestions)
                        {
                            <div class="sug-card">
                                <span class="sug-type">@s.Type</span>
                                <span class="sug-name">@s.ExerciseName</span>
                                <span class="sug-action">Suggestion: @s.Suggestion</span>
                                <span class="sug-reason">@s.Reason</span>
                            </div>
                        }
                    </div>
                </div>
            }
        }
        else if (_activeSection == SectionDiet)
        {
            <div class="two-col equal-progress-row diet-nutrition-row">
                <div class="panel equal-panel today-nutrition-panel">
                    <div class="panel-header">
                        <span class="panel-title">Today's Nutrition</span>
                        <span class="panel-hint">Logged foods</span>
                    </div>
                    <div class="macro-grid">
                        <div class="macro-card">
                            <span class="macro-label">Calories</span>
                            <span class="macro-value">@FormatCalories(_dietSummary.CaloriesToday)</span>
                        </div>
                        <div class="macro-card">
                            <span class="macro-label">Protein</span>
                            <span class="macro-value">@FormatMacro(_dietSummary.ProteinToday)</span>
                        </div>
                        <div class="macro-card">
                            <span class="macro-label">Carbs</span>
                            <span class="macro-value">@FormatMacro(_dietSummary.CarbsToday)</span>
                        </div>
                        <div class="macro-card">
                            <span class="macro-label">Fat</span>
                            <span class="macro-value">@FormatMacro(_dietSummary.FatToday)</span>
                        </div>
                    </div>
                    <div class="food-log-list">
                        @foreach (var food in _recentFoodLogs.Where(f => f.Date == DateOnly.FromDateTime(DateTime.Now)).Take(6))
                        {
                            <div class="food-log-row">
                                <div>
                                    <span class="food-log-name">@food.FoodName</span>
                                    <span class="food-log-meta">@food.MealName · @FormatMealTime(food.MealTime) · @($"{food.Grams:F0}g")</span>
                                </div>
                                <div class="food-log-right">
                                    <span>@FormatCalories(food.Calories)</span>
                                    <span>@FormatMacro(food.Protein)</span>
                                </div>
                            </div>
                        }
                        @if (!_recentFoodLogs.Any(f => f.Date == DateOnly.FromDateTime(DateTime.Now)))
                        {
                            <div class="empty-text">No food logged today. Log meals from the Diet page to populate this section.</div>
                        }
                    </div>
                </div>

                <div class="panel equal-panel daily-calories-panel">
                    <div class="panel-header">
                        <span class="panel-title">Daily Logged Calories</span>
                        <span class="panel-hint">Last 7 days</span>
                    </div>
                    @if (HasNutritionLogs)
                    {
                        <div class="chart-title">Calories by day</div>
                        <div class="nutrition-chart">
                            @{ var maxCalories = _weeklyNutrition.Count > 0 ? Math.Max(_weeklyNutrition.Max(d => d.Calories), 1m) : 1m; }
                            @foreach (var day in _weeklyNutrition)
                            {
                                var height = day.HasLogs ? (int)Math.Round(day.Calories / maxCalories * 100) : 0;
                                var isToday = day.Date == DateOnly.FromDateTime(DateTime.Now);
                                <div class="nutrition-bar-col">
                                    <div class="nutrition-bar-track">
                                        <span class="nutrition-bar-val @(isToday ? "nutrition-bar-latest" : "")">@(day.HasLogs ? FormatCalories(day.Calories) : "No log")</span>
                                        <div class="nutrition-bar @(isToday ? "nutrition-bar-active" : "")" style="flex-basis:@(height)%"></div>
                                    </div>
                                    <span class="nutrition-bar-label">@day.Label</span>
                                </div>
                            }
                        </div>
                        <div class="chart-divider"></div>
                        <div class="chart-title">Macros by day</div>
                        <div class="macro-trend-legend">
                            <span><i class="macro-dot macro-protein"></i>Protein</span>
                            <span><i class="macro-dot macro-carbs"></i>Carbs</span>
                            <span><i class="macro-dot macro-fat"></i>Fat</span>
                        </div>
                        <div class="macro-trend-chart">
                            @{ var maxMacro = GetMaxWeeklyMacro(); }
                            @foreach (var day in _weeklyNutrition)
                            {
                                var isToday = day.Date == DateOnly.FromDateTime(DateTime.Now);
                                <div class="macro-day-col @(isToday ? "macro-day-today" : "")">
                                    <span class="macro-day-value">@(day.HasLogs ? FormatMacro(day.Protein + day.Carbs + day.Fat) : "No log")</span>
                                    <div class="macro-day-bars">
                                        <span class="macro-mini-bar macro-protein" style="height:@GetMacroBarHeight(day.Protein, maxMacro)px" title="Protein: @FormatMacro(day.Protein)"></span>
                                        <span class="macro-mini-bar macro-carbs" style="height:@GetMacroBarHeight(day.Carbs, maxMacro)px" title="Carbs: @FormatMacro(day.Carbs)"></span>
                                        <span class="macro-mini-bar macro-fat" style="height:@GetMacroBarHeight(day.Fat, maxMacro)px" title="Fat: @FormatMacro(day.Fat)"></span>
                                    </div>
                                    <span class="macro-day-label">@day.Label</span>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="empty-text empty-panel-message">No food logs yet. Log foods from the Diet page to see daily calories and macro graphs.</div>
                    }
                </div>
            </div>

            <div class="two-col equal-progress-row diet-consistency-row">
                <div class="panel equal-panel diet-consistency-panel">
                    <div class="panel-header">
                        <span class="panel-title">Diet Consistency</span>
                        <span class="panel-hint">Last 30 days</span>
                    </div>
                    <div class="consistency-grid">
                        @foreach (var day in _dietConsistency)
                        {
                            <div class="c-cell @(day.IsActive ? "c-active" : "")" title="@day.Date.ToString("ddd, d MMM yyyy") - @(day.IsActive ? "Logged" : "No log")">
                                <span class="c-tooltip">@day.Date.ToString("d MMM")<br />@(day.IsActive ? "Logged" : "No log")</span>
                            </div>
                        }
                    </div>
                    <div class="consistency-stats">
                        <div class="cs-item">
                            <span class="cs-label">Logged days</span>
                            <span class="cs-val cs-success">@ActiveDaysText(_dietConsistency)</span>
                        </div>
                        <div class="cs-item">
                            <span class="cs-label">Today</span>
                            <span class="cs-val cs-accent">@_dietSummary.LoggedFoodsToday foods</span>
                        </div>
                        <div class="cs-item">
                            <span class="cs-label">Scheduled</span>
                            <span class="cs-val">@_dietSummary.ScheduledMealsToday meals</span>
                        </div>
                    </div>
                </div>

                <div class="panel equal-panel upcoming-meals-panel">
                    <div class="panel-header">
                        <span class="panel-title">Upcoming Meals</span>
                        <span class="panel-hint">Next 7 days</span>
                    </div>
                    <div class="food-log-list scheduled-foods">
                        @foreach (var meal in _upcomingMeals)
                        {
                            <div class="food-log-row">
                                <div>
                                    <span class="food-log-name">@meal.FoodName</span>
                                    <span class="food-log-meta">@meal.ScheduledDate.ToString("ddd, MMM d") · @FormatMealTime(meal.ScheduledTime) · @meal.MealName</span>
                                </div>
                                <div class="food-log-right">
                                    <span>@($"{meal.QuantityGrams:F0}g")</span>
                                    <span>@ToTitle(meal.Status)</span>
                                </div>
                            </div>
                        }
                        @if (_upcomingMeals.Count == 0)
                        {
                            <div class="empty-text">No meals scheduled. Add diet items from Schedule to see them here.</div>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
}

<Modal IsOpen="_showLogModal" OnClose="() => _showLogModal = false" Size="sm">
    <div class="log-modal">
        <h2>Log Measurements</h2>
        <div class="log-fields">
            <div class="log-field">
                <label>Weight (@WeightUnitLabel)</label>
                <input type="number" step="0.1" @bind="LogWeightDisplay" />
            </div>
            <div class="log-field">
                <label>Body Fat (%)</label>
                <input type="number" step="0.1" @bind="_logBodyFat" />
            </div>
            <div class="log-field">
                <label>Chest (cm)</label>
                <input type="number" step="0.1" @bind="_logChest" />
            </div>
            <div class="log-field">
                <label>Waist (cm)</label>
                <input type="number" step="0.1" @bind="_logWaist" />
            </div>
            <div class="log-field">
                <label>Arms (cm)</label>
                <input type="number" step="0.1" @bind="_logBiceps" />
            </div>
            <div class="log-field">
                <label>Thighs (cm)</label>
                <input type="number" step="0.1" @bind="_logThighs" />
            </div>
            <div class="log-field">
                <label>Hips (cm)</label>
                <input type="number" step="0.1" @bind="_logHips" />
            </div>
        </div>
        <div class="log-actions">
            <button type="button" class="btn-ghost" @onclick="() => _showLogModal = false">Cancel</button>
            <button type="button" class="btn-primary" @onclick="SaveMeasurement">Save</button>
        </div>
    </div>
</Modal>

<Modal IsOpen="_showHistoryModal" OnClose="() => _showHistoryModal = false" Size="lg">
    <div class="log-modal">
        <h2>Measurement History</h2>
        @if (_allMeasurements.Count == 0)
        {
            <div class="empty-text">No measurements logged yet.</div>
        }
        else
        {
            <div class="history-table-wrap">
                <div class="history-table">
                    <div class="history-header">
                        <span class="history-col-date">Date</span>
                        <span class="history-col">Weight (@WeightUnitLabel)</span>
                        <span class="history-col">Body Fat</span>
                        <span class="history-col">Chest</span>
                        <span class="history-col">Waist</span>
                        <span class="history-col">Arms</span>
                        <span class="history-col">Thighs</span>
                        <span class="history-col">Hips</span>
                        <span class="history-col-action"></span>
                    </div>
                    @foreach (var m in _allMeasurements)
                    {
                        var mRef = m;
                        var isEditing = _editingMeasId == m.Id;
                        <div class="history-row">
                            <span class="history-col-date">@m.Date.ToString("d MMM yyyy")</span>
                            @if (isEditing)
                            {
                                <span class="history-col"><input type="number" step="0.1" class="history-input" @bind="EditWeightDisplay" /></span>
                                <span class="history-col"><input type="number" step="0.1" class="history-input" @bind="_editBodyFat" /></span>
                                <span class="history-col"><input type="number" step="0.1" class="history-input" @bind="_editChest" /></span>
                                <span class="history-col"><input type="number" step="0.1" class="history-input" @bind="_editWaist" /></span>
                                <span class="history-col"><input type="number" step="0.1" class="history-input" @bind="_editBiceps" /></span>
                                <span class="history-col"><input type="number" step="0.1" class="history-input" @bind="_editThighs" /></span>
                                <span class="history-col"><input type="number" step="0.1" class="history-input" @bind="_editHips" /></span>
                                <span class="history-col-action">
                                    <button type="button" class="history-btn history-save" @onclick="SaveEdit">Save</button>
                                    <button type="button" class="history-btn history-cancel" @onclick="() => _editingMeasId = -1">Cancel</button>
                                </span>
                            }
                            else if (_deletingMeasId == m.Id)
                            {
                                <span class="history-col history-confirm-text">Delete this entry?</span>
                                <span class="history-col"></span>
                                <span class="history-col"></span>
                                <span class="history-col"></span>
                                <span class="history-col"></span>
                                <span class="history-col"></span>
                                <span class="history-col"></span>
                                <span class="history-col-action">
                                    <button type="button" class="history-btn history-delete" @onclick="() => DeleteMeasurement(mRef)" aria-label="Confirm delete">Delete</button>
                                    <button type="button" class="history-btn history-cancel" @onclick="() => _deletingMeasId = -1" aria-label="Cancel">Cancel</button>
                                </span>
                            }
                            else
                            {
                                <span class="history-col">@FormatWeightValue(m.WeightKg)</span>
                                <span class="history-col">@(m.BodyFatPercent.HasValue ? $"{m.BodyFatPercent:F1}%" : "-")</span>
                                <span class="history-col">@(m.ChestCm.HasValue ? $"{m.ChestCm:F0}" : "-")</span>
                                <span class="history-col">@(m.WaistCm.HasValue ? $"{m.WaistCm:F0}" : "-")</span>
                                <span class="history-col">@(m.BicepsCm.HasValue ? $"{m.BicepsCm:F0}" : "-")</span>
                                <span class="history-col">@(m.ThighsCm.HasValue ? $"{m.ThighsCm:F0}" : "-")</span>
                                <span class="history-col">@(m.HipsCm.HasValue ? $"{m.HipsCm:F0}" : "-")</span>
                                <span class="history-col-action">
                                    <button type="button" class="history-btn history-edit" @onclick="() => StartEdit(mRef)">Edit</button>
                                    <button type="button" class="history-btn history-remove" @onclick="() => _deletingMeasId = mRef.Id">Delete</button>
                                </span>
                            }
                        </div>
                    }
                </div>
            </div>
        }
    </div>
</Modal>

@code {
    private const string SectionBody = "body";
    private const string SectionTraining = "training";
    private const string SectionDiet = "diet";

    private bool _isLoading = true;
    private int _userId;
    private string _weightUnit = "kg";
    private string _energyUnit = "kcal";
    private string _activeSection = SectionBody;

    private int _totalWorkouts;
    private int _streak;
    private int _bestStreak;
    private decimal _weeklyVolume;
    private int _avgSession;
    private List<MuscleCoverageItem> _muscleCoverage = new();
    private List<WeeklyCalorieItem> _weeklyCalories = new();
    private List<PersonalRecord> _personalRecords = new();
    private List<BodyMeasurement> _measurements = new();
    private List<ConsistencyDay> _consistency = new();
    private List<OverloadSuggestion> _suggestions = new();

    private ProgressDietSummary _dietSummary = new();
    private List<ProgressNutritionDay> _weeklyNutrition = new();
    private List<ConsistencyDay> _dietConsistency = new();
    private List<ProgressFoodLogItem> _recentFoodLogs = new();
    private List<ProgressDietScheduleItem> _upcomingMeals = new();

    private List<BodyMeasurement> _chartMeasurements = new();
    private List<PersonalRecord> _allPrs = new();
    private List<ChartSeries> _measSeries = new();
    private List<ChartExercise> _prChartExercises = new();
    private HashSet<string> _hiddenMeasSeries = new();
    private HashSet<string> _hiddenPrSeries = new();

    private bool _showLogModal;
    private decimal? _logWeight;
    private decimal? _logBodyFat;
    private decimal? _logChest;
    private decimal? _logWaist;
    private decimal? _logBiceps;
    private decimal? _logThighs;
    private decimal? _logHips;

    private bool _showHistoryModal;
    private List<BodyMeasurement> _allMeasurements = new();
    private int _editingMeasId = -1;
    private int _deletingMeasId = -1;
    private decimal? _editWeight;
    private decimal? _editBodyFat;
    private decimal? _editChest;
    private decimal? _editWaist;
    private decimal? _editBiceps;
    private decimal? _editThighs;
    private decimal? _editHips;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        var state = await AuthState.GetAuthenticationStateAsync();
        if (state.User.Identity is not { IsAuthenticated: true }) { try { Navigation.NavigateTo("/login", forceLoad: true); } catch { } return; }
        _userId = int.Parse(state.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)!.Value);
        var settings = await SettingsSvc.GetSettingsAsync(_userId);
        _weightUnit = settings.WeightUnit;
        _energyUnit = settings.EnergyUnit;
        await LoadData();
        _isLoading = false;
        StateHasChanged();
    }

    private async Task LoadData()
    {
        _totalWorkouts = await ProgressSvc.GetTotalWorkoutsAsync(_userId);
        _streak = await ProgressSvc.GetStreakAsync(_userId);
        _bestStreak = await ProgressSvc.GetBestStreakAsync(_userId);
        _weeklyVolume = await ProgressSvc.GetWeeklyVolumeAsync(_userId);
        _avgSession = await ProgressSvc.GetAvgSessionMinutesAsync(_userId);
        _muscleCoverage = await ProgressSvc.GetMuscleCoverageAsync(_userId);
        _weeklyCalories = await ProgressSvc.GetWeeklyCaloriesAsync(_userId);
        _personalRecords = await ProgressSvc.GetPersonalRecordsAsync(_userId);
        _measurements = await ProgressSvc.GetRecentMeasurementsAsync(_userId);
        _consistency = await ProgressSvc.GetConsistencyAsync(_userId);
        _suggestions = await ProgressSvc.GetOverloadSuggestionsAsync(_userId);
        _chartMeasurements = await ProgressSvc.GetMeasurementsForChartAsync(_userId);
        _allPrs = await ProgressSvc.GetAllPersonalRecordsAsync(_userId);
        _dietSummary = await ProgressSvc.GetDietSummaryAsync(_userId);
        _weeklyNutrition = await ProgressSvc.GetWeeklyNutritionAsync(_userId);
        _dietConsistency = await ProgressSvc.GetDietConsistencyAsync(_userId);
        _recentFoodLogs = await ProgressSvc.GetRecentFoodLogsAsync(_userId);
        _upcomingMeals = await ProgressSvc.GetUpcomingDietSchedulesAsync(_userId);
        BuildChartData();
    }

    private List<ProgressSectionDisplay> GetProgressSections()
    {
        var latestWeight = GetMeasurementDisplay().FirstOrDefault(x => x.Label == "Weight").Value ?? "-";
        return new()
        {
            new ProgressSectionDisplay(SectionBody, "Body", "Measurements, weight changes, and composition trends.", latestWeight),
            new ProgressSectionDisplay(SectionTraining, "Training", "Volume, performance, muscle coverage, and consistency.", $"{_totalWorkouts} workouts"),
            new ProgressSectionDisplay(SectionDiet, "Diet", "Calories, macros, food logs, and scheduled meals.", FormatCalories(_dietSummary.CaloriesToday))
        };
    }

    private List<StatDisplay> GetActiveStats()
    {
        if (_activeSection == SectionBody)
        {
            return GetMeasurementDisplay().Select(x => new StatDisplay(x.Label, x.Value, string.IsNullOrWhiteSpace(x.Change) ? "Latest" : x.Change)).ToList();
        }

        if (_activeSection == SectionDiet)
        {
            return new()
            {
                new StatDisplay("Calories Today", FormatCalories(_dietSummary.CaloriesToday), "Logged"),
                new StatDisplay("Protein Today", FormatMacro(_dietSummary.ProteinToday), "Logged"),
                new StatDisplay("Meals Today", $"{_dietSummary.LoggedFoodsToday}", $"{_dietSummary.ScheduledMealsToday} scheduled"),
                new StatDisplay("7 Day Average", FormatCalories(_dietSummary.AverageCaloriesSevenDays), "Daily intake")
            };
        }

        return new()
        {
            new StatDisplay("Total Workouts", $"{_totalWorkouts}", "All time"),
            new StatDisplay("Current Streak", $"{_streak}", "Days"),
            new StatDisplay("Weekly Volume", FormatVolume(_weeklyVolume), $"{WeightUnitLabel} lifted"),
            new StatDisplay("Avg Session", $"{_avgSession}m", "This month")
        };
    }

    private List<LegendDisplay> GetMuscleLegend() => new()
    {
        new LegendDisplay("var(--success)", "On track"),
        new LegendDisplay("var(--accent)", "Undertrained"),
        new LegendDisplay("var(--t3)", "Missing"),
        new LegendDisplay("var(--danger)", "High volume")
    };

    private bool HasMuscleCoverageData => _muscleCoverage.Any(m => m.Sets > 0);

    private bool HasWeeklyEnergyLogs => _weeklyCalories.Any(w => w.HasLogs);

    private bool HasNutritionLogs => _weeklyNutrition.Any(day => day.HasLogs);

    private bool HasPrChartData => _prChartExercises.Any(ex => _allPrs.Count(pr => GetExerciseName(pr) == ex.Name) >= 2);

    private string ActiveDaysText(List<ConsistencyDay> days) => days.Count == 0 ? "0/0" : $"{days.Count(day => day.IsActive)}/{days.Count}";

    private static string GetExerciseName(PersonalRecord pr) => pr.Exercise?.Name ?? "Exercise";

    private decimal GetMaxWeeklyMacro()
    {
        var values = _weeklyNutrition.SelectMany(day => new[] { day.Protein, day.Carbs, day.Fat }).ToList();
        var max = values.Count == 0 ? 1m : values.Max();
        return Math.Max(max, 1m);
    }

    private static int GetMacroBarHeight(decimal value, decimal maxValue)
    {
        if (value <= 0 || maxValue <= 0) return 0;
        return Math.Clamp((int)Math.Round(value / maxValue * 72), 2, 72);
    }

    private void BuildChartData()
    {
        _measSeries = new()
        {
            new ChartSeries { Key = "weight", Label = $"Weight ({WeightUnitLabel})", Color = "#38bdf8" },
            new ChartSeries { Key = "bodyfat", Label = "Body Fat (%)", Color = "#2ab8a0" },
            new ChartSeries { Key = "chest", Label = "Chest (cm)", Color = "#a78bfa" },
            new ChartSeries { Key = "waist", Label = "Waist (cm)", Color = "#f0c050" },
            new ChartSeries { Key = "biceps", Label = "Arms (cm)", Color = "#e06c9f" },
            new ChartSeries { Key = "thighs", Label = "Thighs (cm)", Color = "#6ea8fe" },
            new ChartSeries { Key = "hips", Label = "Hips (cm)", Color = "#7bd88f" }
        };

        var exerciseColors = new[] { "#38bdf8", "#2ab8a0", "#a78bfa", "#f0c050", "#e05c6a", "#f472b6", "#34d399", "#fb923c" };
        _prChartExercises = _allPrs
            .Select(GetExerciseName)
            .Where(name => !string.IsNullOrWhiteSpace(name))
            .Distinct()
            .Select((name, i) => new ChartExercise { Name = name, Color = exerciseColors[i % exerciseColors.Length] })
            .ToList();
    }

    private decimal? GetMeasValue(BodyMeasurement m, string key) => key switch
    {
        "weight" => SettingsService.FromKg(m.WeightKg, _weightUnit),
        "bodyfat" => m.BodyFatPercent,
        "chest" => m.ChestCm,
        "waist" => m.WaistCm,
        "biceps" => m.BicepsCm,
        "thighs" => m.ThighsCm,
        "hips" => m.HipsCm,
        _ => null
    };

    private string GetMeasUnit(string key) => key switch
    {
        "weight" => WeightUnitLabel, "bodyfat" => "%", "chest" => "cm", "waist" => "cm",
        "biceps" => "cm", "thighs" => "cm", "hips" => "cm", _ => ""
    };

    private List<ChartPoint> GetMeasPoints(string key, int w, int h, ChartPad pad)
    {
        var data = _chartMeasurements.Where(m => GetMeasValue(m, key).HasValue).ToList();
        if (data.Count == 0) return new();

        var values = data.Select(m => (double)GetMeasValue(m, key)!.Value).ToList();
        var minV = values.Min();
        var maxV = values.Max();
        var range = maxV - minV;
        if (range < 0.01) { minV -= 1; maxV += 1; range = maxV - minV; }
        minV -= range * 0.1;
        maxV += range * 0.1;

        var allDates = _chartMeasurements.Select(m => m.Date).Distinct().OrderBy(d => d).ToList();
        var minDate = allDates.First().ToDateTime(TimeOnly.MinValue).Ticks;
        var maxDate = allDates.Last().ToDateTime(TimeOnly.MinValue).Ticks;
        if (minDate == maxDate) maxDate += TimeSpan.TicksPerDay;

        var cw = w - pad.Left - pad.Right;
        var ch = h - pad.Top - pad.Bottom;
        var unit = GetMeasUnit(key);

        return data.Select(m =>
        {
            var val = (double)GetMeasValue(m, key)!.Value;
            var x = pad.Left + (double)(m.Date.ToDateTime(TimeOnly.MinValue).Ticks - minDate) / (maxDate - minDate) * cw;
            var y = pad.Top + (1 - (val - minV) / (maxV - minV)) * ch;
            return new ChartPoint { X = Math.Round(x, 1), Y = Math.Round(y, 1), Label = $"{m.Date:d MMM yyyy}: {val:F1} {unit}" };
        }).ToList();
    }

    private List<ChartPoint> GetPrPoints(string exerciseName, int w, int h, ChartPad pad)
    {
        var data = _allPrs.Where(pr => GetExerciseName(pr) == exerciseName).OrderBy(pr => pr.Date).ToList();
        if (data.Count == 0) return new();

        var allVisible = _allPrs.Where(pr => !_hiddenPrSeries.Contains(GetExerciseName(pr))).ToList();
        if (allVisible.Count == 0) return new();

        var visibleValues = allVisible.Select(pr => (double)(SettingsService.FromKg(pr.WeightKg, _weightUnit) ?? pr.WeightKg)).ToList();
        var minV = visibleValues.Min() * 0.9;
        var maxV = visibleValues.Max() * 1.1;
        if (Math.Abs(maxV - minV) < 0.01) { minV -= 5; maxV += 5; }

        var minDate = allVisible.Min(pr => pr.Date).ToDateTime(TimeOnly.MinValue).Ticks;
        var maxDate = allVisible.Max(pr => pr.Date).ToDateTime(TimeOnly.MinValue).Ticks;
        if (minDate == maxDate) maxDate += TimeSpan.TicksPerDay;

        var cw = w - pad.Left - pad.Right;
        var ch = h - pad.Top - pad.Bottom;

        return data.Select(pr =>
        {
            var val = (double)(SettingsService.FromKg(pr.WeightKg, _weightUnit) ?? pr.WeightKg);
            var x = pad.Left + (double)(pr.Date.ToDateTime(TimeOnly.MinValue).Ticks - minDate) / (maxDate - minDate) * cw;
            var y = pad.Top + (1 - (val - minV) / (maxV - minV)) * ch;
            return new ChartPoint { X = Math.Round(x, 1), Y = Math.Round(y, 1), Label = $"{pr.Date:d MMM yyyy}: {FormatWeightValue(pr.WeightKg)} × {pr.Reps} reps" };
        }).ToList();
    }

    private List<AxisLabel> GetPrYLabels(int h, ChartPad pad)
    {
        var allVals = _allPrs.Where(pr => !_hiddenPrSeries.Contains(GetExerciseName(pr))).Select(pr => (double)(SettingsService.FromKg(pr.WeightKg, _weightUnit) ?? pr.WeightKg)).ToList();
        return BuildYLabels(allVals, h, pad);
    }

    private static List<AxisLabel> BuildYLabels(List<double> values, int h, ChartPad pad)
    {
        if (values.Count == 0) return new();
        var minV = values.Min() * 0.9;
        var maxV = values.Max() * 1.1;
        if (Math.Abs(maxV - minV) < 0.01) { minV -= 1; maxV += 1; }
        var ch = h - pad.Top - pad.Bottom;
        var result = new List<AxisLabel>();
        for (int i = 0; i <= 4; i++)
        {
            var val = minV + (maxV - minV) * i / 4;
            var y = pad.Top + (1 - (double)i / 4) * ch;
            result.Add(new AxisLabel { Y = Math.Round(y, 1), Label = val >= 100 ? $"{(int)val}" : $"{val:F0}" });
        }
        return result;
    }

    private List<AxisLabel> GetMeasXLabels(int w, ChartPad pad)
    {
        if (_chartMeasurements.Count == 0) return new();
        var dates = _chartMeasurements.Select(m => m.Date).Distinct().OrderBy(d => d).ToList();
        return BuildXLabels(dates, w, pad);
    }

    private List<AxisLabel> GetPrXLabels(int w, ChartPad pad)
    {
        var dates = _allPrs.Where(pr => !_hiddenPrSeries.Contains(GetExerciseName(pr))).Select(pr => pr.Date).Distinct().OrderBy(d => d).ToList();
        return BuildXLabels(dates, w, pad);
    }

    private static List<AxisLabel> BuildXLabels(List<DateOnly> dates, int w, ChartPad pad)
    {
        if (dates.Count == 0) return new();
        var cw = w - pad.Left - pad.Right;
        var minD = dates.First().ToDateTime(TimeOnly.MinValue).Ticks;
        var maxD = dates.Last().ToDateTime(TimeOnly.MinValue).Ticks;
        if (minD == maxD) maxD += TimeSpan.TicksPerDay;
        var step = Math.Max(1, dates.Count / 5);
        return dates.Where((_, i) => i % step == 0 || i == dates.Count - 1)
            .Select(d => new AxisLabel { X = Math.Round(pad.Left + (double)(d.ToDateTime(TimeOnly.MinValue).Ticks - minD) / (maxD - minD) * cw, 1), Label = d.ToString("d MMM") })
            .ToList();
    }

    private void ToggleMeasSeries(string key) { if (!_hiddenMeasSeries.Remove(key)) _hiddenMeasSeries.Add(key); }
    private void TogglePrSeries(string name) { if (!_hiddenPrSeries.Remove(name)) _hiddenPrSeries.Add(name); }

    private async Task SaveMeasurement()
    {
        await ProgressSvc.SaveMeasurementAsync(_userId, _logWeight, _logBodyFat, _logChest, _logWaist, _logBiceps, _logThighs, _logHips);
        _measurements = await ProgressSvc.GetRecentMeasurementsAsync(_userId);
        _chartMeasurements = await ProgressSvc.GetMeasurementsForChartAsync(_userId);
        BuildChartData();
        _showLogModal = false;
        _logWeight = null; _logBodyFat = null; _logChest = null; _logWaist = null; _logBiceps = null; _logThighs = null; _logHips = null;
    }

    private async Task OpenHistory()
    {
        _allMeasurements = await ProgressSvc.GetAllMeasurementsAsync(_userId);
        _editingMeasId = -1;
        _showHistoryModal = true;
    }

    private void StartEdit(BodyMeasurement m)
    {
        _deletingMeasId = -1;
        _editingMeasId = m.Id;
        _editWeight = m.WeightKg;
        _editBodyFat = m.BodyFatPercent;
        _editChest = m.ChestCm;
        _editWaist = m.WaistCm;
        _editBiceps = m.BicepsCm;
        _editThighs = m.ThighsCm;
        _editHips = m.HipsCm;
    }

    private async Task SaveEdit()
    {
        await ProgressSvc.UpdateMeasurementAsync(_editingMeasId, _userId, _editWeight, _editBodyFat, _editChest, _editWaist, _editBiceps, _editThighs, _editHips);
        _allMeasurements = await ProgressSvc.GetAllMeasurementsAsync(_userId);
        _measurements = await ProgressSvc.GetRecentMeasurementsAsync(_userId);
        _chartMeasurements = await ProgressSvc.GetMeasurementsForChartAsync(_userId);
        BuildChartData();
        _editingMeasId = -1;
    }

    private async Task DeleteMeasurement(BodyMeasurement m)
    {
        await ProgressSvc.DeleteMeasurementAsync(m.Id, _userId);
        _allMeasurements = await ProgressSvc.GetAllMeasurementsAsync(_userId);
        _measurements = await ProgressSvc.GetRecentMeasurementsAsync(_userId);
        _chartMeasurements = await ProgressSvc.GetMeasurementsForChartAsync(_userId);
        BuildChartData();
        _deletingMeasId = -1;
        _editingMeasId = -1;
    }

    private List<(string Label, string Value, string Change, string Trend)> GetMeasurementDisplay()
    {
        var latest = _measurements.FirstOrDefault();
        var prev = _measurements.Count > 1 ? _measurements[1] : null;
        if (latest is null) return new() { ("Weight", "-", "", "down"), ("Body Fat", "-", "", "down"), ("Chest", "-", "", "up"), ("Waist", "-", "", "down"), ("Arms", "-", "", "up"), ("Thighs", "-", "", "up") };

        return new()
        {
            ("Weight", FormatWeightValue(latest.WeightKg), FormatWeightChange(latest.WeightKg, prev?.WeightKg), latest.WeightKg < prev?.WeightKg ? "down" : "up"),
            ("Body Fat", latest.BodyFatPercent.HasValue ? $"{latest.BodyFatPercent:F1}%" : "-", FormatChange(latest.BodyFatPercent, prev?.BodyFatPercent, "%"), latest.BodyFatPercent < prev?.BodyFatPercent ? "down" : "up"),
            ("Chest", latest.ChestCm.HasValue ? $"{latest.ChestCm:F0} cm" : "-", FormatChange(latest.ChestCm, prev?.ChestCm, "cm"), latest.ChestCm > prev?.ChestCm ? "up" : "down"),
            ("Waist", latest.WaistCm.HasValue ? $"{latest.WaistCm:F0} cm" : "-", FormatChange(latest.WaistCm, prev?.WaistCm, "cm"), latest.WaistCm < prev?.WaistCm ? "down" : "up"),
            ("Arms", latest.BicepsCm.HasValue ? $"{latest.BicepsCm:F0} cm" : "-", FormatChange(latest.BicepsCm, prev?.BicepsCm, "cm"), latest.BicepsCm > prev?.BicepsCm ? "up" : "down"),
            ("Thighs", latest.ThighsCm.HasValue ? $"{latest.ThighsCm:F0} cm" : "-", FormatChange(latest.ThighsCm, prev?.ThighsCm, "cm"), latest.ThighsCm > prev?.ThighsCm ? "up" : "down")
        };
    }

    private static string FormatChange(decimal? current, decimal? previous, string unit)
    {
        if (!current.HasValue || !previous.HasValue) return "";
        var diff = current.Value - previous.Value;
        return $"{(diff >= 0 ? "+" : "")}{diff:F1} {unit}";
    }

    private string FormatWeightChange(decimal? currentKg, decimal? previousKg)
    {
        if (!currentKg.HasValue || !previousKg.HasValue) return "";
        var current = SettingsService.FromKg(currentKg, _weightUnit);
        var previous = SettingsService.FromKg(previousKg, _weightUnit);
        if (!current.HasValue || !previous.HasValue) return "";
        var diff = current.Value - previous.Value;
        return $"{(diff >= 0 ? "+" : "")}{diff:F1} {WeightUnitLabel}";
    }

    private string GetTrendLabel(string trend, string change)
    {
        if (string.IsNullOrWhiteSpace(change)) return "Latest";
        return $"{(trend == "down" ? "Down" : "Up")} {change}";
    }

    private string GetMuscleColor(string status) => status switch
    {
        "good" => "var(--success)",
        "low" => "var(--accent)",
        "excess" => "var(--danger)",
        _ => "var(--t3)"
    };

    private static string GetMuscleStatusLabel(string status) => status switch
    {
        "good" => "On track",
        "low" => "Undertrained",
        "excess" => "High volume",
        _ => "Missing"
    };

    private string FormatWeightValue(decimal? weightKg) => SettingsService.FormatWeight(weightKg, _weightUnit);

    private string FormatWeightValue(decimal weightKg) => SettingsService.FormatWeight(weightKg, _weightUnit);

    private string FormatEnergyValue(decimal calories) => SettingsService.FormatEnergy(calories, _energyUnit);

    private string WeightUnitLabel => SettingsService.WeightLabel(_weightUnit);

    private decimal? LogWeightDisplay
    {
        get => SettingsService.FromKg(_logWeight, _weightUnit);
        set => _logWeight = SettingsService.ToKg(value, _weightUnit);
    }

    private decimal? EditWeightDisplay
    {
        get => SettingsService.FromKg(_editWeight, _weightUnit);
        set => _editWeight = SettingsService.ToKg(value, _weightUnit);
    }

    private string FormatVolume(decimal vol)
    {
        var converted = SettingsService.FromKg(vol, _weightUnit) ?? vol;
        return converted >= 1000 ? $"{converted / 1000:F1}k" : $"{converted:F0}";
    }

    private static string FormatCalories(decimal calories) => calories >= 1000 ? $"{calories / 1000:F1}k kcal" : $"{calories:F0} kcal";

    private static string FormatMacro(decimal value) => value >= 100 ? $"{value:F0}g" : $"{value:F1}g";

    private static string FormatMealTime(TimeOnly? time) => time.HasValue ? time.Value.ToString("HH:mm") : "No time";

    private static string ToTitle(string value) => string.IsNullOrWhiteSpace(value) ? "Planned" : char.ToUpperInvariant(value[0]) + value[1..].ToLowerInvariant();

    private record ChartPad(int Left, int Top, int Right, int Bottom);
    private record StatDisplay(string Label, string Value, string Sub);
    private record ProgressSectionDisplay(string Key, string Title, string Description, string Meta);
    private record LegendDisplay(string Color, string Label);
    private class ChartPoint { public double X; public double Y; public string Label = ""; }
    private class ChartSeries { public string Key = ""; public string Label = ""; public string Color = ""; }
    private class ChartExercise { public string Name = ""; public string Color = ""; }
    private class AxisLabel { public double X; public double Y; public string Label = ""; }
}
