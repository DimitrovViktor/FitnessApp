@page "/progress"
@inject ProgressService ProgressSvc
@inject SettingsService SettingsSvc
@inject CustomAuthStateProvider AuthState
@inject NavigationManager Navigation
@using FitnessApp.Models.Enums

<PageTitle>Progress - Fitness App</PageTitle>

@if (_isLoading)
{
    <div class="loading-state"><p>Loading...</p></div>
}
else
{
    <div class="progress-page">
        <div class="page-header">
            <h1>Progress</h1>
            <p class="page-sub">Track your performance, volume, and body over time</p>
        </div>

        <div class="stats-grid">
            @foreach (var (label, value, sub) in new[] {
                ("Total Workouts", $"{_totalWorkouts}", "All time"),
                ("Current Streak", $"{_streak}", "Days"),
                ("Weekly Volume", FormatVolume(_weeklyVolume), $"{WeightUnitLabel} lifted"),
                ("Avg Session", $"{_avgSession}m", "This month")
            })
            {
                <div class="stat-card">
                    <span class="stat-label">@label</span>
                    <span class="stat-val">@value</span>
                    <span class="stat-sub">@sub</span>
                </div>
            }
        </div>

        <div class="two-col">
            <div class="panel">
                <div class="panel-header">
                    <span class="panel-title">Weekly Muscle Coverage</span>
                    <span class="panel-hint">This week</span>
                </div>
                <div class="legend-row">
                    @foreach (var (key, color, label) in new[] { ("good","var(--success)","On track"), ("low","var(--accent)","Undertrained"), ("missing","#4a607a","Missing"), ("excess","var(--danger)","High volume") })
                    {
                        <div class="legend-item">
                            <span class="legend-dot" style="background:@color"></span>
                            <span class="legend-text">@label</span>
                        </div>
                    }
                </div>
                <div class="muscle-list">
                    @foreach (var m in _muscleCoverage)
                    {
                        var color = m.Status switch { "good" => "var(--success)", "low" => "var(--accent)", "excess" => "var(--danger)", _ => "#4a607a" };
                        var statusLabel = m.Status switch { "good" => "On track", "low" => "Undertrained", "excess" => "High volume", _ => "Missing" };
                        <div class="muscle-row">
                            <div class="muscle-labels">
                                <span class="muscle-name">@m.Name</span>
                                <div class="muscle-right">
                                    <span class="muscle-sets">@m.Sets/@m.Target sets</span>
                                    <span class="muscle-status" style="color:@color">@statusLabel</span>
                                </div>
                            </div>
                            <div class="muscle-bar-bg">
                                <div class="muscle-bar-fill" style="width:@(m.Target > 0 ? Math.Min((int)((double)m.Sets / m.Target * 100), 100) : 0)%;background:@color"></div>
                            </div>
                        </div>
                    }
                </div>
            </div>

            <div class="panel">
                <div class="panel-header">
                    <span class="panel-title">Weekly Energy Burn</span>
                    <span class="panel-hint">Last @_weeklyCalories.Count weeks</span>
                </div>
                <div class="cal-chart">
                    @{ var maxKcal = _weeklyCalories.Count > 0 ? _weeklyCalories.Max(w => w.Kcal) : 1; }
                    @for (int i = 0; i < _weeklyCalories.Count; i++)
                    {
                        var w = _weeklyCalories[i];
                        var h = maxKcal > 0 ? (int)((double)w.Kcal / maxKcal * 140) : 0;
                        var isLatest = i == _weeklyCalories.Count - 1;
                        <div class="cal-bar-col">
                            <span class="cal-bar-val @(isLatest ? "cal-bar-latest" : "")">@FormatEnergyValue(w.Kcal)</span>
                            <div class="cal-bar-track">
                                <div class="cal-bar @(isLatest ? "cal-bar-active" : "")" style="height:@(h)px"></div>
                            </div>
                            <span class="cal-bar-label">@w.Label</span>
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="two-col">
            <div class="panel">
                <div class="panel-title" style="margin-bottom:16px">Personal Records</div>
                <div class="pr-list">
                    @for (int i = 0; i < _personalRecords.Count; i++)
                    {
                        var pr = _personalRecords[i];
                        <div class="pr-row @(i % 2 == 0 ? "pr-alt" : "")">
                            <div>
                                <span class="pr-name">@pr.Exercise.Name</span>
                                <span class="pr-date">@pr.Date.ToString("MMM d")</span>
                            </div>
                            <div class="pr-right">
                                <span class="pr-weight">@FormatWeightValue(pr.WeightKg)</span>
                                <span class="pr-reps">@pr.Reps reps</span>
                            </div>
                        </div>
                    }
                    @if (_personalRecords.Count == 0)
                    {
                        <div class="empty-text">No personal records yet. Complete workouts with tracked weight to start recording PRs.</div>
                    }
                </div>
                @if (_prChartExercises.Count > 0)
                {
                    <div class="chart-divider"></div>
                    <div class="chart-title">PR Progression Over Time</div>
                    <div class="chart-container">
                        <svg viewBox="0 0 560 220" class="chart-svg">
                            @{ var prPad = new ChartPad(44, 10, 10, 28); }
                            @foreach (var ex in _prChartExercises)
                            {
                                if (_hiddenPrSeries.Contains(ex.Name)) continue;
                                var points = GetPrPoints(ex.Name, 560, 220, prPad);
                                if (points.Count < 2) continue;
                                <polyline points="@string.Join(" ", points.Select(p => $"{p.X},{p.Y}"))" fill="none" stroke="@ex.Color" stroke-width="2" stroke-linejoin="round" opacity="0.8" />
                            }
                            @foreach (var ex in _prChartExercises)
                            {
                                if (_hiddenPrSeries.Contains(ex.Name)) continue;
                                var points = GetPrPoints(ex.Name, 560, 220, prPad);
                                @foreach (var pt in points)
                                {
                                    <circle cx="@pt.X" cy="@pt.Y" r="4.5" fill="@ex.Color" stroke="var(--bg)" stroke-width="2" class="chart-point">
                                        <title>@pt.Label</title>
                                    </circle>
                                }
                            }
                            @{ var prYLabels = GetPrYLabels(220, prPad); }
                            @foreach (var yl in prYLabels)
                            {
                                @((MarkupString)$"<text x='{prPad.Left - 6}' y='{yl.Y + 4}' text-anchor='end' fill='var(--t3)' font-size='10' font-family='Inter,sans-serif'>{yl.Label}</text>")
                                <line x1="@prPad.Left" y1="@yl.Y" x2="@(560 - prPad.Right)" y2="@yl.Y" stroke="var(--border-faint)" stroke-width="1" />
                            }
                            @{ var prXLabels = GetPrXLabels(560, prPad); }
                            @foreach (var xl in prXLabels)
                            {
                                @((MarkupString)$"<text x='{xl.X}' y='{220 - 6}' text-anchor='middle' fill='var(--t3)' font-size='10' font-family='Inter,sans-serif'>{xl.Label}</text>")
                            }
                        </svg>
                    </div>
                    <div class="chart-legend">
                        @foreach (var ex in _prChartExercises)
                        {
                            var name = ex.Name;
                            var hidden = _hiddenPrSeries.Contains(name);
                            <button type="button" class="legend-btn @(hidden ? "legend-hidden" : "")" @onclick="() => TogglePrSeries(name)">
                                <span class="legend-swatch" style="background:@(hidden ? "var(--t3)" : ex.Color)"></span>
                                @name
                            </button>
                        }
                    </div>
                }
            </div>

            <div class="right-stack">
                <div class="panel">
                    <div class="panel-header">
                        <span class="panel-title">Body Measurements</span>
                        <div class="panel-header-btns">
                            <button type="button" class="btn-log" @onclick="OpenHistory">History</button>
                            <button type="button" class="btn-log" @onclick="() => _showLogModal = true">+ Log</button>
                        </div>
                    </div>
                    <div class="measurements-grid">
                        @foreach (var (label, value, change, trend) in GetMeasurementDisplay())
                        {
                            <div class="meas-card">
                                <span class="meas-label">@label</span>
                                <span class="meas-value">@value</span>
                                <span class="meas-change @(trend == "down" ? "meas-down" : "meas-up")">@(trend == "down" ? "Down" : "Up") @change</span>
                            </div>
                        }
                    </div>
                    @if (_chartMeasurements.Count >= 2)
                    {
                        <div class="chart-divider"></div>
                        <div class="chart-title">Measurements Over Time</div>
                        <div class="chart-container">
                            <svg viewBox="0 0 560 220" class="chart-svg">
                                @{ var mPad = new ChartPad(16, 10, 10, 28); }
                                @for (int gi = 0; gi <= 4; gi++)
                                {
                                    var gy = mPad.Top + (double)gi / 4 * (220 - mPad.Top - mPad.Bottom);
                                    <line x1="@mPad.Left" y1="@Math.Round(gy,1)" x2="@(560 - mPad.Right)" y2="@Math.Round(gy,1)" stroke="var(--border-faint)" stroke-width="1" />
                                }
                                @foreach (var series in _measSeries)
                                {
                                    if (_hiddenMeasSeries.Contains(series.Key)) continue;
                                    var points = GetMeasPoints(series.Key, 560, 220, mPad);
                                    if (points.Count < 2) continue;
                                    <polyline points="@string.Join(" ", points.Select(p => $"{p.X},{p.Y}"))" fill="none" stroke="@series.Color" stroke-width="2" stroke-linejoin="round" opacity="0.8" />
                                }
                                @foreach (var series in _measSeries)
                                {
                                    if (_hiddenMeasSeries.Contains(series.Key)) continue;
                                    var points = GetMeasPoints(series.Key, 560, 220, mPad);
                                    @foreach (var pt in points)
                                    {
                                        <circle cx="@pt.X" cy="@pt.Y" r="4.5" fill="@series.Color" stroke="var(--bg)" stroke-width="2" class="chart-point">
                                            <title>@pt.Label</title>
                                        </circle>
                                    }
                                }
                                @{ var mXLabels = GetMeasXLabels(560, mPad); }
                                @foreach (var xl in mXLabels)
                                {
                                    @((MarkupString)$"<text x='{xl.X}' y='{220 - 6}' text-anchor='middle' fill='var(--t3)' font-size='10' font-family='Inter,sans-serif'>{xl.Label}</text>")
                                }
                            </svg>
                        </div>
                        <div class="chart-legend">
                            @foreach (var series in _measSeries)
                            {
                                var key = series.Key;
                                var hidden = _hiddenMeasSeries.Contains(key);
                                <button type="button" class="legend-btn @(hidden ? "legend-hidden" : "")" @onclick="() => ToggleMeasSeries(key)">
                                    <span class="legend-swatch" style="background:@(hidden ? "var(--t3)" : series.Color)"></span>
                                    @series.Label
                                </button>
                            }
                        </div>
                    }
                </div>

                <div class="panel">
                    <div class="panel-header">
                        <span class="panel-title">Consistency</span>
                        <span class="panel-hint">Last 30 days</span>
                    </div>
                    <div class="consistency-grid">
                        @foreach (var day in _consistency)
                        {
                            <div class="c-cell @(day.IsActive ? "c-active" : "")" title="@day.Date.ToString("ddd, d MMM yyyy") — @(day.IsActive ? "Active" : "Rest")">
                                <span class="c-tooltip">@day.Date.ToString("d MMM")<br />@(day.IsActive ? "Active" : "Rest")</span>
                            </div>
                        }
                    </div>
                    <div class="consistency-stats">
                        <div class="cs-item">
                            <span class="cs-label">Current streak</span>
                            <span class="cs-val cs-success">@_streak days</span>
                        </div>
                        <div class="cs-item">
                            <span class="cs-label">Best streak</span>
                            <span class="cs-val cs-accent">@_bestStreak days</span>
                        </div>
                        <div class="cs-item">
                            <span class="cs-label">Active days</span>
                            <span class="cs-val">@_consistency.Count(c => c.IsActive)/@_consistency.Count</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        @if (_suggestions.Count > 0)
        {
            <div class="panel">
                <div class="panel-title" style="margin-bottom:16px">Progressive Overload Suggestions</div>
                <div class="suggestions-grid">
                    @foreach (var s in _suggestions)
                    {
                        <div class="sug-card">
                            <span class="sug-type">@s.Type</span>
                            <span class="sug-name">@s.ExerciseName</span>
                            <span class="sug-action">Suggestion: @s.Suggestion</span>
                            <span class="sug-reason">@s.Reason</span>
                        </div>
                    }
                </div>
            </div>
        }
    </div>
}

<Modal IsOpen="_showLogModal" OnClose="() => _showLogModal = false" Size="sm">
    <div class="log-modal">
        <h2>Log Measurements</h2>
        <div class="log-fields">
            <div class="log-field">
                <label>Weight (@WeightUnitLabel)</label>
                <input type="number" step="0.1" @bind="LogWeightDisplay" />
            </div>
            <div class="log-field">
                <label>Body Fat (%)</label>
                <input type="number" step="0.1" @bind="_logBodyFat" />
            </div>
            <div class="log-field">
                <label>Chest (cm)</label>
                <input type="number" step="0.1" @bind="_logChest" />
            </div>
            <div class="log-field">
                <label>Waist (cm)</label>
                <input type="number" step="0.1" @bind="_logWaist" />
            </div>
        </div>
        <div class="log-actions">
            <button type="button" class="btn-ghost" @onclick="() => _showLogModal = false">Cancel</button>
            <button type="button" class="btn-primary" @onclick="SaveMeasurement">Save</button>
        </div>
    </div>
</Modal>

<Modal IsOpen="_showHistoryModal" OnClose="() => _showHistoryModal = false" Size="lg">
    <div class="log-modal">
        <h2>Measurement History</h2>
        @if (_allMeasurements.Count == 0)
        {
            <div class="empty-text">No measurements logged yet.</div>
        }
        else
        {
            <div class="history-table">
                <div class="history-header">
                    <span class="history-col-date">Date</span>
                    <span class="history-col">Weight (@WeightUnitLabel)</span>
                    <span class="history-col">Body Fat</span>
                    <span class="history-col">Chest</span>
                    <span class="history-col">Waist</span>
                    <span class="history-col-action"></span>
                </div>
                @foreach (var m in _allMeasurements)
                {
                    var mRef = m;
                    var isEditing = _editingMeasId == m.Id;
                    <div class="history-row">
                        <span class="history-col-date">@m.Date.ToString("d MMM yyyy")</span>
                        @if (isEditing)
                        {
                            <span class="history-col"><input type="number" step="0.1" class="history-input" @bind="EditWeightDisplay" /></span>
                            <span class="history-col"><input type="number" step="0.1" class="history-input" @bind="_editBodyFat" /></span>
                            <span class="history-col"><input type="number" step="0.1" class="history-input" @bind="_editChest" /></span>
                            <span class="history-col"><input type="number" step="0.1" class="history-input" @bind="_editWaist" /></span>
                            <span class="history-col-action">
                                <button type="button" class="history-btn history-save" @onclick="SaveEdit" aria-label="Save"><span class="icon icon-check" aria-hidden="true"></span></button>
                                <button type="button" class="history-btn history-cancel" @onclick="() => _editingMeasId = -1" aria-label="Cancel"><span class="icon icon-x" aria-hidden="true"></span></button>
                            </span>
                        }
                        else
                        {
                            <span class="history-col">@FormatWeightValue(m.WeightKg)</span>
                            <span class="history-col">@(m.BodyFatPercent.HasValue ? $"{m.BodyFatPercent:F1}%" : "—")</span>
                            <span class="history-col">@(m.ChestCm.HasValue ? $"{m.ChestCm:F0}" : "—")</span>
                            <span class="history-col">@(m.WaistCm.HasValue ? $"{m.WaistCm:F0}" : "—")</span>
                            <span class="history-col-action">
                                <button type="button" class="history-btn history-edit" @onclick="() => StartEdit(mRef)">Edit</button>
                            </span>
                        }
                    </div>
                }
            </div>
        }
    </div>
</Modal>

@code {
    private bool _isLoading = true;
    private int _userId;
    private string _weightUnit = "kg";
    private string _energyUnit = "kcal";

    private int _totalWorkouts;
    private int _streak;
    private int _bestStreak;
    private decimal _weeklyVolume;
    private int _avgSession;
    private List<MuscleCoverageItem> _muscleCoverage = new();
    private List<WeeklyCalorieItem> _weeklyCalories = new();
    private List<PersonalRecord> _personalRecords = new();
    private List<BodyMeasurement> _measurements = new();
    private List<ConsistencyDay> _consistency = new();
    private List<OverloadSuggestion> _suggestions = new();

    private List<BodyMeasurement> _chartMeasurements = new();
    private List<PersonalRecord> _allPrs = new();
    private List<ChartSeries> _measSeries = new();
    private List<ChartExercise> _prChartExercises = new();
    private HashSet<string> _hiddenMeasSeries = new();
    private HashSet<string> _hiddenPrSeries = new();

    private bool _showLogModal;
    private decimal? _logWeight;
    private decimal? _logBodyFat;
    private decimal? _logChest;
    private decimal? _logWaist;

    private bool _showHistoryModal;
    private List<BodyMeasurement> _allMeasurements = new();
    private int _editingMeasId = -1;
    private decimal? _editWeight;
    private decimal? _editBodyFat;
    private decimal? _editChest;
    private decimal? _editWaist;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        var state = await AuthState.GetAuthenticationStateAsync();
        if (state.User.Identity is not { IsAuthenticated: true }) { try { Navigation.NavigateTo("/login", forceLoad: true); } catch { } return; }
        _userId = int.Parse(state.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)!.Value);
        var settings = await SettingsSvc.GetSettingsAsync(_userId);
        _weightUnit = settings.WeightUnit;
        _energyUnit = settings.EnergyUnit;
        await LoadData();
        _isLoading = false;
        StateHasChanged();
    }

    private async Task LoadData()
    {
        _totalWorkouts = await ProgressSvc.GetTotalWorkoutsAsync(_userId);
        _streak = await ProgressSvc.GetStreakAsync(_userId);
        _bestStreak = await ProgressSvc.GetBestStreakAsync(_userId);
        _weeklyVolume = await ProgressSvc.GetWeeklyVolumeAsync(_userId);
        _avgSession = await ProgressSvc.GetAvgSessionMinutesAsync(_userId);
        _muscleCoverage = await ProgressSvc.GetMuscleCoverageAsync(_userId);
        _weeklyCalories = await ProgressSvc.GetWeeklyCaloriesAsync(_userId);
        _personalRecords = await ProgressSvc.GetPersonalRecordsAsync(_userId);
        _measurements = await ProgressSvc.GetRecentMeasurementsAsync(_userId);
        _consistency = await ProgressSvc.GetConsistencyAsync(_userId);
        _suggestions = await ProgressSvc.GetOverloadSuggestionsAsync(_userId);
        _chartMeasurements = await ProgressSvc.GetMeasurementsForChartAsync(_userId);
        _allPrs = await ProgressSvc.GetAllPersonalRecordsAsync(_userId);
        BuildChartData();
    }

    private void BuildChartData()
    {
        _measSeries = new()
        {
            new ChartSeries { Key = "weight", Label = $"Weight ({WeightUnitLabel})", Color = "#38bdf8" },
            new ChartSeries { Key = "bodyfat", Label = "Body Fat (%)", Color = "#2ab8a0" },
            new ChartSeries { Key = "chest", Label = "Chest (cm)", Color = "#a78bfa" },
            new ChartSeries { Key = "waist", Label = "Waist (cm)", Color = "#f0c050" },
        };

        var exerciseColors = new[] { "#38bdf8", "#2ab8a0", "#a78bfa", "#f0c050", "#e05c6a", "#f472b6", "#34d399", "#fb923c" };
        _prChartExercises = _allPrs
            .Select(pr => pr.Exercise.Name)
            .Distinct()
            .Select((name, i) => new ChartExercise { Name = name, Color = exerciseColors[i % exerciseColors.Length] })
            .ToList();
    }

    private decimal? GetMeasValue(BodyMeasurement m, string key) => key switch
    {
        "weight" => SettingsService.FromKg(m.WeightKg, _weightUnit),
        "bodyfat" => m.BodyFatPercent,
        "chest" => m.ChestCm,
        "waist" => m.WaistCm,
        _ => null
    };

    private string GetMeasUnit(string key) => key switch
    {
        "weight" => WeightUnitLabel, "bodyfat" => "%", "chest" => "cm", "waist" => "cm", _ => ""
    };

    private List<ChartPoint> GetMeasPoints(string key, int w, int h, ChartPad pad)
    {
        var data = _chartMeasurements.Where(m => GetMeasValue(m, key).HasValue).ToList();
        if (data.Count == 0) return new();

        var values = data.Select(m => (double)GetMeasValue(m, key)!.Value).ToList();
        var minV = values.Min();
        var maxV = values.Max();
        var range = maxV - minV;
        if (range < 0.01) { minV -= 1; maxV += 1; range = maxV - minV; }
        minV -= range * 0.1;
        maxV += range * 0.1;

        var allDates = _chartMeasurements.Select(m => m.Date).Distinct().OrderBy(d => d).ToList();
        var minDate = allDates.First().ToDateTime(TimeOnly.MinValue).Ticks;
        var maxDate = allDates.Last().ToDateTime(TimeOnly.MinValue).Ticks;
        if (minDate == maxDate) maxDate += TimeSpan.TicksPerDay;

        var cw = w - pad.Left - pad.Right;
        var ch = h - pad.Top - pad.Bottom;
        var unit = GetMeasUnit(key);

        return data.Select(m =>
        {
            var val = (double)GetMeasValue(m, key)!.Value;
            var x = pad.Left + (double)(m.Date.ToDateTime(TimeOnly.MinValue).Ticks - minDate) / (maxDate - minDate) * cw;
            var y = pad.Top + (1 - (val - minV) / (maxV - minV)) * ch;
            return new ChartPoint { X = Math.Round(x, 1), Y = Math.Round(y, 1), Label = $"{m.Date:d MMM yyyy}: {val:F1} {unit}" };
        }).ToList();
    }

    private List<ChartPoint> GetPrPoints(string exerciseName, int w, int h, ChartPad pad)
    {
        var data = _allPrs.Where(pr => pr.Exercise.Name == exerciseName).OrderBy(pr => pr.Date).ToList();
        if (data.Count == 0) return new();

        var allVisible = _allPrs.Where(pr => !_hiddenPrSeries.Contains(pr.Exercise.Name)).ToList();
        if (allVisible.Count == 0) return new();

        var visibleValues = allVisible.Select(pr => (double)(SettingsService.FromKg(pr.WeightKg, _weightUnit) ?? pr.WeightKg)).ToList();
        var minV = visibleValues.Min() * 0.9;
        var maxV = visibleValues.Max() * 1.1;
        if (Math.Abs(maxV - minV) < 0.01) { minV -= 5; maxV += 5; }

        var minDate = allVisible.Min(pr => pr.Date).ToDateTime(TimeOnly.MinValue).Ticks;
        var maxDate = allVisible.Max(pr => pr.Date).ToDateTime(TimeOnly.MinValue).Ticks;
        if (minDate == maxDate) maxDate += TimeSpan.TicksPerDay;

        var cw = w - pad.Left - pad.Right;
        var ch = h - pad.Top - pad.Bottom;

        return data.Select(pr =>
        {
            var val = (double)(SettingsService.FromKg(pr.WeightKg, _weightUnit) ?? pr.WeightKg);
            var x = pad.Left + (double)(pr.Date.ToDateTime(TimeOnly.MinValue).Ticks - minDate) / (maxDate - minDate) * cw;
            var y = pad.Top + (1 - (val - minV) / (maxV - minV)) * ch;
            return new ChartPoint { X = Math.Round(x, 1), Y = Math.Round(y, 1), Label = $"{pr.Date:d MMM yyyy}: {FormatWeightValue(pr.WeightKg)} × {pr.Reps} reps" };
        }).ToList();
    }

    private List<AxisLabel> GetPrYLabels(int h, ChartPad pad)
    {
        var allVals = _allPrs.Where(pr => !_hiddenPrSeries.Contains(pr.Exercise.Name)).Select(pr => (double)(SettingsService.FromKg(pr.WeightKg, _weightUnit) ?? pr.WeightKg)).ToList();
        return BuildYLabels(allVals, h, pad);
    }

    private static List<AxisLabel> BuildYLabels(List<double> values, int h, ChartPad pad)
    {
        if (values.Count == 0) return new();
        var minV = values.Min() * 0.9;
        var maxV = values.Max() * 1.1;
        if (Math.Abs(maxV - minV) < 0.01) { minV -= 1; maxV += 1; }
        var ch = h - pad.Top - pad.Bottom;
        var result = new List<AxisLabel>();
        for (int i = 0; i <= 4; i++)
        {
            var val = minV + (maxV - minV) * i / 4;
            var y = pad.Top + (1 - (double)i / 4) * ch;
            result.Add(new AxisLabel { Y = Math.Round(y, 1), Label = val >= 100 ? $"{(int)val}" : $"{val:F0}" });
        }
        return result;
    }

    private List<AxisLabel> GetMeasXLabels(int w, ChartPad pad)
    {
        if (_chartMeasurements.Count == 0) return new();
        var dates = _chartMeasurements.Select(m => m.Date).Distinct().OrderBy(d => d).ToList();
        return BuildXLabels(dates, w, pad);
    }

    private List<AxisLabel> GetPrXLabels(int w, ChartPad pad)
    {
        var dates = _allPrs.Where(pr => !_hiddenPrSeries.Contains(pr.Exercise.Name)).Select(pr => pr.Date).Distinct().OrderBy(d => d).ToList();
        return BuildXLabels(dates, w, pad);
    }

    private static List<AxisLabel> BuildXLabels(List<DateOnly> dates, int w, ChartPad pad)
    {
        if (dates.Count == 0) return new();
        var cw = w - pad.Left - pad.Right;
        var minD = dates.First().ToDateTime(TimeOnly.MinValue).Ticks;
        var maxD = dates.Last().ToDateTime(TimeOnly.MinValue).Ticks;
        if (minD == maxD) maxD += TimeSpan.TicksPerDay;
        var step = Math.Max(1, dates.Count / 5);
        return dates.Where((_, i) => i % step == 0 || i == dates.Count - 1)
            .Select(d => new AxisLabel { X = Math.Round(pad.Left + (double)(d.ToDateTime(TimeOnly.MinValue).Ticks - minD) / (maxD - minD) * cw, 1), Label = d.ToString("d MMM") })
            .ToList();
    }

    private void ToggleMeasSeries(string key) { if (!_hiddenMeasSeries.Remove(key)) _hiddenMeasSeries.Add(key); }
    private void TogglePrSeries(string name) { if (!_hiddenPrSeries.Remove(name)) _hiddenPrSeries.Add(name); }

