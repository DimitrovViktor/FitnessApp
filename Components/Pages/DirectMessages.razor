@inject DirectMessageService Dm
@inject FriendService Friends
@inject ChatBroker Broker
@inject CustomAuthStateProvider AuthState
@inject NavigationManager Navigation
@inject IJSRuntime JS
@implements IDisposable

@if (_loading)
{
    <div class="loading-state">
        <p>Loading...</p>
    </div>
}
else
{
    <div class="dm">
        <aside class="dm-side">
            <div class="dm-search">
                <input type="search" class="dm-search-input" placeholder="Search people by username" value="@_search" @oninput="OnSearchInput" />
                @if (_searchResults.Count > 0)
                {
                    <div class="dm-results">
                        @foreach (var result in _searchResults)
                        {
                            <div class="dm-result" @onclick="() => StartConversation(result.Id)">
                                <span class="dm-avatar-click" @onclick="() => OpenPreview(result.Id)" @onclick:stopPropagation="true">
                                    <UserAvatar AvatarData="@result.AvatarData" Name="@result.Username" ShowStatus="true" Status="@result.Status" Size="sm" />
                                </span>
                                <div class="dm-result-text">
                                    <span class="dm-result-name">@result.Username</span>
                                    <span class="dm-result-sub">@PresenceStatus.Label(result.Status)</span>
                                </div>

                                <div class="dm-hovercard">
                                    <div class="dm-hovercard-head">
                                        <UserAvatar AvatarData="@result.Profile.AvatarData" Name="@result.Username" ShowStatus="true" Status="@result.Status" Size="lg" />
                                        <div class="dm-hovercard-id">
                                            <span class="dm-hovercard-username">@result.Username</span>
                                            @if (!string.IsNullOrWhiteSpace(result.Profile.DisplayName))
                                            {
                                                <span class="dm-hovercard-name">@result.Profile.DisplayName</span>
                                            }
                                            <span class="dm-hovercard-status">@PresenceStatus.Label(result.Status)</span>
                                        </div>
                                    </div>
                                    @if (!string.IsNullOrWhiteSpace(result.Profile.Bio))
                                    {
                                        <p class="dm-hovercard-bio">@result.Profile.Bio</p>
                                    }
                                    @if (result.Profile.Stats.Count > 0)
                                    {
                                        <div class="dm-hovercard-stats">
                                            @foreach (var stat in result.Profile.Stats)
                                            {
                                                <div class="dm-hovercard-stat">
                                                    <span class="dm-hovercard-stat-label">@stat.Label</span>
                                                    <span class="dm-hovercard-stat-value">@stat.Value</span>
                                                </div>
                                            }
                                        </div>
                                    }
                                    else if (string.IsNullOrWhiteSpace(result.Profile.Bio) && string.IsNullOrWhiteSpace(result.Profile.DisplayName))
                                    {
                                        <p class="dm-hovercard-empty">This member keeps their profile private.</p>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>

            <div class="dm-conversations">
                @if (_conversations.Count == 0)
                {
                    <p class="dm-empty-list">No conversations yet. Search a username above to start chatting.</p>
                }
                else
                {
                    @foreach (var convo in _conversations)
                    {
                        <div class="dm-convo @(convo.Id == _activeConversationId ? "active" : "")" @onclick="() => OpenConversation(convo)">
                            <span class="dm-avatar-click" @onclick="() => OpenPreview(convo.OtherUserId)" @onclick:stopPropagation="true">
                                <UserAvatar AvatarData="@convo.OtherAvatarData" Name="@convo.OtherUsername" ShowStatus="true" Status="@convo.OtherStatus" Size="md" />
                            </span>
                            <div class="dm-convo-text">
                                <span class="dm-convo-name">@convo.OtherUsername</span>
                                <span class="dm-convo-preview">@(string.IsNullOrEmpty(convo.LastMessagePreview) ? "Say hello" : convo.LastMessagePreview)</span>
                            </div>
                            @if (convo.UnreadCount > 0)
                            {
                                <span class="dm-badge">@convo.UnreadCount</span>
                            }
                        </div>
                    }
                }
            </div>
        </aside>

        <section class="dm-main">
            @if (_activeConversationId is null || _activeOther is null)
            {
                <div class="dm-placeholder">
                    <span class="dm-placeholder-icon" aria-hidden="true"></span>
                    <h2>Your messages</h2>
                    <p>Search for someone by their username to start a direct message. Hover a result to peek at their public profile.</p>
                </div>
            }
            else
            {
                <header class="dm-chat-head">
                    <span class="dm-avatar-click" @onclick="() => OpenPreview(_activeOther.OtherUserId)">
                        <UserAvatar AvatarData="@_activeOther.OtherAvatarData" Name="@_activeOther.OtherUsername" ShowStatus="true" Status="@_activeOther.OtherStatus" Size="md" />
                    </span>
                    <div class="dm-chat-head-text">
                        <span class="dm-chat-head-name">@_activeOther.OtherUsername</span>
                        <span class="dm-chat-head-status">@PresenceStatus.Label(_activeOther.OtherStatus)</span>
                    </div>
                </header>

                <div class="dm-messages" @ref="_messagesRef">
                    @if (_messages.Count == 0)
                    {
                        <div class="dm-thread-empty">This is the start of your conversation with @_activeOther.OtherUsername.</div>
                    }
                    @foreach (var message in _messages)
                    {
                        var mine = message.SenderId == _userId;
                        var selectable = mine && !message.IsDeleted && _editingMessageId != message.Id;
                        <div class="dm-msg @(mine ? "mine" : "theirs")">
                            <div class="dm-bubble @(selectable ? "selectable" : "")" @onclick="() => ToggleActions(message.Id, selectable)">
                                @if (message.IsDeleted)
                                {
                                    <span class="dm-deleted">This message was deleted</span>
                                    <span class="dm-meta"><span class="dm-time">@FormatTime(message.CreatedAt)</span></span>
                                }
                                else if (_editingMessageId == message.Id)
                                {
                                    <div class="dm-edit">
                                        <textarea class="dm-edit-input" value="@_editDraft" @oninput="OnEditInput" @onkeydown="HandleEditKeyDown"></textarea>
                                        <div class="dm-edit-actions">
                                            <button type="button" class="dm-edit-cancel" @onclick="CancelEdit" @onclick:stopPropagation="true">Cancel</button>
                                            <button type="button" class="dm-edit-save" @onclick="SaveEdit" @onclick:stopPropagation="true" disabled="@(string.IsNullOrWhiteSpace(_editDraft))">Save</button>
                                        </div>
                                    </div>
                                }
                                else
                                {
                                    @if (!string.IsNullOrEmpty(message.AttachmentData))
                                    {
                                        @if (message.IsImage)
                                        {
                                            <a class="dm-image" href="@message.AttachmentData" target="_blank" rel="noopener" @onclick:stopPropagation="true">
                                                <img src="@message.AttachmentData" alt="@message.AttachmentName" />
                                            </a>
                                        }
                                        else
                                        {
                                            <a class="dm-file" href="@message.AttachmentData" download="@message.AttachmentName" @onclick:stopPropagation="true">
                                                <span class="dm-file-icon" aria-hidden="true"></span>
                                                <span class="dm-file-meta">
                                                    <span class="dm-file-name">@message.AttachmentName</span>
                                                    <span class="dm-file-size">@FormatSize(message.AttachmentSize)</span>
                                                </span>
                                            </a>
                                        }
                                    }
                                    @if (!string.IsNullOrEmpty(message.Content))
                                    {
                                        <span class="dm-text">@message.Content</span>
                                    }
                                    <span class="dm-meta">
                                        <span class="dm-time">@FormatTime(message.CreatedAt)</span>
                                        @if (message.IsEdited)
                                        {
                                            <span class="dm-edited">edited</span>
                                        }
                                    </span>
                                    @if (selectable && _selectedMessageId == message.Id)
                                    {
                                        <div class="dm-actions">
                                            @if (!string.IsNullOrEmpty(message.Content))
                                            {
                                                <button type="button" class="dm-action" @onclick="() => StartEdit(message)" @onclick:stopPropagation="true">Edit</button>
                                            }
                                            <button type="button" class="dm-action dm-action-danger" @onclick="() => DeleteMessage(message.Id)" @onclick:stopPropagation="true">Delete</button>
                                        </div>
                                    }
                                }
                            </div>
                        </div>
                    }
                </div>

                <div class="dm-composer">
                    @if (_pendingAttachment is not null)
                    {
                        <div class="dm-attach-preview">
                            @if (_pendingAttachment.IsImage)
                            {
                                <img class="dm-attach-thumb" src="@_pendingAttachment.Data" alt="@_pendingAttachment.Name" />
                            }
                            else
                            {
                                <span class="dm-attach-fileicon" aria-hidden="true"></span>
                            }
                            <div class="dm-attach-meta">
                                <span class="dm-attach-name">@_pendingAttachment.Name</span>
                                <span class="dm-attach-size">@FormatSize(_pendingAttachment.Size)</span>
                            </div>
                            <button type="button" class="dm-attach-remove" @onclick="RemoveAttachment" aria-label="Remove attachment">Remove</button>
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(_attachmentError))
                    {
                        <p class="dm-attach-error">@_attachmentError</p>
                    }
                    <div class="dm-composer-row">
                        <label class="dm-attach-btn" title="Attach image or file" aria-label="Attach image or file">
                            <span class="dm-attach-btn-icon" aria-hidden="true"></span>
                            <InputFile OnChange="OnAttachmentSelected" accept="image/*,.pdf,.txt,.zip,.csv,.doc,.docx,.xls,.xlsx" />
                        </label>
                        <textarea @ref="_composerRef" class="dm-input" rows="1" placeholder="Message @_activeOther.OtherUsername" value="@_draft" @oninput="OnDraftInput"></textarea>
                        <button type="button" class="dm-send" @onclick="SendMessage" disabled="@(_sending || (string.IsNullOrWhiteSpace(_draft) && _pendingAttachment is null))">Send</button>
                    </div>
                </div>
            }
        </section>
    </div>

    @if (_previewUserId is not null)
    {
        <div class="dm-preview-overlay" @onclick="ClosePreview">
            <div class="dm-preview" @onclick:stopPropagation="true">
                <button type="button" class="dm-preview-close" @onclick="ClosePreview" aria-label="Close">Close</button>

                @if (_previewLoading || _preview is null)
                {
                    <div class="dm-preview-loading">Loading profile...</div>
                }
                else
                {
                    <div class="dm-preview-head">
                        <UserAvatar AvatarData="@_preview.Profile.AvatarData" Name="@_preview.Profile.Username" ShowStatus="true" Status="@_preview.Profile.Status" Size="lg" />
                        <div class="dm-preview-id">
                            <span class="dm-preview-username">@_preview.Profile.Username</span>
                            @if (!string.IsNullOrWhiteSpace(_preview.Profile.DisplayName))
                            {
                                <span class="dm-preview-name">@_preview.Profile.DisplayName</span>
                            }
                            <span class="dm-preview-status">@PresenceStatus.Label(_preview.Profile.Status)</span>
                        </div>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(_preview.Profile.Bio))
                    {
                        <p class="dm-preview-bio">@_preview.Profile.Bio</p>
                    }

                    @if (_preview.Profile.Stats.Count > 0)
                    {
                        <div class="dm-preview-stats">
                            @foreach (var stat in _preview.Profile.Stats)
                            {
                                <div class="dm-preview-stat">
                                    <span class="dm-preview-stat-label">@stat.Label</span>
                                    <span class="dm-preview-stat-value">@stat.Value</span>
                                </div>
                            }
                        </div>
                    }
                    else if (string.IsNullOrWhiteSpace(_preview.Profile.Bio) && string.IsNullOrWhiteSpace(_preview.Profile.DisplayName))
                    {
                        <p class="dm-preview-empty">This member keeps their profile private.</p>
                    }

                    <div class="dm-preview-actions">
                        <button type="button" class="dm-preview-btn dm-preview-btn-primary" @onclick="MessageFromPreview">Message</button>

                        @switch (_preview.Friendship)
                        {
                            case FriendshipState.None:
                                <button type="button" class="dm-preview-btn" @onclick="AddFriend" disabled="@_previewBusy">Add friend</button>
                                break;
                            case FriendshipState.Outgoing:
                                <button type="button" class="dm-preview-btn" @onclick="RemoveFriend" disabled="@_previewBusy">Cancel request</button>
                                break;
                            case FriendshipState.Incoming:
                                <button type="button" class="dm-preview-btn" @onclick="AcceptFriend" disabled="@_previewBusy">Accept request</button>
                                break;
                            case FriendshipState.Friends:
                                <button type="button" class="dm-preview-btn dm-preview-btn-danger" @onclick="RemoveFriend" disabled="@_previewBusy">Remove friend</button>
                                break;
                        }
                    </div>

                    @if (_preview.Friendship == FriendshipState.Friends)
                    {
                        <p class="dm-preview-note">You are friends</p>
                    }
                    else if (_preview.Friendship == FriendshipState.Outgoing)
                    {
                        <p class="dm-preview-note">Friend request sent</p>
                    }
                }
            </div>
        </div>
    }
}

@code {
    private bool _loading = true;
    private int _userId;
    private string _username = "";

    private List<ConversationDto> _conversations = new();
    private string _search = "";
    private List<UserSearchResult> _searchResults = new();

    private int? _activeConversationId;
    private ConversationDto? _activeOther;
    private List<ChatMessageDto> _messages = new();

    private string _draft = "";
    private AttachmentInput? _pendingAttachment;
    private string? _attachmentError;
    private bool _sending;

    private int? _editingMessageId;
    private string _editDraft = "";
    private int? _selectedMessageId;

    private bool _scrollPending;
    private ElementReference _messagesRef;
    private ElementReference _composerRef;
    private DotNetObjectReference<DirectMessages>? _dotNetRef;
    private int? _boundComposerConversation;
    private IDisposable? _subscription;

    private int? _previewUserId;
    private bool _previewLoading;
    private bool _previewBusy;
    private ProfilePreviewDto? _preview;

    private const long MaxAttachmentBytes = 5 * 1024 * 1024;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var state = await AuthState.GetAuthenticationStateAsync();
            if (state.User.Identity is not { IsAuthenticated: true })
            {
                try { Navigation.NavigateTo("/login", forceLoad: true); } catch { }
                return;
            }

            _userId = int.Parse(state.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)!.Value);
            _username = state.User.FindFirst("Username")?.Value ?? state.User.Identity.Name ?? "User";
            _conversations = await Dm.GetConversationsAsync(_userId);
            _subscription = Broker.Subscribe(_userId, OnBrokerEvent);
            Navigation.LocationChanged += OnLocationChanged;
            _loading = false;
            StateHasChanged();
            await TryOpenFromQuery();
            return;
        }

        if (_activeConversationId is not null && _boundComposerConversation != _activeConversationId)
        {
            _boundComposerConversation = _activeConversationId;
            _dotNetRef ??= DotNetObjectReference.Create(this);
            try { await JS.InvokeVoidAsync("chatComposerInit", _composerRef, _dotNetRef); } catch { }
        }

        if (_scrollPending && _activeConversationId is not null)
        {
            _scrollPending = false;
            try { await JS.InvokeVoidAsync("chatScrollToBottom", _messagesRef); } catch { }
        }
    }

    [JSInvokable]
    public async Task ComposerSend(string currentText)
    {
        _draft = currentText;
        await SendMessage();
        StateHasChanged();
    }

    private async Task OnSearchInput(ChangeEventArgs e)
    {
        _search = e?.Value?.ToString() ?? "";
        if (_search.Trim().Length == 0)
        {
            _searchResults = new();
            return;
        }
        _searchResults = await Dm.SearchUsersAsync(_userId, _search);
    }

    private void OnDraftInput(ChangeEventArgs e) => _draft = e?.Value?.ToString() ?? "";

    private async Task StartConversation(int otherId)
    {
        var convo = await Dm.GetOrCreateConversationAsync(_userId, otherId);
        if (convo is null) return;

        _search = "";
        _searchResults = new();

        var existing = _conversations.FirstOrDefault(c => c.Id == convo.Id);
        if (existing is null)
            _conversations = _conversations.Prepend(convo).ToList();
        else
            convo = existing;

        await OpenConversation(convo);
    }

    private async Task OpenConversation(ConversationDto convo)
    {
        _activeConversationId = convo.Id;
        _activeOther = convo;
        _selectedMessageId = null;
        _editingMessageId = null;
        _editDraft = "";
        _messages = await Dm.GetMessagesAsync(_userId, convo.Id);
        await Dm.MarkReadAsync(_userId, convo.Id);
        _conversations = _conversations.Select(c => c.Id == convo.Id ? c with { UnreadCount = 0 } : c).ToList();
        _scrollPending = true;
    }

    private async Task SendMessage()
    {
        if (_sending || _activeConversationId is null || _activeOther is null) return;

        var text = _draft?.Trim() ?? "";
        if (text.Length == 0 && _pendingAttachment is null) return;

        var conversationId = _activeConversationId.Value;
        var otherId = _activeOther.OtherUserId;
        var attachment = _pendingAttachment;

        _sending = true;
        _draft = "";
        _pendingAttachment = null;
        _attachmentError = null;
        StateHasChanged();

        var dto = await Dm.SendMessageAsync(_userId, conversationId, text, attachment);
        _sending = false;

        if (dto is null) return;
        Broker.Publish(new ChatEvent(conversationId, _userId, otherId, dto));
    }

    private void ToggleActions(int messageId, bool selectable)
    {
        if (!selectable) return;
        _selectedMessageId = _selectedMessageId == messageId ? null : messageId;
    }

    private void StartEdit(ChatMessageDto message)
    {
        _selectedMessageId = null;
        _editingMessageId = message.Id;
        _editDraft = message.Content ?? "";
    }

    private void CancelEdit()
    {
        _editingMessageId = null;
        _editDraft = "";
    }

    private void OnEditInput(ChangeEventArgs e) => _editDraft = e?.Value?.ToString() ?? "";

    private void HandleEditKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Escape") CancelEdit();
    }

    private async Task SaveEdit()
    {
        if (_editingMessageId is null) return;

        var messageId = _editingMessageId.Value;
        var text = _editDraft?.Trim() ?? "";
        if (text.Length == 0) return;

        var dto = await Dm.EditMessageAsync(_userId, messageId, text);
        _editingMessageId = null;
        _editDraft = "";
        if (dto is null) return;

        Broker.Publish(new ChatEvent(dto.ConversationId, _userId, _activeOther?.OtherUserId ?? 0, dto, ChatEventKind.Updated));
    }

    private async Task DeleteMessage(int messageId)
    {
        _selectedMessageId = null;
        var dto = await Dm.DeleteMessageAsync(_userId, messageId);
        if (dto is null) return;

        Broker.Publish(new ChatEvent(dto.ConversationId, _userId, _activeOther?.OtherUserId ?? 0, dto, ChatEventKind.Updated));
    }

    private async Task OnAttachmentSelected(InputFileChangeEventArgs e)
    {
        _attachmentError = null;
        var file = e.File;
        if (file is null) return;

        if (file.Size > MaxAttachmentBytes)
        {
            _attachmentError = "Files must be 5 MB or smaller.";
            return;
        }

        try
        {
            using var stream = file.OpenReadStream(MaxAttachmentBytes);
            using var ms = new MemoryStream();
            await stream.CopyToAsync(ms);
            var contentType = string.IsNullOrEmpty(file.ContentType) ? "application/octet-stream" : file.ContentType;
            _pendingAttachment = new AttachmentInput
            {
                Data = $"data:{contentType};base64,{Convert.ToBase64String(ms.ToArray())}",
                Name = file.Name,
                Type = contentType,
                IsImage = contentType.StartsWith("image/", StringComparison.OrdinalIgnoreCase),
                Size = file.Size
            };
        }
        catch
        {
            _attachmentError = "Could not read that file. Please try another.";
        }
    }

    private void RemoveAttachment()
    {
        _pendingAttachment = null;
        _attachmentError = null;
    }

    private void OnBrokerEvent(ChatEvent message)
    {
        _ = InvokeAsync(async () =>
        {
            await ApplyIncomingAsync(message);
            StateHasChanged();
        });
    }

    private async Task ApplyIncomingAsync(ChatEvent message)
    {
        var isActive = _activeConversationId == message.ConversationId;
        var fromMe = message.Message.SenderId == _userId;

        if (message.Kind == ChatEventKind.Updated)
        {
            if (isActive)
            {
                var index = _messages.FindIndex(m => m.Id == message.Message.Id);
                if (index >= 0) _messages[index] = message.Message;
                if (_editingMessageId == message.Message.Id)
                {
                    _editingMessageId = null;
                    _editDraft = "";
                }
                if (_selectedMessageId == message.Message.Id) _selectedMessageId = null;
            }
            _conversations = await Dm.GetConversationsAsync(_userId);
            return;
        }

        if (isActive)
        {
            if (_messages.All(m => m.Id != message.Message.Id))
            {
                _messages.Add(message.Message);
                _scrollPending = true;
            }
            if (!fromMe)
                await Dm.MarkReadAsync(_userId, message.ConversationId);
        }

        var convo = _conversations.FirstOrDefault(c => c.Id == message.ConversationId);
        if (convo is null)
        {
            _conversations = await Dm.GetConversationsAsync(_userId);
            return;
        }

        var unread = convo.UnreadCount;
        if (isActive) unread = 0;
        else if (!fromMe) unread += 1;

        var updated = convo with
        {
            LastMessagePreview = PreviewFor(message.Message),
            LastMessageAt = message.Message.CreatedAt,
            UnreadCount = unread
        };
        _conversations = _conversations.Where(c => c.Id != convo.Id).Prepend(updated).ToList();
    }

    private static string PreviewFor(ChatMessageDto message)
    {
        if (message.IsDeleted) return "Message deleted";
        if (!string.IsNullOrWhiteSpace(message.Content)) return message.Content!;
        if (message.IsImage) return "Photo";
        return string.IsNullOrWhiteSpace(message.AttachmentName) ? "Attachment" : message.AttachmentName!;
    }

    private async Task OpenPreview(int userId)
    {
        if (userId == _userId) return;
        _previewUserId = userId;
        _preview = null;
        _previewLoading = true;
        StateHasChanged();

        _preview = await Dm.GetProfilePreviewAsync(_userId, userId);
        _previewLoading = false;
        StateHasChanged();
    }

    private void ClosePreview()
    {
        _previewUserId = null;
        _preview = null;
        _previewBusy = false;
    }

    private async Task AddFriend()
    {
        if (_previewUserId is null || _preview is null || _previewBusy) return;
        _previewBusy = true;
        var state = await Friends.SendRequestAsync(_userId, _previewUserId.Value);
        if (_preview is not null) _preview = _preview with { Friendship = state };
        _previewBusy = false;
    }

    private async Task AcceptFriend()
    {
        if (_previewUserId is null || _preview is null || _previewBusy) return;
        _previewBusy = true;
        var state = await Friends.AcceptRequestAsync(_userId, _previewUserId.Value);
        if (_preview is not null) _preview = _preview with { Friendship = state };
        _previewBusy = false;
    }

    private async Task RemoveFriend()
    {
        if (_previewUserId is null || _preview is null || _previewBusy) return;
        _previewBusy = true;
        var state = await Friends.RemoveAsync(_userId, _previewUserId.Value);
        if (_preview is not null) _preview = _preview with { Friendship = state };
        _previewBusy = false;
    }

    private async Task MessageFromPreview()
    {
        if (_previewUserId is null) return;
        var target = _previewUserId.Value;
        ClosePreview();
        await StartConversation(target);
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        _ = InvokeAsync(TryOpenFromQuery);
    }

    private async Task TryOpenFromQuery()
    {
        var id = ReadDmParam();
        if (id is null) return;

        Navigation.NavigateTo("social", replace: true);
        await StartConversation(id.Value);
        StateHasChanged();
    }

    private int? ReadDmParam()
    {
        var query = new Uri(Navigation.Uri).Query;
        if (string.IsNullOrEmpty(query)) return null;

        foreach (var pair in query.TrimStart('?').Split('&', StringSplitOptions.RemoveEmptyEntries))
        {
            var kv = pair.Split('=', 2);
            if (kv.Length == 2 && kv[0] == "dm" && int.TryParse(kv[1], out var id))
                return id;
        }
        return null;
    }

    private static string FormatTime(DateTime utc) => utc.ToLocalTime().ToString("HH:mm");

    private static string FormatSize(long bytes)
    {
        if (bytes <= 0) return "";
        if (bytes < 1024) return $"{bytes} B";
        if (bytes < 1024 * 1024) return $"{bytes / 1024d:0.#} KB";
        return $"{bytes / (1024d * 1024d):0.#} MB";
    }

    public void Dispose()
    {
        Navigation.LocationChanged -= OnLocationChanged;
        _subscription?.Dispose();
        _dotNetRef?.Dispose();
    }
}
