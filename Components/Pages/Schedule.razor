        builder.CloseElement();
    };

    private string FormatWeightValue(decimal? weightKg) => SettingsService.FormatWeight(weightKg, _weightUnit);

    private string FormatEnergyValue(decimal calories) => SettingsService.FormatEnergy(calories, _energyUnit);

    private string FormatSelectedDate()
    {
        var today = DateOnly.FromDateTime(DateTime.Now);
        if (_selectedDate == today) return $"Today — {_selectedDate:dddd, d MMM}";
        if (_selectedDate == today.AddDays(-1)) return $"Yesterday — {_selectedDate:dddd, d MMM}";
        if (_selectedDate == today.AddDays(1)) return $"Tomorrow — {_selectedDate:dddd, d MMM}";
        return _selectedDate.ToString("dddd, d MMM yyyy");
    }

    private static string FormatDuration(DateTime start, DateTime? end)
    {
        if (end is null) return "—";
        var elapsed = end.Value - start;
        return elapsed.TotalHours >= 1 ? $"{(int)elapsed.TotalHours}h {elapsed.Minutes}m" : $"{(int)elapsed.TotalMinutes}m";
    }

    private static string FormatLogStatus(WorkoutLogStatus status) => status switch
    {
        WorkoutLogStatus.Complete => "Complete",
        WorkoutLogStatus.Modified => "Modified",
        WorkoutLogStatus.Partial => "Partial",
        _ => ""
    };

    private static string FormatScheduleStatus(ScheduleStatus status) => status switch
    {
        ScheduleStatus.InProgress => "In progress",
        ScheduleStatus.Postponed => "Postponed",
        ScheduleStatus.Completed => "Completed",
        ScheduleStatus.Cancelled => "Skipped",
        _ => "Scheduled"
    };

    private static string GetProgramType(FitnessApp.Models.Program program)
    {
        var tags = program.Tags ?? "";
        if (tags.Contains("cardio", StringComparison.OrdinalIgnoreCase)) return "Cardio";
        if (tags.Contains("hybrid", StringComparison.OrdinalIgnoreCase)) return "Hybrid";
        return "Workout";
    }

    private static string GetWorkoutKind(Workout workout)
    {
        var tags = workout.Program?.Tags ?? "";
        if (tags.Contains("cardio", StringComparison.OrdinalIgnoreCase)) return "Cardio";
        if (tags.Contains("hybrid", StringComparison.OrdinalIgnoreCase)) return "Hybrid";
        var hasCardio = workout.WorkoutExercises.Any(x => x.Exercise?.MovementType == MovementType.Cardio);
        var hasStrength = workout.WorkoutExercises.Any(x => x.Exercise is not null && x.Exercise.MovementType != MovementType.Cardio);
        if (hasCardio && hasStrength) return "Hybrid";
        if (hasCardio) return "Cardio";
        return "Strength";
    }

    private static string GetWorkoutKindClass(Workout workout) => $"kind-{GetWorkoutKind(workout).ToLowerInvariant()}";

    private static DateOnly StartOfWeek(DateOnly date)
    {
        var diff = ((int)date.DayOfWeek + 6) % 7;
        return date.AddDays(-diff);
    }

