    private RenderFragment RenderRating(string label, int? current, Action<int> setValue) => builder =>
    {
        var seq = 0;
        builder.OpenElement(seq++, "div");
        builder.AddAttribute(seq++, "class", "rating-group");
        builder.OpenElement(seq++, "span");
        builder.AddAttribute(seq++, "class", "rating-label");
        builder.AddContent(seq++, label);
        builder.CloseElement();
        builder.OpenElement(seq++, "div");
        builder.AddAttribute(seq++, "class", "rating-dots");
        for (var i = 1; i <= 5; i++)
        {
            var val = i;
            builder.OpenElement(seq++, "button");
            builder.AddAttribute(seq++, "type", "button");
            builder.AddAttribute(seq++, "class", $"r-dot {(current == val ? "r-active" : "")}");
            builder.AddAttribute(seq++, "onclick", EventCallback.Factory.Create(this, () => setValue(val)));
            builder.AddContent(seq++, val);
