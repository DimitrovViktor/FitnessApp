@page "/profile"
@inject ProfileService ProfileService
@inject SettingsService SettingsSvc
@inject CustomAuthStateProvider AuthState
@inject NavigationManager Navigation
@inject ProfilePresenceState Presence
@implements IDisposable

<PageTitle>Profile - Fitness App</PageTitle>

@if (_isLoading)
{
    <div class="loading-state">
        <p>Loading...</p>
    </div>
}
else
{
    <div class="profile-page">
        <div class="profile-header">
            <h1>Profile</h1>
            <p class="profile-subtitle">Manage how you appear to others and what you share</p>
        </div>

        @if (!string.IsNullOrEmpty(_message))
        {
            <div class="@(_isError ? "msg-error" : "msg-success")">@_message</div>
        }

        <div class="profile-section">
            <div class="preview-head">
                <div>
                    <h2 class="section-title">Public Preview</h2>
                    <p class="section-hint">This is how your profile looks to @(_previewFriends ? "friends" : "everyone"). Fields you keep private stay hidden.</p>
                </div>
                <div class="preview-audience">
                    <button type="button" class="audience-btn @(!_previewFriends ? "selected" : "")" @onclick="() => _previewFriends = false">Everyone</button>
                    <button type="button" class="audience-btn @(_previewFriends ? "selected" : "")" @onclick="() => _previewFriends = true">Friends</button>
                </div>
            </div>

            <div class="preview-card">
                <div class="preview-banner"></div>
                <div class="preview-identity">
                    <span class="preview-avatar">
                        @if (!string.IsNullOrEmpty(_avatarData))
                        {
                            <img src="@_avatarData" alt="Profile picture" />
                        }
                        else
                        {
                            <span class="preview-avatar-initials">@Initials</span>
                        }
                        <span class="preview-status-dot status-@_status" title="@PresenceStatus.Label(_status)"></span>
                    </span>
                    <div class="preview-names">
                        <span class="preview-username">@_username</span>
                        @if (IsVisibleInPreview("name") && !string.IsNullOrWhiteSpace(_data.FullName))
                        {
                            <span class="preview-realname">@_data.FullName</span>
                        }
                        <span class="preview-status-label">@PresenceStatus.Label(_status)</span>
                    </div>
                </div>

                @if (IsVisibleInPreview("bio") && !string.IsNullOrWhiteSpace(_data.Bio))
                {
                    <p class="preview-bio">@_data.Bio</p>
                }

                @{
                    var visibleStats = GridFields.Where(f => IsVisibleInPreview(f.Key) && !string.IsNullOrEmpty(PreviewValue(f.Key))).ToList();
                }
                @if (visibleStats.Count > 0)
                {
                    <div class="preview-grid">
                        @foreach (var field in visibleStats)
                        {
                            <div class="preview-stat">
                                <span class="preview-stat-label">@field.Label</span>
                                <span class="preview-stat-value">@PreviewValue(field.Key)</span>
                            </div>
                        }
                    </div>
                }

                @if (visibleStats.Count == 0 && !(IsVisibleInPreview("name") && !string.IsNullOrWhiteSpace(_data.FullName)) && !(IsVisibleInPreview("bio") && !string.IsNullOrWhiteSpace(_data.Bio)))
                {
                    <p class="preview-empty">Only your username and picture are visible @(_previewFriends ? "to friends" : "to everyone") right now. Make fields public below to share more.</p>
                }
            </div>
        </div>

        <div class="profile-section">
            <h2 class="section-title">Profile Picture</h2>
            <div class="avatar-manage">
                <span class="avatar-current">
                    @if (!string.IsNullOrEmpty(_avatarData))
                    {
                        <img src="@_avatarData" alt="Profile picture" />
                    }
                    else
                    {
                        <span class="avatar-current-initials">@Initials</span>
                    }
                </span>
                <div class="avatar-side">
                    <div class="avatar-actions">
                        <label class="avatar-upload-btn">
                            <span>Upload photo</span>
                            <InputFile OnChange="OnAvatarSelected" accept="image/png, image/jpeg, image/webp, image/gif" />
                        </label>
                        @if (!string.IsNullOrEmpty(_avatarData))
                        {
                            <button type="button" class="avatar-remove-btn" @onclick="RemoveAvatar">Remove</button>
                        }
                    </div>
                    <p class="avatar-hint">PNG, JPG, WEBP or GIF up to 2 MB. Your picture and username are always visible to others.</p>
                    @if (!string.IsNullOrEmpty(_avatarError))
                    {
                        <p class="avatar-error">@_avatarError</p>
                    }
                </div>
            </div>
        </div>

        <div class="profile-section">
            <h2 class="section-title">Status</h2>
            <p class="section-hint">Set how you appear to other people across the app.</p>
            <div class="status-options">
                @foreach (var option in PresenceStatus.Options)
                {
                    <button type="button" class="status-pill @(_status == option.Key ? "selected" : "")" @onclick="() => SetStatus(option.Key)">
                        <span class="status-dot status-@option.Key"></span>
                        <span>@option.Label</span>
                    </button>
                }
            </div>
        </div>

        <div class="profile-section">
            <h2 class="section-title">Privacy &amp; Visibility</h2>
            <p class="section-hint">Choose who can see each part of your profile. Not selected stays private by default.</p>
            <div class="vis-list">
                @foreach (var field in VisFields)
                {
                    var current = GetVisibility(field.Key);
                    <div class="vis-row">
                        <div class="vis-info">
                            <span class="vis-label">@field.Label</span>
                            <span class="vis-hint">@field.Hint</span>
                        </div>
                        <div class="vis-options">
                            @foreach (var option in VisOptions)
                            {
                                <button type="button" class="vis-opt vis-@option.Key @(current == option.Key ? "active" : "")" @onclick="() => SetVisibility(field.Key, option.Key)">
                                    @option.Label
                                </button>
                            }
                        </div>
                    </div>
                }
            </div>
        </div>

        <div class="profile-section">
            <h2 class="section-title">About You</h2>

            <div class="field-grid">
                <div class="form-group">
                    <label class="form-label">Full Name</label>
                    <input class="form-input" @bind="_data.FullName" disabled="@(!_isEditing)" />
                </div>
                <div class="form-group">
                    <label class="form-label">Date of Birth</label>
                    <input type="date" class="form-input" value="@_dobString" @onchange="OnDobChanged" max="@_maxDob" min="@_minDob" disabled="@(!_isEditing)" />
                </div>
                <div class="form-group">
                    <label class="form-label">Weight (@_weightUnit)</label>
                    <input type="number" class="form-input" @bind="DisplayWeight" min="@MinWeight" max="@MaxWeight" step="0.1" disabled="@(!_isEditing)" />
                </div>
                <div class="form-group">
                    <label class="form-label">Height (cm)</label>
                    <input type="number" class="form-input" @bind="_data.HeightCm" min="100" max="250" step="0.1" disabled="@(!_isEditing)" />
                </div>
            </div>
        </div>

        <div class="profile-section">
            <h2 class="section-title">Fitness Profile</h2>

            <div class="form-group">
                <label class="form-label">Fitness Level</label>
                <div class="option-group">
                    @foreach (var level in Enum.GetValues<FitnessLevel>())
                    {
                        <button type="button"
                                class="option-btn @(_data.FitnessLevel == level ? "selected" : "")"
                                disabled="@(!_isEditing)"
                                @onclick="() => _data.FitnessLevel = level">
                            @level
                        </button>
                    }
                </div>
            </div>

            <div class="form-group">
                <label class="form-label">Primary Goal</label>
                <div class="option-group">
                    @foreach (var goal in Enum.GetValues<PrimaryGoal>())
                    {
                        <button type="button"
                                class="option-btn @(_data.PrimaryGoal == goal ? "selected" : "")"
                                disabled="@(!_isEditing)"
                                @onclick="() => _data.PrimaryGoal = goal">
                            @FormatGoal(goal)
                        </button>
                    }
                </div>
            </div>

            <div class="form-group">
                <label class="form-label">Training Days Per Week</label>
                <div class="option-group">
                    @for (int d = 1; d <= 7; d++)
                    {
                        var day = d;
                        <button type="button"
                                class="option-btn option-btn-sm @(_data.TrainingDaysPerWeek == day ? "selected" : "")"
                                disabled="@(!_isEditing)"
                                @onclick="() => _data.TrainingDaysPerWeek = day">
                            @day
                        </button>
                    }
                </div>
            </div>
        </div>

        <div class="profile-section">
            <h2 class="section-title">Available Equipment</h2>

            <div class="equipment-grid">
                @foreach (var eq in _equipment)
                {
                    var isSelected = _data.SelectedEquipmentIds.Contains(eq.Id);
                    <button type="button"
                            class="equipment-btn @(isSelected ? "selected" : "")"
                            disabled="@(!_isEditing)"
                            @onclick="() => ToggleEquipment(eq.Id)">
                        @eq.Name
                    </button>
                }
            </div>
        </div>

        <div class="profile-section">
            <h2 class="section-title">Injuries &amp; Limitations</h2>

            @if (_data.Injuries.Count == 0 && !_isEditing)
            {
                <p class="empty-text">No injuries or limitations recorded.</p>
            }

            @foreach (var injury in _data.Injuries)
            {
                var idx = _data.Injuries.IndexOf(injury);
                <div class="injury-row">
                    <div class="injury-fields">
                        <div class="form-group">
                            <label class="form-label">Description</label>
                            <input class="form-input" @bind="_data.Injuries[idx].Description" disabled="@(!_isEditing)" />
                        </div>
                        <div class="form-group">
                            <label class="form-label">Affected Area</label>
                            <input class="form-input" @bind="_data.Injuries[idx].AffectedArea" disabled="@(!_isEditing)" />
                        </div>
                    </div>
                    @if (_isEditing)
                    {
                        <button type="button" class="remove-btn" @onclick="() => RemoveInjury(idx)">Remove</button>
                    }
                </div>
            }

            @if (_isEditing)
            {
                <button type="button" class="add-btn" @onclick="AddInjury">+ Add Injury</button>
            }
        </div>

        <div class="profile-section">
            <h2 class="section-title">Bio</h2>
            <div class="form-group">
                <textarea class="form-input form-textarea" @bind="_data.Bio" rows="3" disabled="@(!_isEditing)" placeholder="Tell us about yourself..."></textarea>
            </div>
        </div>

        <div class="profile-actions">
            @if (_isEditing)
            {
                <button type="button" class="btn-cancel" @onclick="CancelEdit">Cancel</button>
                <button type="button" class="btn-save" @onclick="SaveProfile" disabled="@_isSaving">
                    @(_isSaving ? "Saving..." : "Save Changes")
                </button>
            }
            else
            {
                <button type="button" class="btn-edit" @onclick="StartEdit">Edit Details</button>
            }
        </div>
    </div>
}

@code {
    private ProfileData _data = new();
    private ProfileData _backup = new();
    private List<Equipment> _equipment = new();
    private bool _isLoading = true;
    private bool _isEditing;
    private bool _isSaving;
    private string? _message;
    private bool _isError;
    private int _userId;
    private string _weightUnit = "kg";
    private string _dobString = "";
    private string _dobBackup = "";
    private readonly string _maxDob = DateOnly.FromDateTime(DateTime.Today.AddYears(-13)).ToString("yyyy-MM-dd");
    private readonly string _minDob = DateOnly.FromDateTime(DateTime.Today.AddYears(-100)).ToString("yyyy-MM-dd");

    private User? _user;
    private ProfileSettings _settings = new();
    private string _username = "";
    private string _status = PresenceStatus.Online;
    private string? _avatarData;
    private string? _avatarError;
    private bool _previewFriends;

    private record VisField(string Key, string Label, string Hint);

    private static readonly VisField[] VisFields =
    {
        new("name", "Display name", "Your full name"),
        new("bio", "Bio", "The short blurb on your profile"),
        new("level", "Fitness level", "Beginner, intermediate or advanced"),
        new("goal", "Primary goal", "What you are training for"),
        new("trainingDays", "Training days", "How many days a week you train"),
        new("weight", "Weight", "Your body weight"),
        new("height", "Height", "Your height"),
        new("age", "Age", "Calculated from your date of birth"),
        new("memberSince", "Member since", "When you joined"),
        new("workouts", "Workouts", "Workouts you post publicly")
    };

    private static readonly VisField[] GridFields =
    {
        new("level", "Fitness level", ""),
        new("goal", "Primary goal", ""),
        new("trainingDays", "Training", ""),
        new("weight", "Weight", ""),
        new("height", "Height", ""),
        new("age", "Age", ""),
        new("memberSince", "Member since", "")
    };

    private static readonly (string Key, string Label)[] VisOptions =
    {
        ("notset", "Not selected"),
        ("public", "Public"),
        ("friends", "Friends only"),
        ("private", "Private")
    };

    private string Initials
    {
        get
        {
            var source = string.IsNullOrWhiteSpace(_username) ? "?" : _username.Trim();
            return source.Length == 0 ? "?" : source[..1].ToUpperInvariant();
        }
    }

    private string AgeText
    {
        get
        {
            if (_data.DateOfBirth is null) return "";
            var today = DateOnly.FromDateTime(DateTime.Today);
            var dob = _data.DateOfBirth.Value;
            var age = today.Year - dob.Year;
            if (dob > today.AddYears(-age)) age--;
            return age > 0 ? $"{age} years" : "";
        }
    }

    private string MemberSinceText => _user is null ? "" : _user.CreatedAt.ToLocalTime().ToString("MMM yyyy");

    private decimal? DisplayWeight
    {
        get => SettingsService.FromKg(_data.WeightKg, _weightUnit);
        set => _data.WeightKg = SettingsService.ToKg(value, _weightUnit);
    }

    private decimal MinWeight => _weightUnit == "lbs" ? 44 : 20;

    private decimal MaxWeight => _weightUnit == "lbs" ? 772 : 350;

    protected override void OnInitialized()
    {
        Presence.OnChange += HandlePresenceChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        var state = await AuthState.GetAuthenticationStateAsync();
        if (state.User.Identity is not { IsAuthenticated: true })
        {
            try { Navigation.NavigateTo("/login", forceLoad: true); } catch { }
            return;
        }

        _userId = int.Parse(state.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)!.Value);
        _username = state.User.FindFirst("Username")?.Value ?? state.User.Identity.Name ?? "User";
        var settings = await SettingsSvc.GetSettingsAsync(_userId);
        _weightUnit = settings.WeightUnit;
        _equipment = await ProfileService.GetAllEquipmentAsync();
        _settings = CloneSettings(await ProfileService.GetProfileSettingsAsync(_userId));
        await LoadProfile();
        _isLoading = false;
        StateHasChanged();
    }

    private async Task LoadProfile()
    {
        var user = await ProfileService.GetUserWithProfileAsync(_userId);
        if (user is null) return;

        _user = user;
        _username = user.Username;
        _status = PresenceStatus.Normalize(user.Status);
        _avatarData = user.AvatarData;

        _data = new ProfileData
        {
            FullName = user.FullName,
            DateOfBirth = user.DateOfBirth,
            WeightKg = user.WeightKg,
            HeightCm = user.HeightCm,
            FitnessLevel = user.FitnessLevel,
            PrimaryGoal = user.PrimaryGoal,
            TrainingDaysPerWeek = user.TrainingDaysPerWeek,
            Bio = user.Bio,
            SelectedEquipmentIds = user.UserEquipment.Select(ue => ue.EquipmentId).ToList(),
            Injuries = user.Injuries.Select(i => new InjuryEntry
            {
                Description = i.Description,
                AffectedArea = i.AffectedArea,
                IsActive = i.IsActive
            }).ToList()
        };
        _dobString = user.DateOfBirth?.ToString("yyyy-MM-dd") ?? "";
    }

    private static ProfileSettings CloneSettings(ProfileSettings source) => new()
    {
        UserId = source.UserId,
        NameVisibility = source.NameVisibility,
        BioVisibility = source.BioVisibility,
        LevelVisibility = source.LevelVisibility,
        GoalVisibility = source.GoalVisibility,
        TrainingDaysVisibility = source.TrainingDaysVisibility,
        WeightVisibility = source.WeightVisibility,
        HeightVisibility = source.HeightVisibility,
        AgeVisibility = source.AgeVisibility,
        MemberSinceVisibility = source.MemberSinceVisibility,
        WorkoutsVisibility = source.WorkoutsVisibility
    };

    private string GetVisibility(string key) => key switch
    {
        "name" => _settings.NameVisibility,
        "bio" => _settings.BioVisibility,
        "level" => _settings.LevelVisibility,
        "goal" => _settings.GoalVisibility,
        "trainingDays" => _settings.TrainingDaysVisibility,
        "weight" => _settings.WeightVisibility,
        "height" => _settings.HeightVisibility,
        "age" => _settings.AgeVisibility,
        "memberSince" => _settings.MemberSinceVisibility,
        "workouts" => _settings.WorkoutsVisibility,
        _ => "notset"
    };

    private async Task SetVisibility(string key, string value)
    {
        switch (key)
        {
            case "name": _settings.NameVisibility = value; break;
            case "bio": _settings.BioVisibility = value; break;
            case "level": _settings.LevelVisibility = value; break;
            case "goal": _settings.GoalVisibility = value; break;
            case "trainingDays": _settings.TrainingDaysVisibility = value; break;
            case "weight": _settings.WeightVisibility = value; break;
            case "height": _settings.HeightVisibility = value; break;
            case "age": _settings.AgeVisibility = value; break;
            case "memberSince": _settings.MemberSinceVisibility = value; break;
            case "workouts": _settings.WorkoutsVisibility = value; break;
        }
        await ProfileService.SaveProfileSettingsAsync(_userId, _settings);
    }

    private bool IsVisibleInPreview(string key)
    {
        var visibility = GetVisibility(key);
        if (visibility == "public") return true;
        if (_previewFriends && visibility == "friends") return true;
        return false;
    }

    private string PreviewValue(string key) => key switch
    {
        "level" => _data.FitnessLevel?.ToString() ?? "",
        "goal" => _data.PrimaryGoal.HasValue ? FormatGoal(_data.PrimaryGoal.Value) : "",
        "trainingDays" => _data.TrainingDaysPerWeek.HasValue ? $"{_data.TrainingDaysPerWeek} days / week" : "",
        "weight" => DisplayWeight.HasValue ? $"{DisplayWeight.Value:0.#} {_weightUnit}" : "",
        "height" => _data.HeightCm.HasValue ? $"{_data.HeightCm.Value:0.#} cm" : "",
        "age" => AgeText,
        "memberSince" => MemberSinceText,
        _ => ""
    };

    private async Task OnAvatarSelected(InputFileChangeEventArgs e)
    {
        _avatarError = null;
        var file = e.File;
        if (file is null) return;

        const long maxBytes = 2 * 1024 * 1024;
        if (file.Size > maxBytes)
        {
            _avatarError = "Image must be 2 MB or smaller.";
            return;
        }

        if (string.IsNullOrEmpty(file.ContentType) || !file.ContentType.StartsWith("image/", StringComparison.OrdinalIgnoreCase))
        {
            _avatarError = "Please choose an image file.";
            return;
        }

        try
        {
            using var stream = file.OpenReadStream(maxBytes);
            using var ms = new MemoryStream();
            await stream.CopyToAsync(ms);
            var dataUri = $"data:{file.ContentType};base64,{Convert.ToBase64String(ms.ToArray())}";
            await ProfileService.UpdateAvatarAsync(_userId, dataUri);
            _avatarData = dataUri;
            Presence.NotifyChanged();
        }
        catch
        {
            _avatarError = "Could not read that image. Please try another file.";
        }
    }

    private async Task RemoveAvatar()
    {
        _avatarError = null;
        await ProfileService.UpdateAvatarAsync(_userId, null);
        _avatarData = null;
        Presence.NotifyChanged();
    }

    private async Task SetStatus(string status)
    {
        _status = PresenceStatus.Normalize(status);
        await ProfileService.UpdateStatusAsync(_userId, _status);
        Presence.NotifyChanged();
    }

    private void HandlePresenceChanged()
    {
        InvokeAsync(async () =>
        {
            if (_userId == 0) return;
            var user = await ProfileService.GetUserAsync(_userId);
            if (user is not null)
            {
                _status = PresenceStatus.Normalize(user.Status);
                _avatarData = user.AvatarData;
            }
            StateHasChanged();
        });
    }

    private void StartEdit()
    {
        _message = null;
        _dobBackup = _dobString;
        _backup = new ProfileData
        {
            FullName = _data.FullName,
            DateOfBirth = _data.DateOfBirth,
            WeightKg = _data.WeightKg,
            HeightCm = _data.HeightCm,
            FitnessLevel = _data.FitnessLevel,
            PrimaryGoal = _data.PrimaryGoal,
            TrainingDaysPerWeek = _data.TrainingDaysPerWeek,
            Bio = _data.Bio,
            SelectedEquipmentIds = new List<int>(_data.SelectedEquipmentIds),
            Injuries = _data.Injuries.Select(i => new InjuryEntry
            {
                Description = i.Description,
                AffectedArea = i.AffectedArea,
                IsActive = i.IsActive
            }).ToList()
        };
        _isEditing = true;
    }

    private void CancelEdit()
    {
        _data = _backup;
        _dobString = _dobBackup;
        _isEditing = false;
        _message = null;
    }

    private async Task SaveProfile()
    {
        _isSaving = true;
        _message = null;

        if (string.IsNullOrWhiteSpace(_data.FullName))
        {
            _message = "Name is required.";
            _isError = true;
            _isSaving = false;
            return;
        }

        if (!string.IsNullOrEmpty(_dobString) && DateOnly.TryParse(_dobString, out var dob))
            _data.DateOfBirth = dob;

        var success = await ProfileService.UpdateProfileAsync(_userId, _data);

        if (success)
        {
            _message = "Profile updated successfully.";
            _isError = false;
            _isEditing = false;
            _user = await ProfileService.GetUserWithProfileAsync(_userId);
        }
        else
        {
            _message = "Failed to save. Please try again.";
            _isError = true;
        }

        _isSaving = false;
    }

    private void ToggleEquipment(int equipmentId)
    {
        if (!_isEditing) return;
        if (!_data.SelectedEquipmentIds.Remove(equipmentId))
            _data.SelectedEquipmentIds.Add(equipmentId);
    }

    private void AddInjury() => _data.Injuries.Add(new InjuryEntry());

    private void RemoveInjury(int index)
    {
        if (index >= 0 && index < _data.Injuries.Count)
            _data.Injuries.RemoveAt(index);
    }

    private void OnDobChanged(ChangeEventArgs e) => _dobString = e?.Value?.ToString() ?? "";

    private static string FormatGoal(PrimaryGoal goal) => goal switch
    {
        PrimaryGoal.FatLoss => "Fat Loss",
        PrimaryGoal.GeneralHealth => "General Health",
        _ => goal.ToString()
    };

    public void Dispose()
    {
        Presence.OnChange -= HandlePresenceChanged;
    }
}
